---
interface Props {
  id?: string;
  class?: string;
  align?: 'left' | 'center';
  /** When false, hides the ★ 5.0 reviews row + "No obligation…" line below the input. */
  showTrust?: boolean;
  /** 'light' for dark text on light backgrounds (default); 'dark' for light text on dark backgrounds (e.g. hero overlays). */
  theme?: 'light' | 'dark';
  /** When true with align='center', center on mobile only; left-align on desktop (lg+). */
  responsive?: boolean;
}
const { id = 'address-form', class: className = '', align = 'left', showTrust = true, theme = 'light', responsive = false } = Astro.props;
const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://app.flipsplit.com';
const trustStrong = theme === 'dark' ? 'text-white' : 'text-slate-400';
const trustSoft   = theme === 'dark' ? 'text-white/80' : 'text-slate-400';
const trustHint   = theme === 'dark' ? 'text-white/70' : 'text-slate-400';
const centerOnly  = align === 'center' && !responsive;
const centerResp  = align === 'center' && responsive;
const formCenter  = centerOnly ? 'mx-auto' : centerResp ? 'mx-auto lg:mx-0' : '';
const rowCenter   = centerOnly ? 'justify-center' : centerResp ? 'justify-center lg:justify-start' : '';
const textCenter  = centerOnly ? 'text-center' : centerResp ? 'text-center lg:text-left' : '';
---

<div class={className}>
  <!-- Shown only when a real (non-anonymous) account is already signed in.
       Makes it obvious why the funnel will attach to that account and gives
       a one-click escape hatch for users testing/retrying the flow. -->
  <div class:list={["address-signed-in hidden flex items-center justify-between gap-3 max-w-lg p-3 mb-3 rounded-xl border bg-blue-50 border-blue-100 text-sm", formCenter]}>
    <span class="text-slate-700 leading-snug">
      Signed in as <strong class="address-signed-in-email">your account</strong> — this property will be added to your dashboard.
    </span>
    <button
      type="button"
      class="address-signed-in-out shrink-0 font-semibold text-blue-600 hover:text-blue-700 disabled:opacity-60"
      style="color: #1e88e5;"
    >
      Not you? Sign out
    </button>
  </div>

  <form
    id={id}
    class:list={["address-form flex items-center bg-white rounded-2xl border border-slate-200 shadow-sm p-2 gap-2 w-full max-w-lg mb-3", formCenter]}
    novalidate
  >
    <input
      type="text"
      name="address"
      required
      placeholder="Enter your home address..."
      autocomplete="off"
      class="flex-1 text-[#1E2A3A] text-[17px] focus:outline-none bg-transparent min-w-0 py-4 px-4 placeholder-slate-400"
    />
    <button
      type="submit"
      aria-label="Get my offer"
      class="address-submit shrink-0 rounded-xl p-4 transition-all hover:brightness-110 disabled:opacity-60 disabled:cursor-wait"
      style="background: #1e88e5;"
    >
      <svg class="address-arrow w-5 h-5" style="color: #ffffff;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      <svg class="address-spinner hidden w-5 h-5 animate-spin" style="color: #ffffff;" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/>
        <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      </svg>
    </button>
  </form>

  <p class="address-error hidden text-xs text-red-500 font-medium mb-2"></p>

  <!-- Address-confirmation modal (one per AddressForm instance, hidden by default).
       Has two states: the default "confirm + unit number" form, and a
       "soft-block" state shown when the address is already on FlipSplit for a
       real account. The block state surfaces a sign-in CTA instead of letting
       the visitor start a duplicate funnel. -->
  <div class="address-modal hidden fixed inset-0 z-[100] flex items-center justify-center px-4 py-8" style="background: rgba(15, 23, 42, 0.55);">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 relative" role="dialog" aria-modal="true" aria-labelledby={`${id}-modal-title`}>
      <button type="button" class="address-modal-close absolute top-5 right-5 p-1 text-slate-400 hover:text-slate-700 transition-colors" aria-label="Close">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <!-- Default state: "is this your address?" -->
      <div class="address-modal-state-default">
        <h2 id={`${id}-modal-title`} class="text-2xl font-bold mb-6 pr-8" style="color:#1E2A3A; font-family:'sahar','Open Sans',sans-serif;">
          Is this the correct home address?
        </h2>

        <div class="rounded-2xl p-4 flex items-start justify-between gap-3 mb-6" style="background:#F1F5F9;">
          <p class="address-modal-address text-sm font-medium leading-relaxed flex-1" style="color:#1E2A3A; white-space: pre-line;"></p>
          <button type="button" class="address-modal-edit text-sm font-semibold shrink-0 hover:opacity-80 transition-opacity" style="color:#1e88e5;">Edit</button>
        </div>

        <label class="block">
          <span class="text-sm font-semibold text-slate-700">Unit, Apt, or Suite # <span class="text-slate-400 font-normal">(optional)</span></span>
          <input
            type="text"
            class="address-modal-unit mt-2 w-full border border-slate-300 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:border-[#1e88e5] transition-colors"
            placeholder="e.g. 30, 4B, Suite C"
            autocomplete="off"
            maxlength="20"
          />
        </label>
        <p class="text-xs text-slate-400 mt-2">Leave blank if your home is single-family.</p>

        <button
          type="button"
          class="address-modal-confirm w-full mt-6 text-white font-bold py-3.5 rounded-xl text-sm transition-all hover:brightness-110 disabled:opacity-60 disabled:cursor-wait"
          style="background:#1e88e5;"
        >
          <span class="address-modal-confirm-label">Confirm address</span>
        </button>
        <p class="address-modal-error hidden text-sm text-red-500 font-medium mt-3 text-center"></p>
      </div>

      <!-- Soft-block state: address already belongs to a real account -->
      <div class="address-modal-state-blocked hidden">
        <h2 class="text-2xl font-bold mb-3 pr-8" style="color:#1E2A3A; font-family:'sahar','Open Sans',sans-serif;">
          Looks like this home is already on FlipSplit
        </h2>
        <p class="text-sm text-slate-500 leading-relaxed mb-5">
          You've already started selling this property. Sign in to pick up where you left off.
        </p>

        <div class="rounded-2xl p-4 mb-6" style="background:#F1F5F9;">
          <p class="address-modal-blocked-address text-sm font-medium leading-relaxed" style="color:#1E2A3A; white-space: pre-line;"></p>
        </div>

        <a
          href={`${APP_URL}/login`}
          class="address-modal-signin block w-full text-center text-white font-bold py-3.5 rounded-xl text-sm transition-all hover:brightness-110"
          style="background:#1e88e5;"
        >
          Sign in
        </a>
        <button
          type="button"
          class="address-modal-different w-full mt-3 text-sm font-semibold text-slate-700 hover:text-slate-900 py-2 transition-colors"
        >
          Use a different address
        </button>
        <a
          href="mailto:hello@flipsplit.com?subject=I'm the new owner of a FlipSplit-listed property"
          class="address-modal-contact block text-center text-xs text-slate-400 hover:text-slate-600 mt-2 transition-colors"
        >
          Not the current owner? Contact us
        </a>
      </div>
    </div>
  </div>

  <!-- Full-screen "looking up your property" overlay. Shown for ~1.5s after the
       address is confirmed so the jump from modal → step 1 has a perceived-
       loading beat. The eager RentCast lookup is already in flight by this
       point, so this is purely UX pacing. -->
  <div class="address-loading-overlay hidden fixed inset-0 z-[150] flex-col items-center justify-center bg-white">
    <div class="progress-bar w-full absolute top-0 left-0" style="height: 4px; background: #1e88e5;"></div>
    <div class="address-loading-spinner mb-8" aria-hidden="true"></div>
    <h1 class="text-3xl md:text-4xl font-semibold mb-3 px-6 text-center" style="color:#1E2A3A; font-family:'sahar','Open Sans',sans-serif;">Looking up your property…</h1>
    <p class="text-base md:text-lg text-slate-500 max-w-md text-center px-6">Pulling public records so we can pre-fill what we know about your home.</p>
  </div>

  {showTrust && (
    <Fragment>
      <div class={`flex flex-wrap items-center gap-1.5 text-sm mb-1.5 ${rowCenter}`}>
        <span style="color: #FBBC05; letter-spacing: 1px;">★★★★★</span>
        <span class={`font-bold ${trustStrong}`}>5.0</span>
        <span class={trustSoft}>· Verified reviews on</span>
        <span class={`font-bold ${trustStrong}`}>REVIEWS.IO</span>
      </div>
      <p class={`text-xs ${trustHint} ${textCenter}`}>No obligation · No repairs needed · Results in 24–48 hours</p>
    </Fragment>
  )}
</div>

<style is:global>
  .pac-container {
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    font-family: 'Open Sans', sans-serif;
    margin-top: 4px;
    overflow: hidden;
  }
  .pac-item {
    padding: 10px 14px;
    font-size: 13px;
    color: #1E2A3A;
    cursor: pointer;
    border-top: 1px solid #f1f5f9;
  }
  .pac-item:first-child { border-top: none; }
  .pac-item:hover, .pac-item-selected { background: #F8FAFC; }
  .pac-icon { display: none; }
  .pac-item-query { font-weight: 600; color: #1E2A3A; }
  .pac-matched { color: #1e88e5; }

  /* Loading overlay (full-screen, shown briefly after address confirmation) */
  .address-loading-overlay { font-family: 'Open Sans', sans-serif; }
  .address-loading-overlay:not(.hidden) { display: flex; }
  .address-loading-spinner {
    width: 56px; height: 56px; border-radius: 50%;
    border: 4px solid #e2e8f0; border-top-color: #1e88e5;
    animation: address-loading-spin 0.85s linear infinite;
  }
  @keyframes address-loading-spin { to { transform: rotate(360deg); } }
</style>

<script>
  import { getSupabase } from '../lib/supabase';
  import { navigate } from 'astro:transitions/client';

  declare global {
    interface Window {
      __placesReady?: boolean;
      __placesQueue?: (() => void)[];
      __onPlacesReady?: () => void;
    }
  }

  // ── Helper: parse address components from a Google Places result ────────
  function parseAddressParts(place: google.maps.places.PlaceResult) {
    const parts: { street?: string; city?: string; state?: string; zip?: string } = {};
    const components = place.address_components || [];
    let streetNumber = '';
    let route = '';

    for (const c of components) {
      if (c.types.includes('street_number')) streetNumber = c.long_name;
      else if (c.types.includes('route')) route = c.long_name;
      else if (c.types.includes('locality')) parts.city = c.long_name;
      else if (c.types.includes('administrative_area_level_1')) parts.state = c.short_name;
      else if (c.types.includes('postal_code')) parts.zip = c.long_name;
    }
    if (streetNumber || route) parts.street = `${streetNumber} ${route}`.trim();
    return parts;
  }

  // Show/hide a "Signed in as <email>" banner above each AddressForm. Helps
  // testers (and any real returning user) see *why* the funnel will skip the
  // signup detour, and gives a one-click sign-out to start fresh. Runs once
  // per page-load; the auth state can also change mid-page via the sign-out
  // button, which re-hides the banner inline.
  async function refreshSignedInBanners() {
    const supabase = getSupabase();
    let email: string | null = null;
    try {
      const { data } = await supabase.auth.getUser();
      const u = data?.user;
      if (u && !u.is_anonymous) {
        email = (u.email as string) || (u.user_metadata?.email as string) || 'your account';
      }
    } catch { /* unauthenticated or network blip — leave banners hidden */ }

    document.querySelectorAll<HTMLElement>('.address-signed-in').forEach((banner) => {
      if (banner.dataset.bannerInit === '1' && !email) {
        banner.classList.add('hidden');
        return;
      }
      banner.dataset.bannerInit = '1';
      if (!email) { banner.classList.add('hidden'); return; }
      const emailEl = banner.querySelector<HTMLElement>('.address-signed-in-email');
      if (emailEl) emailEl.textContent = email;
      banner.classList.remove('hidden');
    });
  }

  function attachSignOutHandlers() {
    document.querySelectorAll<HTMLButtonElement>('.address-signed-in-out').forEach((btn) => {
      if (btn.dataset.signoutInit === '1') return;
      btn.dataset.signoutInit = '1';
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        try { await getSupabase().auth.signOut(); } catch { /* ignore */ }
        // Hide *all* banner instances on the page, not just the clicked one.
        document.querySelectorAll<HTMLElement>('.address-signed-in').forEach((b) => b.classList.add('hidden'));
        btn.disabled = false;
      });
    });
  }

  // ── Form lifecycle ──────────────────────────────────────────────────────
  function attachAutocomplete() {
    document.querySelectorAll<HTMLInputElement>('input[name="address"]').forEach((input) => {
      if (input.dataset.placesInit) return;
      input.dataset.placesInit = '1';

      let pickedPlace: google.maps.places.PlaceResult | null = null;

      // Background work kicked off the moment a place is picked. Returns a
      // discriminated union so we can react to three outcomes:
      //   - 'new'        — address is new; eager session row was inserted
      //   - 'existing'   — address already belongs to *this* signed-in user;
      //                    we'll deep-link them to its dashboard view
      //   - 'soft-block' — address already belongs to a different real account;
      //                    we'll show a Sign-in prompt in the modal
      type BgResult =
        | { kind: 'new'; sessionId: string }
        | { kind: 'existing'; sessionId: string }
        | { kind: 'soft-block' };
      let bgWork: { promise: Promise<BgResult>; address: string } | null = null;

      // Self-healing auth bootstrap. Reads existing session; falls back to a
      // fresh anonymous sign-in if the stored JWT points to a deleted user.
      async function ensureUserId(): Promise<string> {
        const supabase = getSupabase();
        const { data: existing, error: getUserErr } = await supabase.auth.getUser();
        if (existing?.user?.id && !getUserErr) return existing.user.id;
        try { await supabase.auth.signOut(); } catch { /* ignore */ }
        const { data: signin, error: authErr } = await supabase.auth.signInAnonymously();
        if (authErr) {
          throw new Error(
            authErr.message?.includes('Anonymous sign-ins are disabled')
              ? 'Anonymous sign-ins are disabled for this project. Enable them in Supabase → Authentication → Sign In/Up → "Allow anonymous sign-ins".'
              : `Sign-in failed: ${authErr.message}`
          );
        }
        const userId = signin?.user?.id;
        if (!userId) throw new Error('Could not establish a session. Please refresh and try again.');
        return userId;
      }

      // Wraps the place-picked side effects with a server-side check first:
      // if the address is already on FlipSplit for a real account, we *don't*
      // create a duplicate funnel session — we either deep-link (owner) or
      // soft-block (different account).
      async function checkOrEagerLookup(place: google.maps.places.PlaceResult): Promise<BgResult> {
        const supabase = getSupabase();
        let status: { exists?: boolean; is_owner?: boolean; session_id?: string } | null = null;
        try {
          const { data, error } = await supabase.rpc('check_address_status', {
            p_address: place.formatted_address!,
          });
          if (error) console.warn('check_address_status failed:', error.message);
          else status = data as any;
        } catch (e) {
          console.warn('check_address_status threw:', e);
        }

        if (status?.exists && status.is_owner && status.session_id) {
          return { kind: 'existing', sessionId: status.session_id };
        }
        if (status?.exists && !status.is_owner) {
          return { kind: 'soft-block' };
        }

        const sessionId = await startEagerLookup(place);
        return { kind: 'new', sessionId };
      }

      // Kicked off at place-picked. Auth → insert qualification_sessions row →
      // fire lookup-property (non-awaited). Resolves with the new session id.
      async function startEagerLookup(place: google.maps.places.PlaceResult): Promise<string> {
        const supabase = getSupabase();
        const userId = await ensureUserId();
        const parts = parseAddressParts(place);
        const { data: row, error: insertErr } = await supabase
          .from('qualification_sessions')
          .insert({
            user_id: userId,
            address: place.formatted_address!,
            street: parts.street,
            city: parts.city,
            state: parts.state,
            zip: parts.zip,
            current_step: 0,
          })
          .select('id')
          .single();
        if (insertErr) throw insertErr;
        // Fire the RentCast lookup immediately — non-awaited, runs server-side
        // while the user reads the modal.
        supabase.functions
          .invoke('lookup-property', { body: { session_id: row.id } })
          .catch((e: any) => console.warn('lookup-property invoke failed:', e));
        return row.id;
      }

      const ac = new (window as any).google.maps.places.Autocomplete(input, {
        types: ['address'],
        componentRestrictions: { country: 'us' },
        fields: ['formatted_address', 'address_components'],
      });

      const form = input.closest('form');
      if (!form) return;
      const wrap = form.parentElement; // outer <div class={className}>
      if (!wrap) return;

      // Modal elements (each AddressForm instance has its own sibling modal)
      const modal       = wrap.querySelector<HTMLElement>('.address-modal');
      const modalAddr   = wrap.querySelector<HTMLElement>('.address-modal-address');
      const modalUnit   = wrap.querySelector<HTMLInputElement>('.address-modal-unit');
      const modalConfirm= wrap.querySelector<HTMLButtonElement>('.address-modal-confirm');
      const modalLabel  = wrap.querySelector<HTMLElement>('.address-modal-confirm-label');
      const modalClose  = wrap.querySelector<HTMLButtonElement>('.address-modal-close');
      const modalEdit   = wrap.querySelector<HTMLButtonElement>('.address-modal-edit');
      const modalError  = wrap.querySelector<HTMLElement>('.address-modal-error');

      const stateDefault = wrap.querySelector<HTMLElement>('.address-modal-state-default');
      const stateBlocked = wrap.querySelector<HTMLElement>('.address-modal-state-blocked');
      const blockedAddr  = wrap.querySelector<HTMLElement>('.address-modal-blocked-address');
      const useDifferent = wrap.querySelector<HTMLButtonElement>('.address-modal-different');

      function showModalDefault(place: google.maps.places.PlaceResult) {
        if (modalAddr) modalAddr.textContent = place.formatted_address || '';
        if (modalUnit) modalUnit.value = '';
        if (modalError) modalError.classList.add('hidden');
        stateDefault?.classList.remove('hidden');
        stateBlocked?.classList.add('hidden');
      }
      function showModalBlocked(place: google.maps.places.PlaceResult) {
        if (blockedAddr) blockedAddr.textContent = place.formatted_address || '';
        stateBlocked?.classList.remove('hidden');
        stateDefault?.classList.add('hidden');
      }

      function openModal(place: google.maps.places.PlaceResult) {
        if (!modal) return;
        showModalDefault(place);
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => modalUnit?.focus(), 50);
      }
      function closeModal() {
        modal?.classList.add('hidden');
        document.body.style.overflow = '';
      }

      // "Use a different address" inside the soft-block state — close, clear,
      // and put the cursor back in the input so the user can pick another.
      useDifferent?.addEventListener('click', () => {
        closeModal();
        input.value = '';
        pickedPlace = null;
        bgWork = null;
        setTimeout(() => input.focus(), 50);
      });

      // Open modal as soon as the user picks an address from the dropdown.
      // ⚡ Also fires the background check + (conditional) RentCast lookup —
      // the check decides whether this is a new address (proceed), an existing
      // property of the signed-in user (deep-link to dashboard), or already
      // owned by a different account (soft-block in the modal).
      ac.addListener('place_changed', () => {
        const place = ac.getPlace();
        if (!place?.formatted_address) return;
        input.value = place.formatted_address;
        pickedPlace = place;
        input.setCustomValidity('');
        openModal(place);

        // Reuse existing background work if the address didn't change
        // (e.g. user closed the modal and re-submitted). Otherwise kick off
        // a fresh check.
        if (!bgWork || bgWork.address !== place.formatted_address) {
          bgWork = {
            address: place.formatted_address,
            promise: checkOrEagerLookup(place),
          };
          bgWork.promise.catch(() => { bgWork = null; }); // reset on failure
        }

        // The check resolves before the user can usually click Confirm; flip
        // the modal's UI as soon as we know the address is already claimed.
        // Guarded by pickedPlace identity so a fast user typing a new address
        // doesn't get a stale flip from a previous selection.
        const placeAtPick = place;
        bgWork.promise.then((result) => {
          if (pickedPlace !== placeAtPick) return; // user moved on
          if (result.kind === 'soft-block') showModalBlocked(placeAtPick);
          // 'existing' and 'new' both leave the default modal visible — the
          // Confirm handler dispatches on the same `result` when clicked.
        }).catch(() => { /* check failed — modal stays in default state */ });
      });

      input.addEventListener('input', () => {
        pickedPlace = null;
        bgWork = null; // user is typing a new query — abandon prior work
        input.setCustomValidity(
          input.value.trim() ? 'Please select an address from the dropdown suggestions.' : ''
        );
      });

      // Close modal — keeps the address in the input field AND keeps bgWork
      // so a re-open from the same address doesn't redo the lookup.
      modalClose?.addEventListener('click', closeModal);
      // Edit — close + clear so user can search again.
      modalEdit?.addEventListener('click', () => {
        closeModal();
        input.value = '';
        pickedPlace = null;
        bgWork = null; // explicit address change — drop the in-flight work
        setTimeout(() => input.focus(), 50);
      });
      // Esc + backdrop close
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal();
      });

      // Submit button — if a place is picked, re-open modal; otherwise show
      // the usual "select from dropdown" error.
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const errorEl = wrap.querySelector<HTMLElement>('.address-error');
        const showError = (msg: string) => {
          if (errorEl) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); }
        };
        errorEl?.classList.add('hidden');
        if (!input.value.trim()) return showError('Please enter your property address.');
        if (!pickedPlace) return showError('Please select an address from the dropdown suggestions.');
        openModal(pickedPlace);
      });

      // Confirm — by now the background lookup has either finished or is well
      // along. Wait for the session id, add unit_number if provided, then nav.
      modalConfirm?.addEventListener('click', async () => {
        if (!pickedPlace) return;
        const unitNumber = (modalUnit?.value || '').trim() || null;

        modalConfirm.setAttribute('disabled', 'true');
        if (modalLabel) modalLabel.textContent = 'Confirming…';
        if (modalError) modalError.classList.add('hidden');

        try {
          // Fallback: if the eager work never fired (rare — e.g. user pasted
          // a value without triggering place_changed), kick it off here.
          if (!bgWork) {
            bgWork = {
              address: pickedPlace.formatted_address!,
              promise: checkOrEagerLookup(pickedPlace),
            };
          }

          const result = await bgWork.promise;
          const supabase = getSupabase();

          // Soft-block: place_changed already flipped the modal to the Sign-in
          // prompt; Confirm shouldn't ever be visible here. Just bail.
          if (result.kind === 'soft-block') {
            modalConfirm.removeAttribute('disabled');
            if (modalLabel) modalLabel.textContent = 'Confirm address';
            return;
          }

          // Existing property owned by the signed-in caller — skip the funnel
          // and drop them directly onto that property's dashboard view.
          if (result.kind === 'existing') {
            closeModal();
            const overlay = wrap.querySelector<HTMLElement>('.address-loading-overlay');
            if (overlay) {
              overlay.classList.remove('hidden');
              document.body.style.overflow = 'hidden';
            }
            await new Promise((r) => setTimeout(r, 800));
            window.location.assign(`${APP_URL}/?session_id=${result.sessionId}`);
            return;
          }

          const sessionId = result.sessionId;

          // If the user typed a unit number, update the row and re-invoke the
          // lookup so it can fetch with the unit-aware address. (~10% of users.)
          if (unitNumber) {
            await supabase
              .from('qualification_sessions')
              .update({ unit_number: unitNumber })
              .eq('id', sessionId);
            supabase.functions
              .invoke('lookup-property', { body: { session_id: sessionId } })
              .catch((e: any) => console.warn('re-lookup-property invoke failed:', e));
          }

          // funnel_started analytics event (fire and forget).
          const { data: { user: authedUser } } = await supabase.auth.getUser();
          supabase.from('events')
            .insert({
              session_id: sessionId,
              user_id: authedUser?.id,
              event_name: 'funnel_started',
              payload: { address: pickedPlace.formatted_address, unit_number: unitNumber },
            })
            .then((res: any) => { if (res?.error) console.warn('funnel_started event failed:', res.error); });

          // Hide the modal and show a full-screen loading overlay so the
          // jump from "Confirm" → step 1 has perceived weight (~1.5s). The
          // actual backend work is already done by this point — this is pure
          // UX pacing.
          closeModal();
          const overlay = wrap.querySelector<HTMLElement>('.address-loading-overlay');
          if (overlay) {
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          }
          await new Promise((r) => setTimeout(r, 1500));

          // Off to step 1 — use Astro's transition router so the
          // homepage cross-fades into the funnel layout.
          navigate('/offer/step-1/');
        } catch (err: any) {
          console.error('Funnel start failed:', err);
          if (modalError) {
            modalError.textContent = err?.message || 'Something went wrong. Please try again.';
            modalError.classList.remove('hidden');
          }
          modalConfirm.removeAttribute('disabled');
          if (modalLabel) modalLabel.textContent = 'Confirm address';
          // Drop the failed bgWork so next click retries fresh.
          bgWork = null;
        }
      });
    });
  }

  // Banner init doesn't depend on Google Places, so kick it off immediately.
  attachSignOutHandlers();
  refreshSignedInBanners();
  // Re-run after Astro view transitions (e.g. user navigates from /about back
  // to / where another AddressForm renders). astro:page-load fires after each
  // navigation, including the initial load — so this also covers the
  // "scripts didn't re-execute" case.
  document.addEventListener('astro:page-load', () => {
    attachSignOutHandlers();
    refreshSignedInBanners();
  });

  // Lazy-load Google Places, then initialize all forms on the page
  if (!(window as any).google?.maps?.places) {
    window.__placesQueue = window.__placesQueue || [];
    window.__placesQueue.push(attachAutocomplete);
    if (!document.getElementById('gplaces-script')) {
      window.__onPlacesReady = () => {
        window.__placesReady = true;
        (window.__placesQueue || []).forEach((fn) => fn());
      };
      const s = document.createElement('script');
      s.id = 'gplaces-script';
      s.src = 'https://maps.googleapis.com/maps/api/js?key=AIzaSyArzPR5lnfheBpgpS98ZrQWO949cB1ty30&libraries=places&callback=__onPlacesReady';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }
  } else {
    attachAutocomplete();
  }
</script>
