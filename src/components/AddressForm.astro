---
interface Props {
  id?: string;
  class?: string;
  align?: 'left' | 'center';
}
const { id = 'address-form', class: className = '', align = 'left' } = Astro.props;
---

<div class={className}>
  <form
    id={id}
    class="address-form flex items-center bg-white rounded-2xl border border-slate-200 shadow-sm p-1.5 gap-2 w-full max-w-xl mb-3"
    novalidate
  >
    <input
      type="text"
      name="address"
      required
      placeholder="Enter your home address..."
      autocomplete="off"
      class="flex-1 text-[#1E2A3A] text-sm focus:outline-none bg-transparent min-w-0 py-2.5 px-3 placeholder-slate-400"
    />
    <button
      type="submit"
      aria-label="Get my offer"
      class="address-submit shrink-0 rounded-xl p-3 transition-all hover:brightness-110 disabled:opacity-60 disabled:cursor-wait"
      style="background: #1a96e8;"
    >
      <svg class="address-arrow w-5 h-5" style="color: #ffffff;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      <svg class="address-spinner hidden w-5 h-5 animate-spin" style="color: #ffffff;" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/>
        <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      </svg>
    </button>
  </form>

  <p class="address-error hidden text-xs text-red-500 font-medium mb-2"></p>

  <div class={`flex flex-wrap items-center gap-1.5 text-sm mb-1.5 ${align === 'center' ? 'justify-center' : ''}`}>
    <span style="color: #FBBC05; letter-spacing: 1px;">★★★★★</span>
    <span class="font-bold text-[#1E2A3A]">5.0</span>
    <span class="text-slate-400">· Verified reviews on</span>
    <span class="font-bold text-slate-400">REVIEWS.IO</span>
  </div>
  <p class={`text-xs text-slate-400 ${align === 'center' ? 'text-center' : ''}`}>No obligation · No repairs needed · Results in 24–48 hours</p>
</div>

<style is:global>
  .pac-container {
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    font-family: 'Open Sans', sans-serif;
    margin-top: 4px;
    overflow: hidden;
  }
  .pac-item {
    padding: 10px 14px;
    font-size: 13px;
    color: #1E2A3A;
    cursor: pointer;
    border-top: 1px solid #f1f5f9;
  }
  .pac-item:first-child { border-top: none; }
  .pac-item:hover, .pac-item-selected { background: #F8FAFC; }
  .pac-icon { display: none; }
  .pac-item-query { font-weight: 600; color: #1E2A3A; }
  .pac-matched { color: #1a96e8; }
</style>

<script>
  import { getSupabase } from '../lib/supabase';

  declare global {
    interface Window {
      __placesReady?: boolean;
      __placesQueue?: (() => void)[];
      __onPlacesReady?: () => void;
    }
  }

  // ── Helper: parse address components from a Google Places result ────────
  function parseAddressParts(place: google.maps.places.PlaceResult) {
    const parts: { street?: string; city?: string; state?: string; zip?: string } = {};
    const components = place.address_components || [];
    let streetNumber = '';
    let route = '';

    for (const c of components) {
      if (c.types.includes('street_number')) streetNumber = c.long_name;
      else if (c.types.includes('route')) route = c.long_name;
      else if (c.types.includes('locality')) parts.city = c.long_name;
      else if (c.types.includes('administrative_area_level_1')) parts.state = c.short_name;
      else if (c.types.includes('postal_code')) parts.zip = c.long_name;
    }
    if (streetNumber || route) parts.street = `${streetNumber} ${route}`.trim();
    return parts;
  }

  // ── Form lifecycle ──────────────────────────────────────────────────────
  function attachAutocomplete() {
    document.querySelectorAll<HTMLInputElement>('input[name="address"]').forEach((input) => {
      if (input.dataset.placesInit) return;
      input.dataset.placesInit = '1';

      let pickedPlace: google.maps.places.PlaceResult | null = null;

      const ac = new (window as any).google.maps.places.Autocomplete(input, {
        types: ['address'],
        componentRestrictions: { country: 'us' },
        fields: ['formatted_address', 'address_components'],
      });

      ac.addListener('place_changed', () => {
        const place = ac.getPlace();
        if (place?.formatted_address) {
          input.value = place.formatted_address;
          pickedPlace = place;
          input.setCustomValidity('');
        }
      });

      input.addEventListener('input', () => {
        pickedPlace = null;
        input.setCustomValidity(
          input.value.trim() ? 'Please select an address from the dropdown suggestions.' : ''
        );
      });

      const form = input.closest('form');
      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const errorEl = form.parentElement?.querySelector<HTMLElement>('.address-error');
        const submitBtn = form.querySelector<HTMLButtonElement>('.address-submit');
        const arrow = form.querySelector<SVGElement>('.address-arrow');
        const spinner = form.querySelector<SVGElement>('.address-spinner');

        const showError = (msg: string) => {
          if (errorEl) {
            errorEl.textContent = msg;
            errorEl.classList.remove('hidden');
          }
        };
        const clearError = () => errorEl?.classList.add('hidden');

        clearError();

        if (!input.value.trim()) {
          showError('Please enter your property address.');
          return;
        }
        if (!pickedPlace) {
          showError('Please select an address from the dropdown suggestions.');
          return;
        }

        // Show loading state
        submitBtn?.setAttribute('disabled', 'true');
        arrow?.classList.add('hidden');
        spinner?.classList.remove('hidden');

        try {
          const supabase = getSupabase();

          // 1. Sign in anonymously (or reuse existing session if any)
          const { data: sessionData } = await supabase.auth.getSession();
          if (!sessionData.session) {
            const { error: authErr } = await supabase.auth.signInAnonymously();
            if (authErr) throw authErr;
          }

          const { data: userData } = await supabase.auth.getUser();
          const userId = userData.user?.id;
          if (!userId) throw new Error('Could not establish anonymous session.');

          // 2. Insert qualification_sessions row
          const parts = parseAddressParts(pickedPlace);
          const { data: row, error: insertErr } = await supabase
            .from('qualification_sessions')
            .insert({
              user_id: userId,
              address: pickedPlace.formatted_address!,
              street: parts.street,
              city: parts.city,
              state: parts.state,
              zip: parts.zip,
              current_step: 0,
            })
            .select('id')
            .single();
          if (insertErr) throw insertErr;

          // 3. Fire event
          await supabase.from('events').insert({
            session_id: row.id,
            user_id: userId,
            event_name: 'funnel_started',
            payload: { address: pickedPlace.formatted_address },
          });

          // 4. Redirect to step 1
          window.location.assign('/offer/step-1/');
        } catch (err: any) {
          console.error('Funnel start failed:', err);
          showError(err?.message || 'Something went wrong. Please try again.');
          submitBtn?.removeAttribute('disabled');
          arrow?.classList.remove('hidden');
          spinner?.classList.add('hidden');
        }
      });
    });
  }

  // Lazy-load Google Places, then initialize all forms on the page
  if (!(window as any).google?.maps?.places) {
    window.__placesQueue = window.__placesQueue || [];
    window.__placesQueue.push(attachAutocomplete);
    if (!document.getElementById('gplaces-script')) {
      window.__onPlacesReady = () => {
        window.__placesReady = true;
        (window.__placesQueue || []).forEach((fn) => fn());
      };
      const s = document.createElement('script');
      s.id = 'gplaces-script';
      s.src = 'https://maps.googleapis.com/maps/api/js?key=AIzaSyArzPR5lnfheBpgpS98ZrQWO949cB1ty30&libraries=places&callback=__onPlacesReady';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }
  } else {
    attachAutocomplete();
  }
</script>
