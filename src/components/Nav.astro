  <script>
    // Auth UI, scroll-driven state, and the mobile hamburger are all handled by
    // the shared, ClientRouter-safe handler at the bottom of this component.
  </script>
)}

<!-- Shared, ClientRouter-safe nav interactivity for both nav variants.
     Listeners live on `document`/`window`, which persist across Astro view-
     transition swaps, and elements are re-queried on each event. A run-once
     guard stops them from stacking, since ClientRouter re-executes inline
     scripts on every navigation. This replaces the old approach of binding
     straight to elements on first load, which silently died (no hamburger, no
     scroll-reveal) on every page reached by in-app navigation. -->
<script>
  import { getSupabase } from '../lib/supabase';

  if (!(window as any).__fsNavWired) {
    (window as any).__fsNavWired = true;

    // ── Mobile hamburger open/close (delegated) ──
    const fsSetMenu = (menu: HTMLElement | null, open: boolean) => {
      if (!menu) return;
      menu.classList.toggle('hidden', !open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    const FS_MENUS = [
      { toggle: 'menu-toggle',       close: 'menu-close',       menu: 'mobile-menu' },
      { toggle: 'solid-menu-toggle', close: 'solid-menu-close', menu: 'solid-mobile-menu' },
    ];

    document.addEventListener('click', (e) => {
      const el = e.target instanceof Element ? e.target : null;
      if (!el) return;
      for (const m of FS_MENUS) {
        const menu = document.getElementById(m.menu);
        // Tap the hamburger → toggle that variant's menu.
        if (el.closest('#' + m.toggle)) {
          fsSetMenu(menu, menu?.classList.contains('hidden') ?? false);
          return;
        }
        // Tap the X, or any link inside an open menu → close it.
        const anchor = el.closest('a[href]');
        if (el.closest('#' + m.close) || (anchor && menu?.contains(anchor))) {
          fsSetMenu(menu, false);
          return;
        }
      }
    });

    // ── Scroll state: past the hero (480px) the bar goes white and reveals
    //    the address form. Re-queries elements each call so it targets the
    //    current page's nav after a ClientRouter swap. ──
    const fsApplyNavScroll = () => {
      const scrolled = window.scrollY > 480;

      // Transparent variant (homepage hero overlay).
      const nav = document.getElementById('main-nav');
      if (nav) {
        const logo = document.getElementById('nav-logo') as HTMLImageElement | null;
        const links = document.getElementById('nav-links');
        const form = document.getElementById('nav-offer-form-wrap');
        nav.classList.toggle('nav-light', scrolled);
        nav.style.background = scrolled ? '#ffffff' : 'transparent';
        if (logo) logo.src = scrolled ? '/wordmark-on-white.png' : '/wordmark-dark.png';
        if (links) links.style.display = scrolled ? 'none' : '';
        if (form) form.style.display = scrolled ? 'flex' : 'none';
      }

      // Solid variant (every other page).
      const solidNav = document.getElementById('solid-nav');
      if (solidNav) {
        const links = document.getElementById('solid-nav-links');
        const form = document.getElementById('solid-nav-offer-form-wrap');
        solidNav.classList.toggle('nav-light', scrolled);
        solidNav.style.background = scrolled ? '#ffffff' : '';
        if (links) links.style.display = scrolled ? 'none' : '';
        if (form) form.style.display = scrolled ? 'flex' : 'none';
      }
    };

    window.addEventListener('scroll', fsApplyNavScroll, { passive: true });
    window.addEventListener('resize', fsApplyNavScroll);
    // Re-apply on initial load and after every ClientRouter navigation.
    document.addEventListener('astro:page-load', fsApplyNavScroll);
    fsApplyNavScroll();

    // ── Auth UI: swap the "Sign in" link for a profile icon + sign-out when
    //    logged in. We subscribe once, cache the user, and re-apply to the
    //    (re-created) DOM on every navigation. Dropdown toggle, outside-click
    //    close, and sign-out are delegated so they survive ClientRouter swaps.
    //    Handles both nav variants by id prefix: 't' (transparent), 's' (solid).
    const fsSupabase = getSupabase();
    let fsUser: any = null;

    const fsApplyAuthFor = (p: string) => {
      const wrap = document.getElementById(`${p}-profile-wrap`);
      if (!wrap) return; // this variant isn't the one rendered on this page
      const signin   = document.getElementById(`${p}-signin-link`);
      const img      = document.getElementById(`${p}-profile-avatar`) as HTMLImageElement | null;
      const initEl   = document.getElementById(`${p}-profile-initial`);
      const menu     = document.getElementById(`${p}-profile-menu`);
      const emailEl  = document.getElementById(`${p}-profile-email`);
      const mSignin  = document.getElementById(`${p}-mobile-signin-link`);
      const mSignout = document.getElementById(`${p}-mobile-signout-btn`);
      const mProfile = document.getElementById(`${p}-mobile-profile`);
      const mImg     = document.getElementById(`${p}-mobile-profile-avatar`) as HTMLImageElement | null;
      const mInit    = document.getElementById(`${p}-mobile-profile-initial`);
      const mEmail   = document.getElementById(`${p}-mobile-profile-email`);

      const signedIn = !!fsUser && !fsUser.is_anonymous;
      if (signedIn) {
        // Hide "Sign in", show the profile button at md+ only. Use !important
        // because the `.nav-light #*-signin-link` scrolled-bar rule forces the
        // link visible with !important and would otherwise win over a plain
        // inline style — leaving "Sign in" showing for logged-in users.
        if (signin) signin.style.setProperty('display', 'none', 'important');
        wrap.classList.remove('hidden');
        wrap.style.display = window.innerWidth >= 768 ? 'block' : 'none';
        // Mobile menu: swap the Sign in link for the profile row + Sign out.
        mSignin?.classList.add('hidden');
        mSignout?.classList.remove('hidden');
        mProfile?.classList.remove('hidden');
        if (mProfile) mProfile.style.display = 'flex';
        const email = fsUser.email || '';
        if (emailEl) emailEl.textContent = email;
        if (mEmail) mEmail.textContent = email;
        const avatarUrl = fsUser.user_metadata?.avatar_url || fsUser.user_metadata?.picture;
        if (avatarUrl) {
          if (img) { img.src = avatarUrl; img.classList.remove('hidden'); }
          if (mImg) { mImg.src = avatarUrl; mImg.classList.remove('hidden'); }
          initEl?.classList.add('hidden');
          mInit?.classList.add('hidden');
        } else {
          img?.classList.add('hidden');
          mImg?.classList.add('hidden');
          initEl?.classList.remove('hidden');
          mInit?.classList.remove('hidden');
          const initial = (email[0] || 'U').toUpperCase();
          if (initEl) initEl.textContent = initial;
          if (mInit) mInit.textContent = initial;
        }
      } else {
        if (signin) signin.style.removeProperty('display');
        wrap.classList.add('hidden');
        wrap.style.display = '';
        mSignin?.classList.remove('hidden');
        mSignout?.classList.add('hidden');
        mProfile?.classList.add('hidden');
        if (mProfile) mProfile.style.display = '';
        menu?.classList.add('hidden');
      }
    };

    const fsApplyAuth = () => { fsApplyAuthFor('t'); fsApplyAuthFor('s'); };

    document.addEventListener('click', (e) => {
      const el = e.target instanceof Element ? e.target : null;
      if (!el) return;
      // Profile button → toggle that variant's dropdown.
      const btn = el.closest('#t-profile-btn, #s-profile-btn') as HTMLElement | null;
      if (btn) {
        const p = btn.id.charAt(0);
        const menu = document.getElementById(`${p}-profile-menu`);
        const willShow = menu?.classList.contains('hidden') ?? false;
        menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(willShow));
        return;
      }
      // Any sign-out button (desktop dropdown or mobile menu).
      if (el.closest('#t-signout-btn, #s-signout-btn, #t-mobile-signout-btn, #s-mobile-signout-btn')) {
        fsSupabase.auth.signOut().then(() => window.location.assign('/'));
        return;
      }
      // Click anywhere outside an open dropdown → close it.
      for (const p of ['t', 's']) {
        const wrap = document.getElementById(`${p}-profile-wrap`);
        if (wrap && !wrap.contains(el)) {
          document.getElementById(`${p}-profile-menu`)?.classList.add('hidden');
          document.getElementById(`${p}-profile-btn`)?.setAttribute('aria-expanded', 'false');
        }
      }
    });

    // Keep the desktop profile button from showing at mobile widths.
    window.addEventListener('resize', () => {
      for (const p of ['t', 's']) {
        const wrap = document.getElementById(`${p}-profile-wrap`);
        if (wrap && wrap.style.display && wrap.style.display !== '') {
          wrap.style.display = window.innerWidth >= 768 ? 'block' : 'none';
        }
      }
    });

    fsSupabase.auth.getUser().then(({ data }) => { fsUser = data.user; fsApplyAuth(); });
    fsSupabase.auth.onAuthStateChange((_e, session) => { fsUser = session?.user || null; fsApplyAuth(); });
    document.addEventListener('astro:page-load', fsApplyAuth);
  }
</script>
