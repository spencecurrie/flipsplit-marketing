---
interface Props {
  variant?: 'solid' | 'transparent';
}
const { variant = 'solid' } = Astro.props;
---

<style is:global>
  /* ── Top-of-page navigation progress bar (Astro View Transitions) ── */
  #nav-progress-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 3px;
    z-index: 9999;
    pointer-events: none;
    transform-origin: 0 50%;
    transform: scaleX(0);
    opacity: 0;
    transition: transform 0.25s ease, opacity 0.2s ease;
    background: linear-gradient(90deg, #1e88e5 0%, #4ba2ef 100%);
    box-shadow: 0 0 6px rgba(30,136,229,0.45);
  }
  #nav-progress-bar.is-loading {
    opacity: 1;
    transform: scaleX(0.7);
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.15s ease;
  }
  #nav-progress-bar.is-done {
    opacity: 1;
    transform: scaleX(1);
    transition: transform 0.18s ease-out, opacity 0.3s ease 0.15s;
  }
  #nav-progress-bar.is-done.is-fade {
    opacity: 0;
  }

  /* Slightly slower default fade between pages so navigation feels intentional */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 320ms;
  }
</style>
<style>
  .nav-btn { background: #1e88e5; color: #fff; font-weight: 700; font-size: 0.875rem; padding: 0.625rem 1.25rem; border-radius: 8px; transition: filter 0.15s; white-space: nowrap; }
  .nav-btn:hover { filter: brightness(1.08); }
  .nav-dropdown-wrap { position: relative; }
  .nav-dropdown { position: absolute; top: calc(100% + 12px); left: 0; width: 14rem; border-radius: 12px; overflow: hidden; opacity: 0; visibility: hidden; transition: opacity 0.2s, visibility 0.2s; z-index: 60; background: #1E2A3A; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 16px 40px rgba(0,0,0,0.2); }
  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown-wrap:focus-within .nav-dropdown { opacity: 1; visibility: visible; }
  .nav-chevron { transition: transform 0.2s; display: inline-block; }
  .nav-dropdown-wrap:hover .nav-chevron { transform: rotate(180deg); }
  .nav-drop-item { display: block; padding: 0.75rem 1rem; font-size: 0.875rem; color: rgba(255,255,255,0.8); transition: background 0.15s, color 0.15s; border-top: 1px solid rgba(255,255,255,0.08); }
  .nav-drop-item:first-child { border-top: none; }
  .nav-drop-item:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .mobile-dropdown > summary { list-style: none; cursor: pointer; }
  .mobile-dropdown > summary::-webkit-details-marker { display: none; }
  .mobile-dropdown[open] .mobile-chevron { transform: rotate(90deg); }
  .mobile-chevron { transition: transform 0.2s; }

  /* ── Light-theme override for the scrolled-mobile state ── */
  #main-nav.nav-light { border-bottom: 1px solid #e2e8f0; }
  #main-nav.nav-light #nav-offer-form-wrap .field {
    background: #F1F5F9;
    border: 1px solid #E2E8F0;
  }
  #main-nav.nav-light #nav-offer-form-wrap input {
    color: #0f172a;
  }
  #main-nav.nav-light #nav-offer-form-wrap input::placeholder { color: #94a3b8; }
  #main-nav.nav-light #nav-offer-form-wrap .submit-icon {
    background: #1e88e5;
    color: #fff;
  }
  #main-nav.nav-light #t-signin-link {
    display: inline-block;
    color: #0f172a;
    font-size: 0.875rem;
  }
  #main-nav.nav-light #menu-toggle { color: #0f172a; }
</style>

<!-- Top progress bar — controlled by Astro View Transitions lifecycle below -->
<div id="nav-progress-bar" data-astro-transition-persist="nav-progress-bar"></div>

{variant === 'transparent' ? (
  <!-- ─── TRANSPARENT NAV (homepage) ─── -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: transparent;">
    <div class="max-w-[1500px] mx-auto px-6 h-20 flex items-center gap-3 md:gap-0">
      <div class="shrink-0 md:flex-1">
        <a href="/"><img id="nav-logo" src="/wordmark-dark.png" alt="FlipSplit" class="h-9" /></a>
      </div>

      <div id="nav-links" class="hidden md:flex items-center gap-8 text-[15px] font-medium">
        <a href="/how-it-works/" class="text-white/90 hover:text-white transition-colors">Sell</a>
        <div class="nav-dropdown-wrap">
          <button class="flex items-center gap-1 text-white/90 hover:text-white transition-colors text-[15px] font-medium">
            Where We Buy <svg class="nav-chevron mt-0.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-dropdown">
            <a href="/location-la-county/" class="nav-drop-item">Los Angeles County</a>
            <a href="/location-orange-county/" class="nav-drop-item">Orange County</a>
            <a href="/location-riverside-county/" class="nav-drop-item">Riverside County</a>
            <a href="/location-san-bernardino-county/" class="nav-drop-item">San Bernardino County</a>
            <a href="/location-san-diego-county/" class="nav-drop-item">San Diego County</a>
          </div>
        </div>
        <a href="/reviews/" class="text-white/90 hover:text-white transition-colors">Reviews</a>
      </div>

      <div id="nav-offer-form-wrap" class="hidden min-w-0 flex-1 md:flex-[5] md:max-w-4xl md:mx-auto">
        <form action="/" method="get" class="w-full">
          <div class="field flex items-center rounded-xl overflow-hidden border border-white/20" style="background: rgba(255,255,255,0.1);">
            <input type="text" name="address" placeholder="Enter home address" class="flex-1 min-w-0 bg-transparent text-white text-sm placeholder:text-white/60 focus:outline-none px-3 md:px-4 py-2.5" />
            <!-- Compact icon submit (visible on mobile) -->
            <button type="submit" class="submit-icon md:hidden shrink-0 w-9 h-9 mr-1.5 flex items-center justify-center rounded-lg transition-transform active:scale-95" aria-label="Search">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
            <!-- Wider "Get My Offer" button (desktop only) -->
            <button type="submit" class="hidden md:inline-flex shrink-0 text-white text-xs font-bold px-4 py-2.5 transition-all hover:bg-white/10 whitespace-nowrap rounded-lg" style="border: 1.5px solid rgba(255,255,255,0.7); background: transparent;">
              Get My Offer
            </button>
          </div>
        </form>
      </div>

      <div id="nav-right" class="shrink-0 md:flex-1 flex items-center justify-end gap-3 md:gap-5">
        <a id="t-signin-link" href="/sign-in/" class="hidden md:inline-block text-white/90 hover:text-white transition-colors text-[15px] font-medium">Sign in</a>
        <div id="t-profile-wrap" class="hidden relative">
          <button id="t-profile-btn" class="flex items-center justify-center w-9 h-9 rounded-full overflow-hidden hover:opacity-90 transition-opacity" style="background:#1e88e5;" aria-label="Account menu" aria-expanded="false">
            <img id="t-profile-avatar" alt="" class="w-full h-full object-cover hidden" />
            <span id="t-profile-initial" class="text-sm font-bold text-white">U</span>
          </button>
          <div id="t-profile-menu" class="hidden absolute right-0 top-12 w-56 bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden" style="z-index:100;">
            <div class="px-4 py-3 border-b border-slate-100">
              <p class="text-xs text-slate-400">Signed in as</p>
              <p id="t-profile-email" class="text-sm font-semibold text-slate-700 truncate"></p>
            </div>
            <button id="t-signout-btn" class="w-full text-left px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">Sign out</button>
          </div>
        </div>
        <button id="menu-toggle" class="md:hidden p-2 text-white transition-colors" aria-label="Toggle menu">
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden fixed inset-0 bg-white z-[60] flex flex-col">
      <div class="flex items-center justify-between px-6 h-20 border-b border-slate-100 shrink-0">
        <a href="/"><img src="/wordmark-on-white.png" alt="FlipSplit" class="h-9" /></a>
        <button id="menu-close" class="p-2 text-slate-700" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="t-mobile-profile" class="hidden items-center gap-3 px-6 py-5 border-b border-slate-200 shrink-0" style="background:#F8FAFC;">
        <div class="w-10 h-10 rounded-full flex items-center justify-center overflow-hidden shrink-0" style="background:#1e88e5;">
          <img id="t-mobile-profile-avatar" alt="" class="w-full h-full object-cover hidden" />
          <span id="t-mobile-profile-initial" class="text-sm font-bold text-white">U</span>
        </div>
        <p id="t-mobile-profile-email" class="font-semibold text-slate-900 truncate"></p>
      </div>
      <div class="flex-1 overflow-y-auto px-6">
        <a href="/how-it-works/" class="mobile-nav-link flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Sell</a>
        <details class="mobile-dropdown border-b border-slate-200">
          <summary class="flex items-center justify-between py-6 text-2xl font-medium text-slate-900 cursor-pointer">
            <span>Where We Buy</span>
            <svg class="mobile-chevron text-slate-700" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
          </summary>
          <div class="pb-5 ml-1 space-y-1">
            <a href="/location-la-county/" class="mobile-nav-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">Los Angeles County</a>
            <a href="/location-orange-county/" class="mobile-nav-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">Orange County</a>
            <a href="/location-riverside-county/" class="mobile-nav-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">Riverside County</a>
            <a href="/location-san-bernardino-county/" class="mobile-nav-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">San Bernardino County</a>
            <a href="/location-san-diego-county/" class="mobile-nav-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">San Diego County</a>
          </div>
        </details>
        <a href="/reviews/" class="mobile-nav-link flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Reviews</a>
        <a id="t-mobile-signin-link" href="/sign-in/" class="mobile-nav-link flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Sign in</a>
        <button id="t-mobile-signout-btn" class="hidden w-full text-left flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Sign out</button>
      </div>
      <div class="p-6 shrink-0">
        <a href="#get-offer" class="mobile-nav-link flex items-center justify-between gap-3 p-4 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div>
            <div class="font-bold text-slate-900 text-base">Ready to get started?</div>
            <div class="text-sm text-slate-500 mt-0.5">Get your free offer in 24–48 hours</div>
          </div>
          <svg class="text-slate-700 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <script>
    import { getSupabase } from '../lib/supabase';

    // ── Nav progress bar wired to Astro View Transitions lifecycle ──
    // Visible flash of progress + slight delay on every internal click so
    // navigation feels intentional. Bar element lives in Nav (persisted).
    {
      const showBar = () => {
        const bar = document.getElementById('nav-progress-bar');
        if (!bar) return;
        bar.classList.remove('is-done', 'is-fade');
        // force reflow so transition restarts
        // eslint-disable-next-line @typescript-eslint/no-unused-expressions
        bar.offsetWidth;
        bar.classList.add('is-loading');
      };
      const completeBar = () => {
        const bar = document.getElementById('nav-progress-bar');
        if (!bar) return;
        bar.classList.remove('is-loading');
        bar.classList.add('is-done');
        // brief moment at 100%, then fade
        setTimeout(() => bar.classList.add('is-fade'), 120);
        // and finally reset
        setTimeout(() => {
          bar.classList.remove('is-done', 'is-fade');
        }, 600);
      };
      document.addEventListener('astro:before-preparation', showBar);
      document.addEventListener('astro:after-swap', completeBar);
      document.addEventListener('astro:page-load', completeBar);
    }

    const nav = document.getElementById('main-nav') as HTMLElement;
    const navLinks = document.getElementById('nav-links') as HTMLElement;
    const navOfferFormWrap = document.getElementById('nav-offer-form-wrap') as HTMLElement;
    const navRight = document.getElementById('nav-right') as HTMLElement;
    const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
    const iconOpen = document.getElementById('icon-open') as HTMLElement;
    const iconClose = document.getElementById('icon-close') as HTMLElement;

    // ─── Auth state: swap Sign in link with profile icon when logged in ───
    const tSignin       = document.getElementById('t-signin-link') as HTMLAnchorElement;
    const tProfileWrap  = document.getElementById('t-profile-wrap') as HTMLElement;
    const tProfileBtn   = document.getElementById('t-profile-btn') as HTMLButtonElement;
    const tProfileImg   = document.getElementById('t-profile-avatar') as HTMLImageElement;
    const tProfileInit  = document.getElementById('t-profile-initial') as HTMLElement;
    const tProfileMenu  = document.getElementById('t-profile-menu') as HTMLElement;
    const tProfileEmail = document.getElementById('t-profile-email') as HTMLElement;
    const tSignoutBtn   = document.getElementById('t-signout-btn') as HTMLButtonElement;
    const tMSignin      = document.getElementById('t-mobile-signin-link') as HTMLAnchorElement;
    const tMSignout     = document.getElementById('t-mobile-signout-btn') as HTMLButtonElement;
    const tSupabase = getSupabase();

    const tMProfile     = document.getElementById('t-mobile-profile') as HTMLElement;
    const tMProfileImg  = document.getElementById('t-mobile-profile-avatar') as HTMLImageElement;
    const tMProfileInit = document.getElementById('t-mobile-profile-initial') as HTMLElement;
    const tMProfileEmail= document.getElementById('t-mobile-profile-email') as HTMLElement;

    function tApplyAuth(user: any) {
      const signedIn = !!user && !user.is_anonymous;
      if (signedIn) {
        // Desktop: hide Sign in text (inline beats md:inline-block), show
        // profile button only at md+ (don't show on mobile — that's what the
        // hamburger menu is for).
        tSignin.style.display = 'none';
        tProfileWrap.classList.remove('hidden');
        tProfileWrap.style.display = window.innerWidth >= 768 ? 'block' : 'none';
        // Mobile menu: swap Sign in link for the profile row + Sign out.
        tMSignin.classList.add('hidden');
        tMSignout.classList.remove('hidden');
        tMProfile.classList.remove('hidden');
        tMProfile.style.display = 'flex';
        const email = user.email || '';
        tProfileEmail.textContent = email;
        tMProfileEmail.textContent = email;
        const avatarUrl = user.user_metadata?.avatar_url || user.user_metadata?.picture;
        if (avatarUrl) {
          tProfileImg.src = avatarUrl;
          tMProfileImg.src = avatarUrl;
          tProfileImg.classList.remove('hidden');
          tMProfileImg.classList.remove('hidden');
          tProfileInit.classList.add('hidden');
          tMProfileInit.classList.add('hidden');
        } else {
          tProfileImg.classList.add('hidden');
          tMProfileImg.classList.add('hidden');
          tProfileInit.classList.remove('hidden');
          tMProfileInit.classList.remove('hidden');
          const initial = (email[0] || 'U').toUpperCase();
          tProfileInit.textContent = initial;
          tMProfileInit.textContent = initial;
        }
      } else {
        tSignin.style.display = '';
        tProfileWrap.classList.add('hidden');
        tProfileWrap.style.display = '';
        tMSignin.classList.remove('hidden');
        tMSignout.classList.add('hidden');
        tMProfile.classList.add('hidden');
        tMProfile.style.display = '';
        tProfileMenu.classList.add('hidden');
      }
    }
    // Keep mobile-vs-desktop visibility correct on viewport resize.
    window.addEventListener('resize', () => {
      if (tProfileWrap.style.display && tProfileWrap.style.display !== '') {
        tProfileWrap.style.display = window.innerWidth >= 768 ? 'block' : 'none';
      }
    });
    tSupabase.auth.getUser().then(({ data }) => tApplyAuth(data.user));
    tSupabase.auth.onAuthStateChange((_event, session) => tApplyAuth(session?.user || null));

    tProfileBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const willShow = tProfileMenu.classList.contains('hidden');
      tProfileMenu.classList.toggle('hidden');
      tProfileBtn.setAttribute('aria-expanded', String(willShow));
    });
    document.addEventListener('click', (e) => {
      if (!tProfileWrap.contains(e.target as Node)) {
        tProfileMenu.classList.add('hidden');
        tProfileBtn.setAttribute('aria-expanded', 'false');
      }
    });

    async function tHandleSignOut() {
      await tSupabase.auth.signOut();
      window.location.assign('/');
    }
    tSignoutBtn.addEventListener('click', tHandleSignOut);
    tMSignout.addEventListener('click', tHandleSignOut);

    const navLogo = document.getElementById('nav-logo') as HTMLImageElement;

    function updateNav() {
      const scrolled = window.scrollY > 80;
      const isMobile = window.innerWidth < 768;
      if (scrolled) {
        navLinks.style.display = 'none';
        navOfferFormWrap.style.display = 'flex';
        if (isMobile) {
          // White nav: logo dark, form + sign-in + hamburger all visible
          nav.classList.add('nav-light');
          nav.style.background = '#ffffff';
          if (navLogo) navLogo.src = '/wordmark-on-white.png';
          navRight.style.display = '';
        } else {
          // Existing dark scrolled state (desktop)
          nav.classList.remove('nav-light');
          nav.style.background = '#1E2A3A';
          if (navLogo) navLogo.src = '/wordmark-dark.png';
          navRight.style.display = 'none';
        }
      } else {
        // Top of page — transparent over hero
        nav.classList.remove('nav-light');
        nav.style.background = 'transparent';
        if (navLogo) navLogo.src = '/wordmark-dark.png';
        navLinks.style.display = '';
        navRight.style.display = '';
        navOfferFormWrap.style.display = 'none';
      }
    }

    window.addEventListener('scroll', updateNav);
    window.addEventListener('resize', updateNav);
    updateNav();

    function closeMobileMenu() {
      mobileMenu.classList.add('hidden');
      document.body.style.overflow = '';
    }

    menuToggle.addEventListener('click', () => {
      const willOpen = mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      document.body.style.overflow = willOpen ? 'hidden' : '';
    });

    document.getElementById('menu-close')?.addEventListener('click', closeMobileMenu);

    mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMobileMenu);
    });
  </script>
) : (
  <!-- ─── SOLID NAV (all other pages — mirrors homepage scroll behavior) ─── -->
  <nav id="solid-nav" class="sticky top-0 z-50 bg-white border-b border-slate-100 transition-all duration-300">
    <div class="max-w-[1500px] mx-auto px-6 h-16 flex items-center">
      <div class="flex-1">
        <a href="/"><img id="solid-nav-logo" src="/wordmark-on-white.png" alt="FlipSplit" class="h-9" /></a>
      </div>

      <div id="solid-nav-links" class="hidden md:flex items-center gap-8 text-[15px] text-slate-500 font-medium">
        <a href="/how-it-works/" class="hover:text-[#1E2A3A] transition-colors">Sell</a>
        <div class="nav-dropdown-wrap">
          <button class="flex items-center gap-1 text-slate-500 hover:text-[#1E2A3A] transition-colors text-[15px] font-medium">
            Where We Buy <svg class="nav-chevron mt-0.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-dropdown">
            <a href="/location-la-county/" class="nav-drop-item">Los Angeles County</a>
            <a href="/location-orange-county/" class="nav-drop-item">Orange County</a>
            <a href="/location-riverside-county/" class="nav-drop-item">Riverside County</a>
            <a href="/location-san-bernardino-county/" class="nav-drop-item">San Bernardino County</a>
            <a href="/location-san-diego-county/" class="nav-drop-item">San Diego County</a>
          </div>
        </div>
        <a href="/reviews/" class="hover:text-[#1E2A3A] transition-colors">Reviews</a>
      </div>

      <div id="solid-nav-offer-form-wrap" class="hidden flex-[5] max-w-4xl mx-auto">
        <form>
          <div class="flex items-center rounded-xl overflow-hidden border border-white/20" style="background: rgba(255,255,255,0.1);">
            <input type="text" name="address" placeholder="Enter your home address..." class="flex-1 bg-transparent text-white text-sm placeholder:text-white/50 focus:outline-none px-4 py-2.5" />
            <button type="submit" class="shrink-0 text-white text-xs font-bold px-4 py-2.5 transition-all hover:bg-white/10 whitespace-nowrap rounded-lg" style="border: 1.5px solid rgba(255,255,255,0.7); background: transparent;">
              Get My Offer
            </button>
          </div>
        </form>
      </div>

      <div id="solid-nav-right" class="flex-1 flex items-center justify-end gap-5">
        <a id="s-signin-link" href="/sign-in/" class="hidden md:inline-block text-slate-500 hover:text-[#1E2A3A] transition-colors text-[15px] font-medium">Sign in</a>
        <div id="s-profile-wrap" class="hidden relative">
          <button id="s-profile-btn" class="flex items-center justify-center w-9 h-9 rounded-full overflow-hidden hover:opacity-90 transition-opacity" style="background:#1e88e5;" aria-label="Account menu" aria-expanded="false">
            <img id="s-profile-avatar" alt="" class="w-full h-full object-cover hidden" />
            <span id="s-profile-initial" class="text-sm font-bold text-white">U</span>
          </button>
          <div id="s-profile-menu" class="hidden absolute right-0 top-12 w-56 bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden" style="z-index:100;">
            <div class="px-4 py-3 border-b border-slate-100">
              <p class="text-xs text-slate-400">Signed in as</p>
              <p id="s-profile-email" class="text-sm font-semibold text-slate-700 truncate"></p>
            </div>
            <button id="s-signout-btn" class="w-full text-left px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">Sign out</button>
          </div>
        </div>
        <button id="solid-menu-toggle" class="md:hidden p-2 text-slate-600" aria-label="Toggle menu">
          <svg id="solid-icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="solid-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <div id="solid-mobile-menu" class="hidden md:hidden fixed inset-0 bg-white z-[60] flex flex-col">
      <div class="flex items-center justify-between px-6 h-16 border-b border-slate-100 shrink-0">
        <a href="/"><img src="/wordmark-on-white.png" alt="FlipSplit" class="h-9" /></a>
        <button id="solid-menu-close" class="p-2 text-slate-700" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="s-mobile-profile" class="hidden items-center gap-3 px-6 py-5 border-b border-slate-200 shrink-0" style="background:#F8FAFC;">
        <div class="w-10 h-10 rounded-full flex items-center justify-center overflow-hidden shrink-0" style="background:#1e88e5;">
          <img id="s-mobile-profile-avatar" alt="" class="w-full h-full object-cover hidden" />
          <span id="s-mobile-profile-initial" class="text-sm font-bold text-white">U</span>
        </div>
        <p id="s-mobile-profile-email" class="font-semibold text-slate-900 truncate"></p>
      </div>
      <div class="flex-1 overflow-y-auto px-6">
        <a href="/how-it-works/" class="solid-mobile-link flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Sell</a>
        <details class="mobile-dropdown border-b border-slate-200">
          <summary class="flex items-center justify-between py-6 text-2xl font-medium text-slate-900 cursor-pointer">
            <span>Where We Buy</span>
            <svg class="mobile-chevron text-slate-700" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
          </summary>
          <div class="pb-5 ml-1 space-y-1">
            <a href="/location-la-county/" class="solid-mobile-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">Los Angeles County</a>
            <a href="/location-orange-county/" class="solid-mobile-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">Orange County</a>
            <a href="/location-riverside-county/" class="solid-mobile-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">Riverside County</a>
            <a href="/location-san-bernardino-county/" class="solid-mobile-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">San Bernardino County</a>
            <a href="/location-san-diego-county/" class="solid-mobile-link block text-base text-slate-600 hover:text-[#1e88e5] transition-colors py-2">San Diego County</a>
          </div>
        </details>
        <a href="/reviews/" class="solid-mobile-link flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Reviews</a>
        <a id="s-mobile-signin-link" href="/sign-in/" class="solid-mobile-link flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Sign in</a>
        <button id="s-mobile-signout-btn" class="hidden w-full text-left flex items-center justify-between py-6 border-b border-slate-200 text-2xl font-medium text-slate-900">Sign out</button>
      </div>
      <div class="p-6 shrink-0">
        <a href="/request-offer/" class="solid-mobile-link flex items-center justify-between gap-3 p-4 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div>
            <div class="font-bold text-slate-900 text-base">Ready to get started?</div>
            <div class="text-sm text-slate-500 mt-0.5">Get your free offer in 24–48 hours</div>
          </div>
          <svg class="text-slate-700 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <script>
    import { getSupabase } from '../lib/supabase';

    // ─── Auth state: swap Sign in link with profile icon when logged in ───
    const sSignin       = document.getElementById('s-signin-link') as HTMLAnchorElement;
    const sProfileWrap  = document.getElementById('s-profile-wrap') as HTMLElement;
    const sProfileBtn   = document.getElementById('s-profile-btn') as HTMLButtonElement;
    const sProfileImg   = document.getElementById('s-profile-avatar') as HTMLImageElement;
    const sProfileInit  = document.getElementById('s-profile-initial') as HTMLElement;
    const sProfileMenu  = document.getElementById('s-profile-menu') as HTMLElement;
    const sProfileEmail = document.getElementById('s-profile-email') as HTMLElement;
    const sSignoutBtn   = document.getElementById('s-signout-btn') as HTMLButtonElement;
    const sMSignin      = document.getElementById('s-mobile-signin-link') as HTMLAnchorElement;
    const sMSignout     = document.getElementById('s-mobile-signout-btn') as HTMLButtonElement;
    const sSupabase = getSupabase();

    const sMProfile     = document.getElementById('s-mobile-profile') as HTMLElement;
    const sMProfileImg  = document.getElementById('s-mobile-profile-avatar') as HTMLImageElement;
    const sMProfileInit = document.getElementById('s-mobile-profile-initial') as HTMLElement;
    const sMProfileEmail= document.getElementById('s-mobile-profile-email') as HTMLElement;

    function sApplyAuth(user: any) {
      const signedIn = !!user && !user.is_anonymous;
      if (signedIn) {
        sSignin.style.display = 'none';
        sProfileWrap.classList.remove('hidden');
        sProfileWrap.style.display = window.innerWidth >= 768 ? 'block' : 'none';
        sMSignin.classList.add('hidden');
        sMSignout.classList.remove('hidden');
        sMProfile.classList.remove('hidden');
        sMProfile.style.display = 'flex';
        const email = user.email || '';
        sProfileEmail.textContent = email;
        sMProfileEmail.textContent = email;
        const avatarUrl = user.user_metadata?.avatar_url || user.user_metadata?.picture;
        if (avatarUrl) {
          sProfileImg.src = avatarUrl;
          sMProfileImg.src = avatarUrl;
          sProfileImg.classList.remove('hidden');
          sMProfileImg.classList.remove('hidden');
          sProfileInit.classList.add('hidden');
          sMProfileInit.classList.add('hidden');
        } else {
          sProfileImg.classList.add('hidden');
          sMProfileImg.classList.add('hidden');
          sProfileInit.classList.remove('hidden');
          sMProfileInit.classList.remove('hidden');
          const initial = (email[0] || 'U').toUpperCase();
          sProfileInit.textContent = initial;
          sMProfileInit.textContent = initial;
        }
      } else {
        sSignin.style.display = '';
        sProfileWrap.classList.add('hidden');
        sProfileWrap.style.display = '';
        sMSignin.classList.remove('hidden');
        sMSignout.classList.add('hidden');
        sMProfile.classList.add('hidden');
        sMProfile.style.display = '';
        sProfileMenu.classList.add('hidden');
      }
    }
    window.addEventListener('resize', () => {
      if (sProfileWrap.style.display && sProfileWrap.style.display !== '') {
        sProfileWrap.style.display = window.innerWidth >= 768 ? 'block' : 'none';
      }
    });
    sSupabase.auth.getUser().then(({ data }) => sApplyAuth(data.user));
    sSupabase.auth.onAuthStateChange((_event, session) => sApplyAuth(session?.user || null));

    sProfileBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const willShow = sProfileMenu.classList.contains('hidden');
      sProfileMenu.classList.toggle('hidden');
      sProfileBtn.setAttribute('aria-expanded', String(willShow));
    });
    document.addEventListener('click', (e) => {
      if (!sProfileWrap.contains(e.target as Node)) {
        sProfileMenu.classList.add('hidden');
        sProfileBtn.setAttribute('aria-expanded', 'false');
      }
    });

    async function sHandleSignOut() {
      await sSupabase.auth.signOut();
      window.location.assign('/');
    }
    sSignoutBtn.addEventListener('click', sHandleSignOut);
    sMSignout.addEventListener('click', sHandleSignOut);

    const solidNav = document.getElementById('solid-nav') as HTMLElement;
    const solidNavLogo = document.getElementById('solid-nav-logo') as HTMLImageElement;
    const solidNavLinks = document.getElementById('solid-nav-links') as HTMLElement;
    const solidNavOfferFormWrap = document.getElementById('solid-nav-offer-form-wrap') as HTMLElement;
    const solidNavRight = document.getElementById('solid-nav-right') as HTMLElement;
    const toggle = document.getElementById('solid-menu-toggle');
    const menu = document.getElementById('solid-mobile-menu');

    // Mirror homepage nav: after scrolling past the hero, swap to dark navy + address form input.
    function updateSolidNav() {
      const scrolled = window.scrollY > 80;
      const isMobile = window.innerWidth < 768;
      if (scrolled) {
        solidNav.style.background = '#1E2A3A';
        solidNav.style.borderBottomColor = 'rgba(255,255,255,0.06)';
        solidNavLogo.src = '/wordmark-dark.png';
        solidNavLinks.style.display = 'none';
        if (isMobile) {
          solidNavOfferFormWrap.style.display = 'none';
          solidNavRight.style.display = '';
        } else {
          solidNavOfferFormWrap.style.display = 'flex';
          solidNavRight.style.display = 'none';
        }
      } else {
        solidNav.style.background = '';
        solidNav.style.borderBottomColor = '';
        solidNavLogo.src = '/wordmark-on-white.png';
        solidNavLinks.style.display = '';
        solidNavRight.style.display = '';
        solidNavOfferFormWrap.style.display = 'none';
      }
    }

    window.addEventListener('scroll', updateSolidNav);
    window.addEventListener('resize', updateSolidNav);
    updateSolidNav();

    function closeSolidMenu() {
      menu?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    toggle?.addEventListener('click', () => {
      const willOpen = menu!.classList.contains('hidden');
      menu!.classList.toggle('hidden');
      document.body.style.overflow = willOpen ? 'hidden' : '';
    });

    document.getElementById('solid-menu-close')?.addEventListener('click', closeSolidMenu);

    menu?.querySelectorAll('.solid-mobile-link').forEach(link => {
      link.addEventListener('click', closeSolidMenu);
    });
  </script>
)}
