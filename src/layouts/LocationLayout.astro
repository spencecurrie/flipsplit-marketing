---
import '../styles/global.css'
import Nav from '../components/Nav.astro';

interface CaseStudy {
  tag: string;
  headline: string;
  body: string;
  result: string;
}

interface Props {
  title: string;
  description: string;
  slug: string;
  city: string;
  shortName: string;
  testimonialsName?: string;
  heroHeadline: string;
  heroSub: string;
  stats: Array<{ label: string; value: string }>;
  step1Body: string;
  testimonials?: Array<{ quote: string; name: string; location: string }>;
  faqs: Array<{ q: string; a: string }>;
  places: string[];
  placesHeading?: string;
  placesDescription?: string;
  caseStudies?: CaseStudy[];
  showValueProp?: boolean;
  howItWorksVideoUrl?: string;
  marketOverview?: string;
  marketHeading?: string;
  whySellBody?: string;
  serviceAreaBody?: string;
}

const {
  title, description, slug, city, shortName,
  testimonialsName = shortName,
  heroHeadline, heroSub, stats, step1Body,
  testimonials = [],
  faqs, places,
  placesHeading = `Serving all of ${city}.`,
  placesDescription = `We buy homes in every city and neighborhood across ${city}.`,
  caseStudies,
  showValueProp = false,
  howItWorksVideoUrl = "https://www.youtube.com/embed/3YIU7W5GULA",
  marketOverview,
  marketHeading = `The ${city} real estate market in 2026.`,
  serviceAreaBody = `Whether you're looking to sell a single-family home, an inherited property, a rental with tenants, or a house that needs major work — FlipSplit buys homes throughout ${city} in any condition. We specialize in situations traditional buyers won't touch: deferred maintenance, outdated systems, fire or water damage, difficult tenant situations, and full estate cleanouts.\n\nOur team has deep knowledge of every corner of ${city}. No matter where your property is located, we can evaluate it and deliver a fair offer within 24–48 hours.`,
  whySellBody = `If you want to sell your home in ${city}, the traditional path means paying for repairs upfront, managing contractors, sitting through weeks of showings, and hoping a buyer doesn't walk after inspection. A cash buyer solves the hassle — but discounts your home 20–30% below market and keeps every dollar of renovation profit for themselves.\n\nFlipSplit is a third option. We buy your home as-is, fund and manage the entire renovation at zero cost to you, and split the profit when the updated home sells for more. You get a guaranteed cash offer at closing and a backend check once the renovated home sells. No repairs. No showings. No surprises.`,
} = Astro.props;

const displayTestimonials = !(caseStudies && caseStudies.length > 0) && testimonials.length > 0;
const mapQuery = encodeURIComponent(`${city}, CA`);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://www.flipsplit.com/${slug}`} />
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root { --brand-cyan: #1a96e8; --brand-dark: #1E2A3A; --brand-body: #374151; }
    body { font-family: 'Open Sans', sans-serif; color: var(--brand-body); }
    h1, h2, h3, h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: var(--brand-dark); }
    .btn-primary { background: var(--brand-cyan); color: #ffffff; font-weight: 700; transition: filter 0.15s ease; }
    .btn-primary:hover { filter: brightness(1.08); }
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    .faq-icon { transition: transform 0.2s ease; display: inline-block; }
    details[open] .faq-icon { transform: rotate(45deg); }
    .step-chevron { transition: transform 0.2s ease; }
    details[open] .step-chevron { transform: rotate(180deg); }
    a, button, summary, select, [role="button"] { cursor: pointer !important; }
    #address-wrap, #address-wrap-bottom { position: relative; }
    .fs-pac-input-wrap { display:flex; align-items:center; background:rgba(255,255,255,0.97); border-radius:12px; position:relative; }
    .fs-pac-input { width:100%; padding:14px 62px 14px 44px; font-size:15px; font-family:'Open Sans',sans-serif; color:#1E2A3A; background:transparent; border:none; border-radius:12px; outline:none; }
    .fs-pac-input::placeholder { color:#94a3b8; }
    .fs-pac-input:focus { box-shadow:0 0 0 2px #1a96e8; border-radius:12px; }
    .fs-pac-dropdown { position:absolute; left:0; right:0; top:calc(100% + 6px); background:#fff; border-radius:12px; box-shadow:0 8px 24px rgba(0,0,0,0.12); z-index:9999; display:none; overflow:hidden; border:1px solid rgba(0,0,0,0.06); }
    .fs-pac-item { padding:12px 16px; cursor:pointer; font-size:14px; color:#1E2A3A; font-family:'Open Sans',sans-serif; border-bottom:1px solid #f4f4f4; }
    .fs-pac-item:last-child { border-bottom:none; }
    .fs-pac-item:hover { background:rgba(26,150,232,0.1); }
  </style>
</head>
<body class="bg-white antialiased">

  <!-- NAV -->
  <Nav />

  <!-- HERO -->
  <section class="py-20 px-6 bg-white border-b border-slate-100">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <span class="inline-block text-xs font-semibold tracking-wide mb-5 px-4 py-1.5 rounded-full" style="background:rgba(26,150,232,0.1); color:#1a96e8;">{city}</span>
        <h1 class="text-4xl sm:text-5xl font-black leading-tight mb-6" style="color:#1E2A3A; font-family:'sahar','Open Sans',sans-serif;">
          {heroHeadline}
        </h1>
        <p class="text-slate-500 text-lg leading-relaxed mb-8">{heroSub}</p>
        <div id="address-wrap" class="max-w-lg w-full"></div>
        <div class="flex items-center gap-2 mt-3">
          <div class="flex gap-px" style="color:#FBBC05; font-size:13px; line-height:1;">★★★★★</div>
          <span class="text-xs font-bold" style="color:#1E2A3A;">5.0</span>
          <span class="text-slate-400 text-xs">· Verified reviews on</span>
          <span class="text-xs font-bold tracking-wide" style="color:var(--brand-cyan);">REVIEWS.IO</span>
        </div>
        <p class="text-slate-400 text-xs mt-2">No obligation · No repairs needed · Results in 24–48 hours</p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {stats.map(s => (
          <div class="rounded-2xl p-6 border border-slate-200" style="background:#ffffff;">
            <div class="text-3xl font-black mb-1" style="color: var(--brand-cyan);">{s.value}</div>
            <div class="text-sm text-slate-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY FLIPSPLIT -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Your options</p>
      <h2 class="text-3xl font-black mb-6" style="color:#1E2A3A;">Why {city} homeowners choose FlipSplit.</h2>
      <div class="space-y-4 mb-12">
        {whySellBody.split('\\n\\n').map(para => (
          <p class="text-slate-600 leading-relaxed text-base">{para}</p>
        ))}
      </div>
      <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
        <div class="min-w-[560px]">
          <!-- Header -->
          <div class="grid grid-cols-4 text-sm font-bold text-center" style="background:#F8FAFC;">
            <div class="px-5 py-4 text-left text-slate-400 text-xs uppercase tracking-widest font-semibold border-b border-slate-200"></div>
            <div class="px-5 py-5 text-center font-black text-lg border-b border-slate-200" style="color:var(--brand-cyan);">FlipSplit</div>
            <div class="px-5 py-4 text-slate-400 font-semibold text-sm flex items-center justify-center border-b border-slate-200">Traditional Sale</div>
            <div class="px-5 py-4 text-slate-400 font-semibold text-sm flex items-center justify-center border-b border-slate-200">Cash Buyer</div>
          </div>
          <!-- Rows -->
          {[
            { label: "Best for",            flip: "Homes needing renovation",   trad: "Move-in ready homes",         cash: "Distressed properties" },
            { label: "Time to close",       flip: "7–30 days",                  trad: "45–90 days",                  cash: "7–14 days" },
            { label: "Upfront costs",       flip: "$0 to you",                  trad: "$15K–$60K+ in repairs",       cash: "$0" },
            { label: "Renovation",          flip: "FlipSplit handles everything",trad: "You manage it all",           cash: "Buyer's responsibility" },
            { label: "Share of upside",     flip: "0–100% profit split",        trad: "Yours (after all costs)",     cash: "0% — buyer keeps it all" },
            { label: "Contingencies",       flip: "None",                       trad: "Inspection, financing, appraisal", cash: "Low" },
            { label: "Net to seller",       flip: "Competitive offer + upside", trad: "Below market after costs",    cash: "Deeply discounted" },
          ].map((row, i) => (
            <div class={`grid grid-cols-4 text-sm items-start ${i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}`}>
              <div class="px-5 py-4 font-bold text-[#1E2A3A]">{row.label}</div>
              <div class="px-5 py-4 font-semibold text-center" style="color:#1E2A3A; background:rgba(26,150,232,0.06);">{row.flip}</div>
              <div class="px-5 py-4 text-slate-400 text-center">{row.trad}</div>
              <div class="px-5 py-4 text-slate-400 text-center">{row.cash}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS CTA -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-2xl mx-auto text-center rounded-2xl border border-slate-200 py-12 px-8" style="background:#F8FAFC;">
      <h2 class="text-2xl font-black mb-3" style="color:#1E2A3A;">Ready to see what your {city} home is worth?</h2>
      <p class="text-slate-500 text-sm mb-7">Get a guaranteed cash offer in 24–48 hours. No repairs, no showings, no obligation.</p>
      <a href="#get-offer" class="btn-primary inline-block px-8 py-4 rounded-xl text-base font-bold">Get My Free Offer →</a>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Where we buy</p>
        <h2 class="text-3xl font-black mb-5" style="color:#1E2A3A;">We help {city} homeowners sell as-is.</h2>
        <div class="space-y-4 mb-8">
          {serviceAreaBody.split('\\n\\n').map(para => (
            <p class="text-slate-600 leading-relaxed text-base">{para}</p>
          ))}
        </div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Cities &amp; areas we serve</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-2">
          {places.map(p => (
            <div class="flex items-center gap-2 text-sm text-slate-600 py-0.5">
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background:var(--brand-cyan);"></span>
              {p}
            </div>
          ))}
        </div>
      </div>
      <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm lg:sticky lg:top-24" style="height:480px;">
        <iframe
          src={`https://maps.google.com/maps?q=${mapQuery}&output=embed`}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-24 px-6 bg-white">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: heading + accordion steps -->
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">The process</p>
        <h2 class="text-3xl font-black mb-10 leading-snug" style="color:#1E2A3A;">How FlipSplit works in {city}.</h2>

        {[
          { n: "1", title: "Share your address", bullets: [
            `Takes 2 minutes — we just need your ${city} address`,
            "We analyze your home using current local market data",
            "Receive a guaranteed cash offer within 24–48 hours",
          ]},
          { n: "2", title: "Review your offer", bullets: [
            "We walk through comparable sales and your renovation plan",
            "Your profit participation percentage is fully negotiable",
            "No obligation — take all the time you need to decide",
          ]},
          { n: "3", title: "We renovate", bullets: [
            "FlipSplit funds 100% of all renovation costs",
            "We manage every contractor, permit, and material",
            "You move out on your timeline — we handle the rest",
          ]},
          { n: "4", title: "You get paid twice", bullets: [
            "Guaranteed cash hits your account at first closing",
            "Second check issued when the renovated home sells",
            "Your full agreed profit share with no hidden deductions",
          ]},
        ].map(({ n, title, bullets }, i) => (
          <details open={i === 0} class="group border-t border-slate-200">
            <summary class="flex items-center gap-4 py-5 cursor-pointer list-none">
              <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-black shrink-0" style="background:#f1f5f9; color:#1E2A3A;">{n}</span>
              <span class="flex-1 font-black text-base" style="color:#1E2A3A;">{title}</span>
              <svg class="step-chevron shrink-0 text-slate-400" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="pb-5 pl-12">
              <ul class="space-y-2">
                {bullets.map(b => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-500">
                    <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#1a96e8" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="#1a96e8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
        <div class="border-t border-slate-200"></div>
      </div>

      <!-- Right: video or placeholder -->
      <div class="rounded-2xl overflow-hidden w-full border border-slate-200" style="aspect-ratio:16/9; background:#F8FAFC;">
        {howItWorksVideoUrl ? (
          <iframe src={howItWorksVideoUrl} width="100%" height="100%" style="border:0;" allow="autoplay; fullscreen" allowfullscreen></iframe>
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center gap-4">
            <div class="w-16 h-16 rounded-full flex items-center justify-center" style="background:rgba(26,150,232,0.15); border:2px solid rgba(26,150,232,0.3);">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 4l12 6-12 6V4z" fill="#1a96e8"/></svg>
            </div>
            <p class="text-sm font-semibold" style="color:#1a96e8;">How It Works Video</p>
            <p class="text-xs text-slate-400">Coming soon</p>
          </div>
        )}
      </div>

    </div>
  </section>

  <!-- MARKET OVERVIEW -->
  {marketOverview && (
    <section class="py-20 px-6" style="background:#F8FAFC;">
      <div class="max-w-5xl mx-auto lg:grid lg:grid-cols-[1fr_2fr] lg:gap-16 lg:items-start">
        <div class="mb-8 lg:mb-0 lg:sticky lg:top-24">
          <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: var(--brand-cyan);">2026 Market Overview</p>
          <h2 class="text-3xl font-black leading-snug" style="color: #1E2A3A;">{marketHeading}</h2>
        </div>
        <div class="space-y-5">
          {marketOverview.split('\n\n').map(para => (
            <p class="text-slate-600 leading-relaxed text-base">{para}</p>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- VALUE PROP CALLOUT (Anaheim) -->
  {showValueProp && (
    <section class="py-16 px-6" style="background:#F8FAFC;">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3 text-center">At a glance</p>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { stat: "0", label: "Upfront costs to you", sub: "We fund 100% of all renovation work" },
            { stat: "30–50%", label: "Profit split for you", sub: "Of the amount above your guaranteed offer" },
            { stat: "7 days", label: "Minimum close time", sub: "Cash in hand in as little as 7 days" },
          ].map(({ stat, label, sub }) => (
            <div class="text-center bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
              <div class="text-4xl font-black mb-2 text-[#1E2A3A]">{stat}</div>
              <div class="font-bold text-[#1E2A3A] mb-1">{label}</div>
              <div class="text-xs text-slate-400">{sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CASE STUDIES (Long Beach) -->
  {caseStudies && caseStudies.length > 0 && (
    <section class="py-20 px-6 bg-slate-50">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Real cases</p>
          <h2 class="text-4xl font-black text-[#1E2A3A]">{city} homes we've bought.</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {caseStudies.map(c => (
            <div class="bg-white rounded-2xl border border-slate-200 p-8">
              <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full mb-4" style="background: rgba(26,150,232,0.12); color: #1E2A3A;">{c.tag}</span>
              <h3 class="text-xl font-black text-[#1E2A3A] mb-3">{c.headline}</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-5">{c.body}</p>
              <div class="rounded-xl px-5 py-4 border border-slate-200" style="background:#F8FAFC;">
                <span class="text-xs font-semibold uppercase tracking-widest" style="color: var(--brand-cyan);">Result</span>
                <p class="font-bold mt-1" style="color:#1E2A3A;">{c.result}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- TESTIMONIALS -->
  {displayTestimonials && (
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">What homeowners say</p>
          <h2 class="text-4xl font-black text-[#1E2A3A]">Real {testimonialsName} homeowners, real results.</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {testimonials.map(t => (
            <div class="bg-white rounded-2xl border border-slate-200 p-6 flex flex-col">
              <div class="flex gap-0.5 mb-4" style="color: #FBBC05;">★★★★★</div>
              <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-5">"{t.quote}"</p>
              <div class="flex items-center gap-3 mt-auto">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-[#1E2A3A] shrink-0" style="background: rgba(26,150,232,0.2);">{t.name.charAt(0)}</div>
                <div>
                  <div class="text-sm font-bold text-[#1E2A3A]">{t.name}</div>
                  <div class="text-xs text-slate-400">{t.location}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="py-20 px-6 bg-slate-50">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">FAQ</p>
        <h2 class="text-4xl font-black text-[#1E2A3A]">Questions about selling in {city}.</h2>
      </div>
      <div>
        {faqs.map(({ q, a }) => (
          <details class="group border-b border-slate-200 py-1">
            <summary class="flex justify-between items-center py-5 cursor-pointer font-semibold text-[#1E2A3A]">
              {q}
              <span class="faq-icon text-slate-400 text-2xl leading-none ml-6 shrink-0">+</span>
            </summary>
            <div class="pb-5 text-slate-500 leading-relaxed text-sm">{a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>


  <!-- GET OFFER -->
  <section id="get-offer" class="py-20 px-6" style="background: #1E2A3A;">
    <input type="hidden" id="offer-city" value={city} />
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: var(--brand-cyan);">Free. No obligation.</p>
      <h2 class="text-4xl sm:text-5xl font-black mb-4 leading-tight" style="color: white;">Get your free {shortName} offer today.</h2>
      <p class="text-slate-300 text-base leading-relaxed mb-7">Enter your address below. We'll respond within 24–48 hours with a guaranteed cash offer, renovation plan, and profit projection.</p>

      <!-- Address autocomplete input -->
      <div id="address-wrap-bottom" class="mb-4 text-left"></div>

      <!-- Reviews badge -->
      <div class="flex items-center justify-center gap-2 mb-7">
        <div class="flex gap-px" style="color:#FBBC05; font-size:13px; line-height:1;">★★★★★</div>
        <span class="text-white text-xs font-bold">5.0</span>
        <span class="text-slate-400 text-xs">· Verified reviews on</span>
        <span class="text-xs font-bold tracking-wide" style="color:var(--brand-cyan);">REVIEWS.IO</span>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {["No repairs needed", "Cash offer in 24–48 hours", "Zero upfront costs"].map(t => (
          <span class="flex items-center gap-2 text-sm text-slate-400">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#1a96e8" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="#1a96e8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {t}
          </span>
        ))}
      </div>

      <!-- Success state (hidden by default) -->
      <div id="offer-success" class="hidden mt-10 p-8 rounded-2xl" style="background: rgba(26,150,232,0.08); border: 1px solid rgba(26,150,232,0.2);">
        <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-5" style="background: rgba(26,150,232,0.15);">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5 9-9" stroke="#1a96e8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="text-2xl font-black text-white mb-2">We'll be in touch!</h3>
        <p class="text-slate-300 text-sm leading-relaxed">Our team will review your address and reach out within 24–48 hours with your offer details.</p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="background: #081e21;" class="py-10 px-6">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-500">
      <img src="/wordmark.png" alt="FlipSplit" class="h-8" />
      <div class="flex gap-6">
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <a href="/#how-it-works" class="hover:text-white transition-colors">How It Works</a>
        <a href="/#faq" class="hover:text-white transition-colors">FAQ</a>
        <a href="mailto:hello@flipsplit.com" class="hover:text-white transition-colors">Contact</a>
      </div>
      <p>© 2026 FlipSplit. All rights reserved.</p>
    </div>
  </footer>

  <!-- Address confirmation modal -->
  <div id="addr-modal" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-4" style="background: rgba(0,0,0,0.6);">
    <div class="bg-white w-full max-w-md p-8 relative shadow-2xl" style="border-radius:28px; font-family:'Open Sans',sans-serif;">
      <!-- Close button: outlined circle -->
      <button id="modal-close" class="absolute top-5 right-5 w-10 h-10 flex items-center justify-center rounded-full hover:bg-slate-50 transition-colors" style="border:1.5px solid #1E2A3A;">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 1l11 11M12 1L1 12" stroke="#1E2A3A" stroke-width="1.75" stroke-linecap="round"/></svg>
      </button>
      <!-- Heading -->
      <h3 class="text-3xl font-black leading-tight mb-6 pr-12" style="font-family:'sahar','Open Sans',sans-serif; color:#1E2A3A;">Is this the correct home address?</h3>
      <!-- Address box -->
      <div class="rounded-2xl px-5 py-4 flex items-start justify-between gap-4 mb-6" style="background:#f2f2f2;">
        <p id="modal-addr" class="text-base leading-snug flex-1" style="color:#1E2A3A;"></p>
        <button id="modal-edit" class="text-sm font-bold shrink-0 hover:opacity-70 transition-opacity" style="color:#1a96e8;">Edit</button>
      </div>
      <!-- Ownership question -->
      <p class="text-base font-bold mb-3" style="color:#1E2A3A;">Are you the owner of this home? <span style="color:#ef4444;">*</span></p>
      <div class="relative mb-6">
        <select id="ownership" class="w-full appearance-none bg-white border rounded-2xl px-5 py-4 text-base focus:outline-none focus:border-[#1a96e8] transition-colors pr-12" style="border-color:#e2e8f0; color:#94a3b8;">
          <option value="" disabled selected>Select</option>
          <option style="color:#1E2A3A;">Yes</option>
          <option style="color:#1E2A3A;">No</option>
          <option style="color:#1E2A3A;">Agent</option>
          <option style="color:#1E2A3A;">Other</option>
        </select>
        <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2" style="color:#9ca3af;">
          <svg width="16" height="16" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </div>
      <button id="modal-continue" class="w-full py-4 rounded-2xl font-bold text-base transition-opacity hover:opacity-90" style="background:#1a96e8; color:#ffffff;">Confirm</button>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var modal = document.getElementById('addr-modal');
      var activeWrapId = 'address-wrap';

      document.getElementById('modal-close').onclick = function () {
        modal.classList.add('hidden');
      };
      modal.addEventListener('click', function (e) {
        if (e.target === modal) modal.classList.add('hidden');
      });
      document.getElementById('modal-edit').onclick = function () {
        modal.classList.add('hidden');
        var wrap = document.getElementById(activeWrapId);
        if (wrap) {
          var inp = wrap.querySelector('.fs-pac-input');
          var dd = wrap.querySelector('.fs-pac-dropdown');
          if (inp) { inp.value = ''; inp.focus(); }
          if (dd) { dd.innerHTML = ''; dd.style.display = 'none'; }
        }
      };
      document.getElementById('ownership').onchange = function () {
        this.style.borderColor = '#e2e8f0';
        this.style.color = '#1E2A3A';
      };
      document.getElementById('modal-continue').onclick = function () {
        var sel = document.getElementById('ownership');
        if (!sel.value) { sel.style.borderColor = '#ef4444'; return; }
        var addr = document.getElementById('modal-addr').textContent;
        var cityVal = (document.getElementById('offer-city') || {}).value || '';
        modal.classList.add('hidden');

        // Show success state and scroll to section
        var successEl = document.getElementById('offer-success');
        var bottomWrap = document.getElementById('address-wrap-bottom');
        if (successEl) {
          successEl.classList.remove('hidden');
          if (bottomWrap) bottomWrap.style.display = 'none';
          document.getElementById('get-offer').scrollIntoView({ behavior: 'smooth' });
        }

        // Submit address to Formspree
        fetch('https://formspree.io/f/YOUR_FORM_ID', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ address: addr, ownership: sel.value, location: cityVal })
        }).catch(function (err) { console.error('Form submit error:', err); });
      };

      function initPAC(wrapId) {
        var wrap = document.getElementById(wrapId);
        if (!wrap) return;

        var inputWrap = document.createElement('div');
        inputWrap.className = 'fs-pac-input-wrap';

        var searchIcon = document.createElement('span');
        searchIcon.style.cssText = 'position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;display:flex;';
        searchIcon.innerHTML = '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="7.5" cy="7.5" r="5" stroke="#1a96e8" stroke-width="1.6"/><path d="M12 12l3 3" stroke="#1a96e8" stroke-width="1.6" stroke-linecap="round"/></svg>';

        var input = document.createElement('input');
        input.className = 'fs-pac-input';
        input.type = 'text';
        input.placeholder = 'Enter your home address...';
        input.autocomplete = 'off';

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.style.cssText = 'position:absolute;right:6px;top:50%;transform:translateY(-50%);width:44px;height:44px;border-radius:8px;border:none;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:filter 0.15s;background:#1a96e8;';
        btn.innerHTML = '<svg width="19" height="19" viewBox="0 0 18 18" fill="none"><circle cx="7.5" cy="7.5" r="5" stroke="#ffffff" stroke-width="1.8"/><path d="M12 12l3 3" stroke="#ffffff" stroke-width="1.8" stroke-linecap="round"/></svg>';
        btn.addEventListener('mouseenter', function () { this.style.filter = 'brightness(1.08)'; });
        btn.addEventListener('mouseleave', function () { this.style.filter = ''; });

        inputWrap.appendChild(searchIcon);
        inputWrap.appendChild(input);
        inputWrap.appendChild(btn);

        var dropdown = document.createElement('div');
        dropdown.className = 'fs-pac-dropdown';

        wrap.appendChild(inputWrap);
        wrap.appendChild(dropdown);

        input.addEventListener('focus', function () {
          activeWrapId = wrapId;
          if (dropdown.children.length) dropdown.style.display = 'block';
        });

        google.maps.importLibrary('places').then(function (lib) {
          var debounce;

          function fetchSuggestions(query, cb) {
            if (lib.AutocompleteService) {
              new lib.AutocompleteService().getPlacePredictions(
                { input: query, types: ['address'], componentRestrictions: { country: 'us' } },
                function (preds, status) {
                  cb(status === 'OK' && preds ? preds.map(function (p) { return p.description; }) : []);
                }
              );
            } else if (lib.AutocompleteSuggestion && lib.AutocompleteSuggestion.fetchAutocompleteSuggestions) {
              lib.AutocompleteSuggestion.fetchAutocompleteSuggestions({
                input: query,
                includedRegionCodes: ['us'],
                includedPrimaryTypes: ['address']
              }).then(function (res) {
                cb((res.suggestions || []).map(function (s) {
                  return s.placePrediction && s.placePrediction.text
                    ? (s.placePrediction.text.text || s.placePrediction.text.toString())
                    : '';
                }).filter(Boolean));
              }).catch(function (err) { console.error('[FS] AutocompleteSuggestion error:', err); cb([]); });
            } else {
              cb([]);
            }
          }

          function selectAddress(addr) {
            activeWrapId = wrapId;
            input.value = addr;
            dropdown.innerHTML = '';
            dropdown.style.display = 'none';
            document.getElementById('modal-addr').textContent = addr;
            document.getElementById('ownership').value = '';
            document.getElementById('ownership').style.borderColor = '#e2e8f0';
            document.getElementById('ownership').style.color = '#94a3b8';
            modal.classList.remove('hidden');
          }

          function renderDropdown(suggestions) {
            dropdown.innerHTML = '';
            if (!suggestions.length) { dropdown.style.display = 'none'; return; }
            suggestions.forEach(function (addr) {
              var item = document.createElement('div');
              item.className = 'fs-pac-item';
              item.textContent = addr;
              item.addEventListener('mousedown', function (e) {
                e.preventDefault();
                selectAddress(addr);
              });
              dropdown.appendChild(item);
            });
            dropdown.style.display = 'block';
          }

          btn.addEventListener('click', function () {
            activeWrapId = wrapId;
            if (input.value.trim()) { fetchSuggestions(input.value, renderDropdown); } else { input.focus(); }
          });

          input.addEventListener('input', function () {
            clearTimeout(debounce);
            if (!input.value.trim()) { dropdown.innerHTML = ''; dropdown.style.display = 'none'; return; }
            debounce = setTimeout(function () { fetchSuggestions(input.value, renderDropdown); }, 250);
          });
          input.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { dropdown.innerHTML = ''; dropdown.style.display = 'none'; }
          });
          input.addEventListener('blur', function () {
            setTimeout(function () { dropdown.style.display = 'none'; }, 200);
          });

        }).catch(function (err) { console.error('Places load error:', err); });
      }

      // Bootstrap Loader
      (function(g){
        var h,a,k,p='The Google Maps JavaScript API',c='google',l='importLibrary',q='__ib__',m=document,b=window;
        b=b[c]||(b[c]={});
        var d=b.maps||(b.maps={}),r=new Set,e=new URLSearchParams;
        var u=function(){return h||(h=new Promise(function(f,n){
          a=m.createElement('script');
          e.set('libraries',Array.from(r).join(','));
          for(k in g)e.set(k.replace(/[A-Z]/g,function(t){return '_'+t[0].toLowerCase();}),g[k]);
          e.set('callback',c+'.maps.'+q);
          a.src='https://maps.googleapis.com/maps/api/js?'+e;
          d[q]=f;a.onerror=function(){h=n(new Error(p+' could not load.'));};
          m.head.append(a);
        }));};
        d[l]?console.warn(p+' only loads once. Ignoring:',g):d[l]=function(f){r.add(f);return u().then(function(){return d[l](f);});};
      })({ key: 'AIzaSyArzPR5lnfheBpgpS98ZrQWO949cB1ty30', v: 'weekly' });

      initPAC('address-wrap');
      initPAC('address-wrap-bottom');
    });
  </script>
</body>
</html>
