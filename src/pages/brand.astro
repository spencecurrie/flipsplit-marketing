---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Brand Guidelines — FlipSplit</title>
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --brand-cyan: #41ebd6;
      --brand-dark: #0C3034;
      --brand-body: #34313D;
    }
    body { font-family: 'Open Sans', sans-serif; color: #34313D; background: #f8fafc; }
    h1,h2,h3,h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: #0C3034; }
    .section { background: white; border-radius: 16px; padding: 40px; margin-bottom: 24px; border: 1px solid #e2e8f0; }
    .section-title { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #94a3b8; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid #f1f5f9; }
    .swatch { border-radius: 12px; height: 80px; margin-bottom: 12px; }
    .do { border-left: 3px solid #22c55e; background: #f0fdf4; padding: 12px 16px; border-radius: 0 8px 8px 0; font-size: 14px; }
    .dont { border-left: 3px solid #ef4444; background: #fef2f2; padding: 12px 16px; border-radius: 0 8px 8px 0; font-size: 14px; }
    .do strong, .dont strong { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
    .do strong { color: #16a34a; }
    .dont strong { color: #dc2626; }
    code { background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 13px; font-family: monospace; color: #0C3034; }
  </style>
</head>
<body style="max-width:900px; margin:0 auto; padding:48px 24px;">

  <!-- Header -->
  <div style="margin-bottom:40px;">
    <img src="/wordmark.png" alt="FlipSplit" style="height:36px; margin-bottom:20px;" />
    <h1 style="font-size:36px; font-weight:900; margin:0 0 8px;">Brand Guidelines</h1>
    <p style="color:#64748b; margin:0;">Reference this page when making any design changes to the site.</p>
  </div>

  <!-- ── COLORS ── -->
  <div class="section">
    <p class="section-title">Colors</p>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:20px; margin-bottom:32px;">

      <div>
        <div class="swatch" style="background:#0C3034;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Brand Dark</p>
        <code>#0C3034</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Headlines, nav, dark section backgrounds, button text on cyan</p>
      </div>

      <div>
        <div class="swatch" style="background:#41ebd6; border:1px solid #e2e8f0;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Brand Cyan</p>
        <code>#41ebd6</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">CTA buttons, hover states, icon accents, decorative borders, text <em>only on dark backgrounds</em></p>
      </div>

      <div>
        <div class="swatch" style="background:#34313D;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Body Text</p>
        <code>#34313D</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Paragraphs, descriptions, general copy</p>
      </div>

      <div>
        <div class="swatch" style="background:#64748b;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Muted Text</p>
        <code>#64748b (slate-500)</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Labels, metadata, dates, secondary info, eyebrow text on white</p>
      </div>

      <div>
        <div class="swatch" style="background:#ffffff; border:1px solid #e2e8f0;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">White</p>
        <code>#ffffff</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Primary page background, card backgrounds</p>
      </div>

      <div>
        <div class="swatch" style="background:#f8fafc; border:1px solid #e2e8f0;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Off-White</p>
        <code>#f8fafc (slate-50)</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Subtle section backgrounds, alternating rows</p>
      </div>

    </div>

    <!-- Color rules -->
    <p style="font-weight:700; font-size:13px; margin:0 0 12px; color:#0C3034;">The most important color rule</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do">
        <strong>Do</strong>
        Use cyan as a <strong>background color</strong> for buttons and badges, or as <strong>text on dark (#0C3034) backgrounds</strong> — e.g. the labels inside the dark CTA sections.
      </div>
      <div class="dont">
        <strong>Don't</strong>
        Use cyan as text color on white or light backgrounds. It reads as "bright blue" and feels off-brand. Use <code>text-slate-500</code> (#64748b) for eyebrow/label text on white.
      </div>
    </div>
  </div>

  <!-- ── TYPOGRAPHY ── -->
  <div class="section">
    <p class="section-title">Typography</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-bottom:32px;">
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;margin:0 0 12px;">Headings — Sahar</p>
        <p style="font-family:'sahar','Open Sans',sans-serif;font-weight:900;font-size:36px;line-height:1.1;color:#0C3034;margin:0 0 8px;">The quick brown fox</p>
        <p style="font-size:12px;color:#64748b;">Use for all H1–H4. Always font-black (900). Color is always Brand Dark (#0C3034) on light backgrounds, white on dark backgrounds.</p>
      </div>
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;margin:0 0 12px;">Body — Open Sans</p>
        <p style="font-family:'Open Sans',sans-serif;font-size:16px;line-height:1.7;color:#34313D;margin:0 0 8px;">The quick brown fox jumps over the lazy dog. Use this for all body copy, descriptions, and UI text.</p>
        <p style="font-size:12px;color:#64748b;">400 for body, 600 for labels and nav, 700 for strong emphasis.</p>
      </div>
    </div>

    <p style="font-weight:700; font-size:13px; margin:0 0 16px; color:#0C3034;">Size scale</p>
    <div style="border:1px solid #f1f5f9; border-radius:12px; overflow:hidden;">
      {[
        { label:'H1 — Page title', size:'48–60px', weight:'900', usage:'Homepage hero, major page headlines', sample:'Sell Your Home For More' },
        { label:'H2 — Section title', size:'32–40px', weight:'900', usage:'Section headings, blog post H2s', sample:'How It Works' },
        { label:'H3 — Card title', size:'20–24px', weight:'900', usage:'Card headings, blog post H3s', sample:'Get Your Free Offer' },
        { label:'Body large', size:'18px', weight:'400', usage:'Hero subheadline, intro paragraphs', sample:'FlipSplit renovates your home before it hits the market.' },
        { label:'Body', size:'16px', weight:'400', usage:'General copy, FAQ answers, blog body text', sample:'Share your address and we will respond within 48 hours.' },
        { label:'Label / Eyebrow', size:'12px', weight:'700', usage:'Section labels above headings, metadata', sample:'HOW IT WORKS' },
      ].map(r => (
        <div style="display:grid; grid-template-columns:180px 1fr; border-bottom:1px solid #f1f5f9; last:border-0;">
          <div style="padding:14px 16px; border-right:1px solid #f1f5f9; background:#f8fafc;">
            <p style="font-size:12px; font-weight:700; color:#0C3034; margin:0 0 2px;">{r.label}</p>
            <p style="font-size:11px; color:#94a3b8; margin:0;">{r.size} · {r.weight}</p>
          </div>
          <div style="padding:14px 16px;">
            <p style="font-size:12px; color:#64748b; margin:0 0 4px;">{r.usage}</p>
            <p style="font-family:'sahar','Open Sans',sans-serif; font-size:13px; color:#0C3034; margin:0;">{r.sample}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── BUTTONS ── -->
  <div class="section">
    <p class="section-title">Buttons</p>
    <div style="display:flex; flex-wrap:wrap; gap:24px; align-items:center; margin-bottom:24px;">
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; background:#41ebd6; color:#0C3034; font-weight:700; padding:12px 24px; border-radius:10px; text-decoration:none; font-size:14px;">Get My Free Offer →</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Primary CTA</p>
      </div>
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; background:#0C3034; color:white; font-weight:700; padding:12px 24px; border-radius:10px; text-decoration:none; font-size:14px;">Learn More</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Secondary</p>
      </div>
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; border:2px solid #0C3034; color:#0C3034; font-weight:700; padding:10px 24px; border-radius:10px; text-decoration:none; font-size:14px;">View All →</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Outline</p>
      </div>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do"><strong>Do</strong>One primary CTA per section. Primary button = cyan bg, dark text. Only use on the most important action on the page.</div>
      <div class="dont"><strong>Don't</strong>Use multiple primary (cyan) buttons in the same view. If there are two actions, make one primary and one secondary or outline.</div>
    </div>
  </div>

  <!-- ── EYEBROW / LABEL TEXT ── -->
  <div class="section">
    <p class="section-title">Eyebrow Labels (small text above headings)</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-bottom:24px;">
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#64748b;margin:0 0 6px;">On white / light backgrounds</p>
        <p style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#64748b;margin:0 0 4px;">FlipSplit Resources</p>
        <h2 style="font-family:'sahar',sans-serif;font-weight:900;font-size:28px;color:#0C3034;margin:0;">Section Headline Here</h2>
        <p style="font-size:12px;color:#94a3b8;margin:12px 0 0;">Eyebrow = <code>text-slate-500</code> (#64748b)</p>
      </div>
      <div style="background:#0C3034; border-radius:12px; padding:24px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#41ebd6;margin:0 0 6px;">On dark backgrounds</p>
        <h2 style="font-family:'sahar',sans-serif;font-weight:900;font-size:28px;color:white;margin:0;">Section Headline Here</h2>
        <p style="font-size:12px;color:#94a3b8;margin:12px 0 0;">Eyebrow = <code style="background:#1a4a50;color:#41ebd6;">#41ebd6</code> (cyan is OK here)</p>
      </div>
    </div>
  </div>

  <!-- ── BADGES & PILLS ── -->
  <div class="section">
    <p class="section-title">Badges &amp; Category Pills</p>
    <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:24px; align-items:center;">
      <span style="font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;background:rgba(65,235,214,0.12);color:#0C3034;">Home Selling</span>
      <span style="font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;background:rgba(65,235,214,0.12);color:#0C3034;">Local Trends</span>
      <span style="font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;background:#f1f5f9;color:#64748b;">Featured</span>
      <span style="font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;background:#fef2f2;color:#ef4444;">Hostile tenant</span>
    </div>
    <p style="font-size:13px; color:#64748b; margin:0;">Category badges use a <strong>very light cyan tint background</strong> (<code>rgba(65,235,214,0.12)</code>) with <strong>Brand Dark text</strong> — not cyan text. The tint gives the brand feel without the harsh bright color on white.</p>
  </div>

  <!-- ── SPACING ── -->
  <div class="section">
    <p class="section-title">Spacing &amp; Layout</p>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:24px;">
      {[
        { label:'Page max-width', value:'max-w-6xl (1152px)', usage:'All main content areas' },
        { label:'Section padding', value:'py-20 to py-28', usage:'Vertical breathing room between sections' },
        { label:'Page padding', value:'px-6', usage:'Horizontal gutters on all sections' },
        { label:'Card border radius', value:'rounded-2xl (16px)', usage:'All cards, modals, image containers' },
        { label:'Small radius', value:'rounded-xl (12px)', usage:'Buttons, inputs, inline elements' },
        { label:'Gap between cards', value:'gap-5 or gap-6', usage:'Card grids' },
      ].map(r => (
        <div style="background:#f8fafc; border-radius:10px; padding:16px;">
          <p style="font-size:11px;font-weight:700;color:#94a3b8;margin:0 0 4px;text-transform:uppercase;letter-spacing:.08em;">{r.label}</p>
          <code style="font-size:13px;">{r.value}</code>
          <p style="font-size:12px;color:#64748b;margin:6px 0 0;">{r.usage}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ── VOICE ── -->
  <div class="section">
    <p class="section-title">Voice &amp; Tone</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do"><strong>Do</strong>Direct and reassuring. "Get your offer in 24–48 hours." Short sentences. Talk to homeowners like they're smart people going through something stressful.</div>
      <div class="dont"><strong>Don't</strong>Jargon-heavy or salesy. Avoid "industry-leading," "cutting-edge," "seamless experience." Don't over-promise or under-explain.</div>
      <div class="do"><strong>Do</strong>Specific and concrete. "$0 out of pocket." "30–45 day close." "Share of profit above your offer." Numbers build trust.</div>
      <div class="dont"><strong>Don't</strong>Vague superlatives. "The best way to sell your home!" doesn't mean anything. Lead with the mechanism, not the marketing claim.</div>
    </div>
  </div>

  <p style="text-align:center; font-size:12px; color:#94a3b8; margin-top:40px;">FlipSplit Internal · Last updated May 2026</p>

</body>
</html>
