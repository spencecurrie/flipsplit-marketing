---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Brand Guidelines — FlipSplit</title>
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --brand-blue: #1e88e5;
      --brand-dark: #1E2A3A;
      --brand-body: #374151;
    }
    body { font-family: 'Open Sans', sans-serif; color: #374151; background: #f8fafc; }
    h1,h2,h3,h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: #1E2A3A; }
    .section { background: white; border-radius: 16px; padding: 40px; margin-bottom: 24px; border: 1px solid #e2e8f0; }
    .section-title { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #94a3b8; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid #f1f5f9; }
    .swatch { border-radius: 12px; height: 80px; margin-bottom: 12px; }
    .do { border-left: 3px solid #22c55e; background: #f0fdf4; padding: 12px 16px; border-radius: 0 8px 8px 0; font-size: 14px; }
    .dont { border-left: 3px solid #ef4444; background: #fef2f2; padding: 12px 16px; border-radius: 0 8px 8px 0; font-size: 14px; }
    .do strong, .dont strong { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
    .do strong { color: #16a34a; }
    .dont strong { color: #dc2626; }
    code { background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 13px; font-family: monospace; color: #1E2A3A; }
    .demo-card { background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 24px; }
    .demo-card.featured { border-color: #1e88e5; box-shadow: 0 4px 24px rgba(26,150,232,0.12); }
  </style>
</head>
<body style="max-width:960px; margin:0 auto; padding:48px 24px;">

  <!-- Header -->
  <div style="margin-bottom:48px;">
    <img src="/wordmark.png" alt="FlipSplit" style="height:36px; margin-bottom:20px;" />
    <h1 style="font-size:36px; font-weight:900; margin:0 0 8px;">Brand Guidelines</h1>
    <p style="color:#64748b; margin:0;">Reference this page when making any design changes to the site.</p>
  </div>

  <!-- ── COLORS ── -->
  <div class="section">
    <p class="section-title">Colors</p>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:20px; margin-bottom:32px;">
      <div>
        <div class="swatch" style="background:#1E2A3A;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Brand Dark</p>
        <code>#1E2A3A</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Headlines, nav, dark section backgrounds, button text on blue</p>
      </div>
      <div>
        <div class="swatch" style="background:#1e88e5; border:1px solid #e2e8f0;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Brand Blue</p>
        <code>#1e88e5</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">CTA buttons, hover states, icon accents, featured highlights. Text <em>only on dark backgrounds</em>.</p>
      </div>
      <div>
        <div class="swatch" style="background:#374151;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Body Text</p>
        <code>#374151</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Paragraphs, descriptions, general copy</p>
      </div>
      <div>
        <div class="swatch" style="background:#64748b;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Muted Text</p>
        <code>#64748b (slate-500)</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Labels, metadata, secondary info, eyebrow text on white</p>
      </div>
      <div>
        <div class="swatch" style="background:#ffffff; border:1px solid #e2e8f0;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">White</p>
        <code>#ffffff</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Primary page background, card backgrounds</p>
      </div>
      <div>
        <div class="swatch" style="background:#f8fafc; border:1px solid #e2e8f0;"></div>
        <p style="font-weight:700; font-size:14px; margin:0 0 2px;">Off-White</p>
        <code>#f8fafc (slate-50)</code>
        <p style="font-size:12px; color:#64748b; margin:8px 0 0;">Subtle section backgrounds, alternating rows</p>
      </div>
    </div>

    <p style="font-weight:700; font-size:13px; margin:0 0 12px; color:#1E2A3A;">The most important color rule</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do">
        <strong>Do</strong>
        Use blue as a <strong>background color</strong> for buttons and badges, or as <strong>text on dark (#1E2A3A) backgrounds</strong>.
      </div>
      <div class="dont">
        <strong>Don't</strong>
        Use blue as text color on white or light backgrounds. Use <code>text-slate-500</code> (#64748b) for eyebrow/label text on white.
      </div>
    </div>
  </div>

  <!-- ── TYPOGRAPHY ── -->
  <div class="section">
    <p class="section-title">Typography</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-bottom:32px;">
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;margin:0 0 12px;">Headings — Sahar</p>
        <p style="font-family:'sahar','Open Sans',sans-serif;font-weight:900;font-size:36px;line-height:1.1;color:#1E2A3A;margin:0 0 8px;">The quick brown fox</p>
        <p style="font-size:12px;color:#64748b;">All H1–H4. Always font-black (900). Brand Dark on light backgrounds, white on dark backgrounds.</p>
      </div>
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;margin:0 0 12px;">Body — Open Sans</p>
        <p style="font-family:'Open Sans',sans-serif;font-size:16px;line-height:1.7;color:#374151;margin:0 0 8px;">The quick brown fox jumps over the lazy dog. Use for all body copy, descriptions, and UI text.</p>
        <p style="font-size:12px;color:#64748b;">400 for body, 600 for labels and nav, 700 for strong emphasis.</p>
      </div>
    </div>

    <p style="font-weight:700; font-size:13px; margin:0 0 16px; color:#1E2A3A;">Size scale</p>
    <div style="border:1px solid #f1f5f9; border-radius:12px; overflow:hidden;">
      {[
        { label:'H1 — Page title', size:'48–60px', weight:'900', usage:'Hero headlines', sample:'Create Your Offer' },
        { label:'H2 — Section title', size:'32–40px', weight:'900', usage:'Section headings', sample:'How FlipSplit Works' },
        { label:'H3 — Card title', size:'20–24px', weight:'900', usage:'Card headings, step titles', sample:'Share Your Address' },
        { label:'Body large', size:'18px', weight:'400', usage:'Hero subheadline, intro paragraphs', sample:'FlipSplit buys your home as-is, renovates it, and splits the profit.' },
        { label:'Body', size:'16px', weight:'400', usage:'General copy, FAQ answers', sample:'Share your address and we will respond within 48 hours.' },
        { label:'Label / Eyebrow', size:'11–12px', weight:'700', usage:'Section labels above headings', sample:'THE PROCESS' },
        { label:'Step number', size:'11–12px', weight:'700', usage:'Numbered steps (01, 02, 03)', sample:'01' },
      ].map(r => (
        <div style="display:grid; grid-template-columns:180px 1fr; border-bottom:1px solid #f1f5f9;">
          <div style="padding:14px 16px; border-right:1px solid #f1f5f9; background:#f8fafc;">
            <p style="font-size:12px; font-weight:700; color:#1E2A3A; margin:0 0 2px;">{r.label}</p>
            <p style="font-size:11px; color:#94a3b8; margin:0;">{r.size} · {r.weight}</p>
          </div>
          <div style="padding:14px 16px;">
            <p style="font-size:12px; color:#64748b; margin:0 0 4px;">{r.usage}</p>
            <p style="font-family:'sahar','Open Sans',sans-serif; font-size:13px; color:#1E2A3A; margin:0;">{r.sample}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── NUMBERED STEPS ── -->
  <div class="section">
    <p class="section-title">Numbered Steps (01, 02, 03 pattern)</p>
    <p style="font-size:13px; color:#64748b; margin:0 0 24px;">Use two-digit step numbers with a leading zero for any sequential process. The number sits above the step title, small and muted — it orients the reader without dominating the layout.</p>

    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
      {[
        { n:"01", title:"Share your address", body:"Takes 2 minutes. We analyze your home and respond in 24–48 hours." },
        { n:"02", title:"Review your offer", body:"Walk through the numbers together. The split is negotiable." },
        { n:"03", title:"Collect two checks", body:"Cash at closing, then a bonus if the home beats the projection." },
      ].map(({ n, title, body }) => (
        <div class="demo-card">
          <p style="font-size:11px; font-weight:700; letter-spacing:.1em; color:#94a3b8; margin:0 0 10px;">{n}</p>
          <h3 style="font-family:'sahar',sans-serif; font-weight:900; font-size:17px; color:#1E2A3A; margin:0 0 8px;">{title}</h3>
          <p style="font-size:13px; color:#64748b; margin:0;">{body}</p>
        </div>
      ))}
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do"><strong>Do</strong>Always use two digits: 01, 02, 03. Color is <code>text-slate-400</code> (#94a3b8) — understated, not bold.</div>
      <div class="dont"><strong>Don't</strong>Use large decorative numbers (e.g. 120px display text). Keep the number small and functional, not decorative.</div>
    </div>
  </div>

  <!-- ── THREE-OPTION COMPARISON CARDS ── -->
  <div class="section">
    <p class="section-title">Three-Option Comparison (with featured highlight)</p>
    <p style="font-size:13px; color:#64748b; margin:0 0 24px;">When presenting three options, always highlight the recommended/default one with a blue border and a "Default offer" or "Most popular" badge. The non-featured cards use a plain white bg with a standard slate border.</p>

    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
      <div class="demo-card">
        <p style="font-size:11px; font-weight:700; letter-spacing:.1em; color:#94a3b8; margin:0 0 12px;">Max Cash</p>
        <h3 style="font-family:'sahar',sans-serif; font-weight:900; font-size:17px; color:#1E2A3A; margin:0 0 8px;">Highest upfront offer</h3>
        <p style="font-size:13px; color:#64748b; margin:0 0 16px;">Maximum cash at closing. No backend participation.</p>
        <a href="#" style="font-size:13px; font-weight:700; color:#1E2A3A; text-decoration:none;">Learn More →</a>
      </div>
      <div class="demo-card featured">
        <span style="display:inline-block; font-size:11px; font-weight:700; padding:3px 10px; border-radius:999px; background:rgba(26,150,232,0.15); color:#1E2A3A; margin-bottom:12px;">Default offer</span>
        <p style="font-size:11px; font-weight:700; letter-spacing:.1em; color:#94a3b8; margin:0 0 12px;">Balanced</p>
        <h3 style="font-family:'sahar',sans-serif; font-weight:900; font-size:17px; color:#1E2A3A; margin:0 0 8px;">Cash now + upside later</h3>
        <p style="font-size:13px; color:#64748b; margin:0 0 16px;">Max offer with a 50% split on any amount above the projection.</p>
        <a href="#" style="font-size:13px; font-weight:700; color:#1E2A3A; text-decoration:none;">Learn More →</a>
      </div>
      <div class="demo-card">
        <p style="font-size:11px; font-weight:700; letter-spacing:.1em; color:#94a3b8; margin:0 0 12px;">Max Upside</p>
        <h3 style="font-family:'sahar',sans-serif; font-weight:900; font-size:17px; color:#1E2A3A; margin:0 0 8px;">Highest backend potential</h3>
        <p style="font-size:13px; color:#64748b; margin:0 0 16px;">Lower cash offer, bigger share of outperformance.</p>
        <a href="#" style="font-size:13px; font-weight:700; color:#1E2A3A; text-decoration:none;">Learn More →</a>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do"><strong>Do</strong>Feature the middle/recommended option with <code>border-color:#1e88e5</code> and a subtle blue-tint background. Add a small badge ("Default offer" / "Most popular").</div>
      <div class="dont"><strong>Don't</strong>Feature more than one card, or use a filled blue background on the featured card — it overwhelms. A blue border + light tint is enough.</div>
    </div>
  </div>

  <!-- ── FEATURE PILLS ── -->
  <div class="section">
    <p class="section-title">Feature Pills &amp; Attribute Tags</p>
    <p style="font-size:13px; color:#64748b; margin:0 0 20px;">Small inline pills used to label attributes, features, or process phases. Three styles depending on context.</p>

    <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:24px; align-items:center;">
      <!-- Blue tint — primary feature -->
      <span style="font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:rgba(26,150,232,0.12);color:#1E2A3A;">Expert Design</span>
      <span style="font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:rgba(26,150,232,0.12);color:#1E2A3A;">Quality Contractors</span>
      <span style="font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:rgba(26,150,232,0.12);color:#1E2A3A;">Project Oversight</span>
      <!-- Slate — neutral/secondary -->
      <span style="font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:#f1f5f9;color:#64748b;">6–10 weeks</span>
      <span style="font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:#f1f5f9;color:#64748b;">Your timeline</span>
      <!-- Dark bg — used on dark sections -->
      <span style="font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.7);">On dark bg</span>
    </div>

    <div style="border:1px solid #f1f5f9; border-radius:12px; overflow:hidden;">
      {[
        { style:'Blue tint', code:'bg: rgba(26,150,232,0.12) · text: #1E2A3A', usage:'Feature attributes, value props, process labels on white/light backgrounds' },
        { style:'Slate neutral', code:'bg: #f1f5f9 · text: #64748b', usage:'Time estimates, secondary metadata, non-featured tags' },
        { style:'Dark bg variant', code:'bg: rgba(255,255,255,0.10) · text: rgba(255,255,255,0.7)', usage:'Any pills placed on the #1E2A3A dark background sections' },
      ].map(({ style, code, usage }) => (
        <div style="display:grid; grid-template-columns:140px 1fr; border-bottom:1px solid #f1f5f9;">
          <div style="padding:12px 16px; border-right:1px solid #f1f5f9; background:#f8fafc;">
            <p style="font-size:12px; font-weight:700; color:#1E2A3A; margin:0;">{style}</p>
          </div>
          <div style="padding:12px 16px;">
            <code style="font-size:11px; display:block; margin-bottom:4px;">{code}</code>
            <p style="font-size:12px; color:#64748b; margin:0;">{usage}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── BUTTONS ── -->
  <div class="section">
    <p class="section-title">Buttons</p>
    <div style="display:flex; flex-wrap:wrap; gap:24px; align-items:center; margin-bottom:24px;">
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; background:#1e88e5; color:#1E2A3A; font-weight:700; padding:12px 24px; border-radius:10px; text-decoration:none; font-size:14px;">Get My Free Offer →</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Primary CTA</p>
      </div>
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; background:#1E2A3A; color:white; font-weight:700; padding:12px 24px; border-radius:10px; text-decoration:none; font-size:14px;">Learn More</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Secondary</p>
      </div>
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; border:2px solid #1E2A3A; color:#1E2A3A; font-weight:700; padding:10px 24px; border-radius:10px; text-decoration:none; font-size:14px;">View All →</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Outline</p>
      </div>
      <div style="text-align:center;">
        <a href="#" style="display:inline-block; font-weight:700; font-size:14px; color:#1E2A3A; text-decoration:none; border-bottom:2px solid #1e88e5; padding-bottom:2px;">Learn More →</a>
        <p style="font-size:11px; color:#94a3b8; margin:8px 0 0;">Text link</p>
      </div>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do"><strong>Do</strong>One primary CTA per section. Primary = blue bg, dark text. Use text links ("Learn More →") for low-priority actions inside cards.</div>
      <div class="dont"><strong>Don't</strong>Use multiple blue buttons in the same view. If two actions exist, make one primary and one secondary/outline/text.</div>
    </div>
  </div>

  <!-- ── EYEBROW / LABEL TEXT ── -->
  <div class="section">
    <p class="section-title">Eyebrow Labels</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-bottom:24px;">
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#64748b;margin:0 0 6px;">On white / light backgrounds</p>
        <p style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#64748b;margin:0 0 4px;">Our Recipe</p>
        <h2 style="font-family:'sahar',sans-serif;font-weight:900;font-size:28px;color:#1E2A3A;margin:0;">We make your home value rise.</h2>
        <p style="font-size:12px;color:#94a3b8;margin:12px 0 0;">Eyebrow = <code>text-slate-500</code> (#64748b). Always uppercase, tracking-widest, text-xs.</p>
      </div>
      <div style="background:#1E2A3A; border-radius:12px; padding:24px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#1e88e5;margin:0 0 6px;">On dark backgrounds</p>
        <h2 style="font-family:'sahar',sans-serif;font-weight:900;font-size:28px;color:white;margin:0;">Create Your Offer.</h2>
        <p style="font-size:12px;color:#94a3b8;margin:12px 0 0;">Eyebrow = <code style="background:#001a40;color:#1e88e5;">#1e88e5</code> (blue is OK here)</p>
      </div>
    </div>
  </div>

  <!-- ── SPACING ── -->
  <div class="section">
    <p class="section-title">Spacing &amp; Layout</p>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
      {[
        { label:'Page max-width', value:'max-w-7xl (1152px)', usage:'All main content areas' },
        { label:'Section padding', value:'py-20 to py-24', usage:'Vertical breathing room — lean toward more whitespace' },
        { label:'Page padding', value:'px-6', usage:'Horizontal gutters on all sections' },
        { label:'Card border radius', value:'rounded-2xl (16px)', usage:'All cards, modals, containers' },
        { label:'Small radius', value:'rounded-xl (12px)', usage:'Buttons, inputs, pills, inline elements' },
        { label:'Gap between cards', value:'gap-5 or gap-6', usage:'Card grids' },
        { label:'Card border', value:'1px solid #e2e8f0', usage:'Default card border — subtle, not heavy' },
        { label:'Featured card border', value:'1px solid #1e88e5', usage:'Highlighted/recommended option only' },
        { label:'Section alternation', value:'white → #F8FAFC → white', usage:'Alternate section backgrounds to create rhythm' },
      ].map(r => (
        <div style="background:#f8fafc; border-radius:10px; padding:16px;">
          <p style="font-size:11px;font-weight:700;color:#94a3b8;margin:0 0 4px;text-transform:uppercase;letter-spacing:.08em;">{r.label}</p>
          <code style="font-size:12px;">{r.value}</code>
          <p style="font-size:12px;color:#64748b;margin:6px 0 0;">{r.usage}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ── VOICE & TONE ── -->
  <div class="section">
    <p class="section-title">Voice &amp; Tone</p>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
      <div class="do"><strong>Do</strong>Direct and reassuring. Short sentences. Talk to homeowners like they're smart people going through something stressful. "Get your offer in 24–48 hours."</div>
      <div class="dont"><strong>Don't</strong>Jargon-heavy or salesy. Avoid "industry-leading," "cutting-edge," "seamless experience." Don't over-promise or under-explain.</div>
      <div class="do"><strong>Do</strong>Specific and concrete. "$0 out of pocket." "7-day close." "50% of anything above the projected resale." Numbers build trust.</div>
      <div class="dont"><strong>Don't</strong>Vague superlatives. "The best way to sell your home!" doesn't mean anything. Lead with the mechanism, not the marketing claim.</div>
      <div class="do"><strong>Do</strong>Frame choices as empowering. "You choose how much cash vs. upside." "Create your offer." The customer is in control.</div>
      <div class="dont"><strong>Don't</strong>Make it sound transactional or one-sided. Avoid "we buy homes fast." Lead with what the homeowner gets, not what FlipSplit does.</div>
    </div>
  </div>

  <!-- ── MESSAGING PILLARS ── -->
  <div class="section">
    <p class="section-title">Core Messaging Pillars</p>
    <p style="font-size:13px; color:#64748b; margin:0 0 20px;">Every page and section should reinforce at least one of these. When writing new copy, check it against these.</p>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">
      {[
        { n:"01", title:"Create Your Offer", body:"The homeowner is in control. They choose how much cash upfront vs. how much backend participation. No other buyer lets you do this." },
        { n:"02", title:"Maximum Cash, Not Discounted Cash", body:"FlipSplit gives the highest offer we can justify. We are not a wholesaler or lowball cash buyer. Our offer starts at the maximum." },
        { n:"03", title:"Zero Upfront Cost", body:"We fund 100% of the renovation. No repairs, no contractor management, no out-of-pocket spend. Ever." },
      ].map(({ n, title, body }) => (
        <div style="background:#f8fafc; border-radius:12px; padding:20px;">
          <p style="font-size:11px; font-weight:700; letter-spacing:.1em; color:#94a3b8; margin:0 0 10px;">{n}</p>
          <h3 style="font-family:'sahar',sans-serif; font-weight:900; font-size:16px; color:#1E2A3A; margin:0 0 8px;">{title}</h3>
          <p style="font-size:13px; color:#64748b; margin:0; line-height:1.6;">{body}</p>
        </div>
      ))}
    </div>
  </div>

  <p style="text-align:center; font-size:12px; color:#94a3b8; margin-top:40px;">FlipSplit Internal · Last updated May 2026</p>

</body>
</html>
