---
import '../styles/global.css';
import AddressForm from '../components/AddressForm.astro'
import Nav from '../components/Nav.astro';

// Steps that drive the "Our home sale recipe" tab tour below the hero.
// `icon` is a raw <svg> string injected via Astro's `set:html`.
const steps = [
  {
    tabLabel: 'Submit Details',
    title: 'Submit your property details.',
    body: 'Share your address, a few photos, and a quick home walkthrough. That\'s all we need to put together a real offer.',
    bullets: ['Address, photos, and a quick walkthrough', 'No-contingencies offer in 24–48 hours', 'Zero obligation — review on your time'],
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
  },
  {
    tabLabel: 'Customize Offer',
    title: 'Customize your offer.',
    body: 'Pick the mix that fits you — maximum cash today, or trade some upfront cash for a bigger share of the resale profit.',
    bullets: ['Slide between cash now and backend upside', 'Adjust the split up or down anytime', 'Lock it in or shop it elsewhere'],
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>',
  },
  {
    tabLabel: 'We Renovate',
    title: 'We handle the hard stuff.',
    body: 'Tenants, permitting, contractors, the entire renovation — we cover every dollar and manage every step.',
    bullets: ['We pay 100% of renovation costs', 'Permits, tenants, and contractors handled', 'You don\'t spend a dollar or lift a finger'],
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
  },
  {
    tabLabel: 'Get Paid',
    title: 'You get paid — twice.',
    body: 'Cash at closing, then a bonus check after we renovate and resell. Most sellers walk away with a six-figure backend.',
    bullets: ['Cash at closing — fast and guaranteed', 'Bonus check within 10 days of the resale', 'Our sellers average $120,000+ in extra profit'],
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
  },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>How FlipSplit Works | Sell As-Is, Share the Profit</title>
  <meta name="description" content="See exactly how FlipSplit works — guaranteed cash offer, zero-cost renovation, and a profit split when your home sells for more." />
  <link rel="canonical" href="https://www.flipsplit.com/how-it-works" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root { --brand-cyan: #1a96e8; --brand-dark: #1E2A3A; --brand-body: #374151; }
    body { font-family: 'Open Sans', sans-serif; color: var(--brand-body); }
    h1, h2, h3, h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: var(--brand-dark); }
    .btn-primary { background: var(--brand-cyan); color: #ffffff; font-weight: 700; transition: filter 0.15s ease; }
    .btn-primary:hover { filter: brightness(1.08); }
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    .faq-icon { transition: transform 0.2s ease; display: inline-block; }
    details[open] .faq-icon { transform: rotate(45deg); }
    a, button, summary { cursor: pointer; }
    @keyframes hiw-fill { from { width: 0%; } to { width: 100%; } }
    .hiw-step { transition: border-color 0.2s, box-shadow 0.2s; }
    .hiw-step.hiw-active { border-left-color: var(--brand-cyan) !important; box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
    .hiw-step.hiw-active .hiw-num { color: var(--brand-cyan) !important; }
    .hiw-step.hiw-active .hiw-title { color: var(--brand-dark) !important; }
    .hiw-step .hiw-body { max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s ease, opacity 0.4s ease, margin-top 0.4s ease; margin-top: 0; }
    .hiw-step.hiw-active .hiw-body { max-height: 100px; opacity: 1; margin-top: 0.375rem; }
    .hiw-step.hiw-active .hiw-bar { animation: hiw-fill 4s linear forwards; }
  </style>
</head>
<body class="bg-white antialiased">

  <!-- NAV -->
  <Nav />

  <!-- ─── SECTION 1: HERO ─── -->
  <section class="relative overflow-hidden py-24 px-6" style="background: linear-gradient(180deg, #EEF5FC 0%, #F8FAFC 100%);">
    <div class="relative max-w-6xl mx-auto grid lg:grid-cols-[5fr_6fr] gap-24 xl:gap-32 items-center">

      <!-- Left: copy + form -->
      <div>
        <span class="inline-block text-xs font-semibold tracking-wide mb-6 px-4 py-1.5 rounded-full" style="background:rgba(26,150,232,0.1); color:#1a96e8;">How It Works</span>
        <h1 class="text-5xl sm:text-6xl font-black leading-tight mb-6" style="color:#1E2A3A; font-family:'sahar','Open Sans',sans-serif;">
          Sell Today.<br/><span style="color:#1a96e8;">Get Paid Twice.</span>
        </h1>
        <p class="text-slate-500 text-lg leading-relaxed mb-10 max-w-lg">
          FlipSplit gives you the maximum cash offer we can justify. Then you choose: take the full amount at closing, or trade some upfront cash for a larger share of the backend profit.
        </p>
        <AddressForm id="hero-form" showTrust={false} />
      </div>

      <!-- Right: draggable before/after slider with floating Cash-now / Upside-later chips -->
      <div class="flex items-center justify-center mt-10 lg:mt-0">
        <div class="hiw-frame">
          <div class="ba-slider" id="ba-slider" role="img" aria-label="Before and after kitchen — drag to compare">
            <!-- AFTER is the base layer (always visible) -->
            <img class="ba-after"  src="/casestudies/kimball-kitchen-after.jpg"  alt="Kitchen after FlipSplit renovation"  draggable="false" />
            <!-- BEFORE sits on top and is clipped by --pos -->
            <img class="ba-before" src="/casestudies/kimball-kitchen-before.jpg" alt="Kitchen before FlipSplit renovation" draggable="false" />
            <span class="ba-label ba-label-after">After</span>
            <div class="ba-handle" aria-hidden="true">
              <div class="ba-handle-line"></div>
              <div class="ba-handle-grip">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E2A3A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 3 12 9 6"/>
                  <polyline points="15 6 21 12 15 18"/>
                </svg>
              </div>
            </div>
          </div>
          <!-- Cash now (bottom-left, white pill) -->
          <div class="hiw-chip hiw-chip-now">
            <div class="text-[10px] uppercase tracking-widest text-slate-400 font-semibold">Cash now</div>
            <div class="text-2xl font-black text-brand-dark leading-none mt-1">$900k</div>
          </div>
          <!-- Upside later (top-right, brand-blue pill) -->
          <div class="hiw-chip hiw-chip-later">
            <div class="text-[10px] uppercase tracking-widest font-semibold" style="color:rgba(255,255,255,0.8);">Upside later</div>
            <div class="text-2xl font-black leading-none mt-1" style="color:#fff;">+$125k</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <style>
    /* Draggable before/after slider + floating chips in the hero */
    .hiw-frame { position: relative; width: 100%; max-width: 600px; }

    .ba-slider {
      position: relative;
      width: 100%;
      aspect-ratio: 3 / 2;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 18px 44px rgba(15, 23, 42, 0.14);
      background: #f1f5f9;
      cursor: ew-resize;
      user-select: none;
      touch-action: none;
      --pos: 50%;
    }
    .ba-slider img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none;
      -webkit-user-drag: none;
    }
    .ba-before { clip-path: inset(0 calc(100% - var(--pos)) 0 0); }

    .ba-handle {
      position: absolute; top: 0; bottom: 0;
      left: var(--pos);
      transform: translateX(-50%);
      pointer-events: none;
      display: flex; align-items: center; justify-content: center;
    }
    .ba-handle-line {
      position: absolute; top: 0; bottom: 0;
      width: 3px;
      background: #fff;
      box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
    }
    .ba-handle-grip {
      position: relative;
      width: 44px; height: 44px;
      border-radius: 50%;
      background: #fff;
      box-shadow: 0 4px 14px rgba(0,0,0,0.25);
      display: flex; align-items: center; justify-content: center;
    }

    .ba-label {
      position: absolute;
      top: 14px;
      padding: 5px 12px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      pointer-events: none;
    }
    .ba-label-before { left: 14px;  background: rgba(15,23,42,0.7); color: #fff; }
    .ba-label-after  { right: 14px; background: #1a96e8;            color: #fff; }

    /* Floating chips outside the slider frame — gentle bob keeps them feeling lively */
    @keyframes hiw-chip-float {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-6px); }
    }
    .hiw-chip {
      position: absolute;
      padding: 0.6rem 1.15rem;
      border-radius: 999px;
      background: #fff;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.18);
      white-space: nowrap;
      font-family: 'sahar', 'Open Sans', sans-serif;
      pointer-events: none;   /* chips overlap the slider — clicks pass through */
      animation: hiw-chip-float 4s ease-in-out infinite;
    }
    .hiw-chip-now   { bottom: -0.75rem; left: -0.75rem; }
    .hiw-chip-later { top: -0.75rem;    right: -0.75rem; background: #1a96e8; animation-delay: 2s; }
    @media (prefers-reduced-motion: reduce) {
      .hiw-chip { animation: none; }
    }

    /* ── "Our home sale recipe" tab tour ──────────────────────────────── */
    .hiw2-tabs { white-space: nowrap; }
    .hiw2-tab {
      position: relative;
      padding: 0.9rem 0.25rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: #94a3b8;
      cursor: pointer;
      background: transparent;
      border: 0;
      font-family: 'Open Sans', sans-serif;
      transition: color 0.25s ease;
      flex-shrink: 0;
    }
    .hiw2-tab.is-active { color: var(--brand-dark); }
    /* Underline doubles as the progress bar — fills 0→100% over the step. */
    .hiw2-tab::after {
      content: "";
      position: absolute;
      left: 0; right: 0;
      bottom: -1px;
      height: 2px;
      background: var(--brand-cyan);
      transform: scaleX(0);
      transform-origin: left center;
    }
    .hiw2-tab.is-active::after {
      animation: hiw2-tab-fill 5s linear forwards;
    }
    @keyframes hiw2-tab-fill {
      from { transform: scaleX(0); }
      to   { transform: scaleX(1); }
    }

    /* Card stage — overlapping cards, only the active one is in flow */
    .hiw2-card-stage { position: relative; }
    .hiw2-card {
      position: absolute;
      inset: 0;
      background: #F8FAFC;
      border-radius: 24px;
      padding: 2.25rem 2rem 2.5rem;
      opacity: 0;
      transform: translateX(40px);
      transition: opacity 0.45s ease, transform 0.5s cubic-bezier(.4, 0, .2, 1);
      pointer-events: none;
    }
    .hiw2-card.is-active {
      position: relative;            /* active card drives stage height */
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
    }
    .hiw2-card.is-exiting {
      opacity: 0;
      transform: translateX(-40px);
    }

    .hiw2-card-icon {
      display: inline-flex;
      align-items: center; justify-content: center;
      width: 56px; height: 56px;
      border-radius: 14px;
      background: linear-gradient(135deg, #EEF5FC 0%, #DEE9F6 100%);
      color: #1a96e8;
      margin-bottom: 1.4rem;
    }
    .hiw2-card-icon svg { width: 28px; height: 28px; }

    .hiw2-card-title {
      font-family: 'sahar', 'Open Sans', sans-serif;
      font-size: 1.875rem;
      line-height: 1.15;
      font-weight: 900;
      color: var(--brand-dark);
      margin-bottom: 0.85rem;
    }
    @media (min-width: 768px) { .hiw2-card-title { font-size: 2.25rem; } }

    .hiw2-card-body {
      color: #64748b;
      line-height: 1.65;
      margin-bottom: 1.5rem;
    }

    .hiw2-card-bullets {
      list-style: none;
      padding: 0; margin: 0;
      display: flex; flex-direction: column;
      gap: 0.7rem;
    }
    .hiw2-card-bullets li {
      display: flex; align-items: flex-start; gap: 0.75rem;
      font-size: 0.95rem;
      color: #334155;
    }
    .hiw2-bullet-check {
      flex-shrink: 0;
      width: 22px; height: 22px;
      border-radius: 50%;
      background: rgba(26, 150, 232, 0.12);
      color: #1a96e8;
      display: inline-flex;
      align-items: center; justify-content: center;
      margin-top: 1px;
    }
    .hiw2-bullet-check svg { width: 12px; height: 12px; }

    @media (prefers-reduced-motion: reduce) {
      .hiw2-card { transition: opacity 0.2s ease; transform: none; }
      .hiw2-card.is-exiting, .hiw2-card.is-active { transform: none; }
      .hiw2-tab.is-active::after { animation: none; transform: scaleX(1); }
    }
  </style>

  <script is:inline>
    // ── Hero before/after slider (drag or click the photo to compare) ──
    (function () {
      var el = document.getElementById('ba-slider');
      if (!el) return;
      var active = false;

      function setPos(pct) {
        var p = Math.max(0, Math.min(100, pct));
        el.style.setProperty('--pos', p + '%');
      }
      function xFrom(e) {
        return (e.touches && e.touches[0]) ? e.touches[0].clientX : e.clientX;
      }
      function updateFromEvent(e) {
        var rect = el.getBoundingClientRect();
        setPos(((xFrom(e) - rect.left) / rect.width) * 100);
      }

      el.addEventListener('mousedown',  function (e) { active = true; updateFromEvent(e); e.preventDefault(); });
      el.addEventListener('touchstart', function (e) { active = true; updateFromEvent(e); }, { passive: true });
      window.addEventListener('mousemove', function (e) { if (active) updateFromEvent(e); });
      window.addEventListener('touchmove', function (e) { if (active) updateFromEvent(e); }, { passive: true });
      window.addEventListener('mouseup',     function () { active = false; });
      window.addEventListener('touchend',    function () { active = false; });
      window.addEventListener('touchcancel', function () { active = false; });

      // Keyboard a11y: focus the slider and press ← / → to nudge by 5%.
      el.setAttribute('tabindex', '0');
      el.addEventListener('keydown', function (e) {
        var cur = parseFloat(getComputedStyle(el).getPropertyValue('--pos')) || 50;
        if (e.key === 'ArrowLeft')  { setPos(cur - 5); e.preventDefault(); }
        if (e.key === 'ArrowRight') { setPos(cur + 5); e.preventDefault(); }
      });
    })();

    // ── "Our home sale recipe" tab tour ──
    // Cards slide in from the right and exit to the left. The active tab's
    // underline animates 0→100% over the step duration (CSS @keyframes
    // hiw2-tab-fill 5s); its animationend advances the tour. A setTimeout
    // fallback covers prefers-reduced-motion users (CSS disables the anim).
    document.addEventListener('DOMContentLoaded', function () {
      var tabs  = document.querySelectorAll('.hiw2-tab');
      var cards = document.querySelectorAll('.hiw2-card');
      if (!tabs.length || !cards.length) return;

      var idx = 0;
      var STEP_MS = 5000;
      var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var fallbackTimer;

      function show(i) {
        var next = ((i % cards.length) + cards.length) % cards.length;
        cards.forEach(function (c, j) {
          c.classList.remove('is-exiting');
          if (j !== next && c.classList.contains('is-active')) {
            c.classList.remove('is-active');
            c.classList.add('is-exiting');
          }
        });
        cards[next].classList.remove('is-exiting');
        cards[next].classList.add('is-active');
        tabs.forEach(function (t, j) { t.classList.toggle('is-active', j === next); });
        idx = next;
        if (prefersReduced) {
          if (fallbackTimer) clearTimeout(fallbackTimer);
          fallbackTimer = setTimeout(function () { show(idx + 1); }, STEP_MS);
        }
      }

      // Underline animation finishing on the ACTIVE tab = advance.
      // (animationend bubbles from the ::after pseudo-element up to the tab.)
      tabs.forEach(function (tab, i) {
        tab.addEventListener('click', function () { show(i); });
        tab.addEventListener('animationend', function (e) {
          if (e.animationName === 'hiw2-tab-fill' && tab.classList.contains('is-active')) {
            show(idx + 1);
          }
        });
      });

      // First card is already is-active in markup; the CSS animation starts on render.
      if (prefersReduced) fallbackTimer = setTimeout(function () { show(idx + 1); }, STEP_MS);
    });
  </script>

  <!-- ─── SECTION 2: TAB TOUR ─── -->
  <section class="hiw2-section py-28 px-6 bg-white border-t border-slate-100 relative overflow-hidden">
    <div class="max-w-3xl mx-auto relative">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold tracking-wide mb-3" style="color:#4B5563;">Simple by design</p>
        <h2 class="text-4xl md:text-5xl font-black" style="color: var(--brand-dark);">Our home sale recipe.</h2>
      </div>

      <!-- Step tab nav — each tab's underline doubles as the progress bar -->
      <div class="hiw2-tabs flex justify-center gap-6 sm:gap-10 md:gap-14 border-b border-slate-200 mb-12 mx-auto max-w-3xl px-4">
        {steps.map((s, i) => (
          <button class={`hiw2-tab ${i === 0 ? 'is-active' : ''}`} data-step={i} type="button">{s.tabLabel}</button>
        ))}
      </div>

      <!-- Card stack — only the active card is in flow; others overlay and animate -->
      <div class="hiw2-card-stage" aria-live="polite">
        {steps.map((s, i) => (
          <article class={`hiw2-card ${i === 0 ? 'is-active' : ''}`} data-step={i}>
            <div class="hiw2-card-icon" set:html={s.icon} />
            <h3 class="hiw2-card-title">{s.title}</h3>
            <p class="hiw2-card-body">{s.body}</p>
            <ul class="hiw2-card-bullets">
              {s.bullets.map((b) => (
                <li>
                  <span class="hiw2-bullet-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 3: CREATE YOUR OFFER ─── -->
  <section class="py-24 px-6" style="background:#F8FAFC;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Your choice</p>
        <h2 class="text-4xl font-black mb-4" style="color:#1E2A3A;">Create your offer.</h2>
        <p class="text-slate-500 text-base max-w-2xl mx-auto">Every FlipSplit offer starts with the maximum cash we can justify. From there, you decide how to structure it — more cash at closing, more backend participation, or anywhere in between.</p>
      </div>

      <!-- Three positions -->
      <div class="grid md:grid-cols-3 gap-5 mb-12">
        {[
          {
            label: "Max Cash",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#1a96e8" stroke-width="1.8"/><path d="M12 7v5l3 3" stroke="#1a96e8" stroke-width="1.8" stroke-linecap="round"/></svg>`,
            offer: "$1,050,000",
            split: "0%",
            threshold: "None",
            desc: "Take the highest possible upfront offer. You walk away at first closing with the maximum guaranteed cash. No backend participation — your payout is locked regardless of how the renovation performs.",
            best: "Best for: sellers who need maximum certainty and don't want to wait for a second check.",
            featured: false,
          },
          {
            label: "Balanced",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 3v18M3 12h18" stroke="#1a96e8" stroke-width="1.8" stroke-linecap="round"/></svg>`,
            offer: "$1,000,000",
            split: "50%",
            threshold: "$1,250,000",
            desc: "Our standard offer — the maximum cash we can justify today, with a 50/50 split on anything the home sells above our projected resale. At the projected price, your bonus is $0. Any outperformance is split equally.",
            best: "Best for: sellers who want maximum upfront cash and a fair share of any upside.",
            featured: true,
          },
          {
            label: "Max Upside",
