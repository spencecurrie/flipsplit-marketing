---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import AddressForm from '../components/AddressForm.astro'
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Customer Reviews | FlipSplit</title>
  <meta name="description" content="Real reviews from homeowners who sold with FlipSplit. See what our customers say about our transparent process, fair offers, and profit-sharing model." />
  <link rel="canonical" href="https://www.flipsplit.com/reviews" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root { --brand-blue: #1e88e5; --brand-dark: #1E2A3A; --brand-body: #374151; }
    body { font-family: 'Open Sans', sans-serif; color: var(--brand-body); }
    h1, h2, h3, h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: var(--brand-dark); }
    .btn-primary { background: var(--brand-blue); color: #ffffff; font-weight: 700; transition: filter 0.15s ease; }
    .btn-primary:hover { filter: brightness(1.08); }
    a, button, summary { cursor: pointer; }
    .review-card { background: white; border: 1px solid #e2e8f0; border-radius: 20px; padding: 28px; transition: box-shadow 0.2s, border-color 0.2s; }
    .review-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); border-color: #cbd5e1; }
    .review-card.featured { border-color: #1e88e5; box-shadow: 0 4px 24px rgba(26,150,232,0.1); }
  </style>
  <ClientRouter />
</head>
<body class="bg-white antialiased">

  <!-- NAV -->
  <Nav />

  <!-- ─── HERO ─── -->
  <section class="py-24 px-6 bg-white border-b border-slate-100">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-xs font-bold uppercase tracking-widest" style="background:rgba(26,150,232,0.1); color:#1e88e5;">
        Verified Reviews
      </div>
      <h1 class="text-5xl sm:text-6xl font-semibold leading-tight mb-6" style="color:#1E2A3A; font-family:'sahar','Open Sans',sans-serif;">
        Real homeowners.<br/><span style="color:#1e88e5;">Real results.</span>
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mb-12 max-w-2xl mx-auto">
        Every review is verified through REVIEWS.IO. We don't cherry-pick — this is our complete public record.
      </p>

      <!-- Aggregate stats -->
      <div class="inline-flex flex-wrap items-center justify-center gap-10 py-8 px-10 rounded-2xl border border-slate-200" style="background:#F8FAFC;">
        <div class="text-center">
          <div class="text-5xl font-black mb-1" style="color:#1E2A3A;">5.0</div>
          <div class="flex justify-center gap-0.5 mb-1" style="color:#FBBC05; font-size:20px;">★★★★★</div>
          <div class="text-xs text-slate-400 font-medium">Average rating</div>
        </div>
        <div class="hidden sm:block w-px h-14 bg-slate-200"></div>
        <div class="text-center">
          <div class="text-5xl font-black mb-1" style="color:#1E2A3A;">100%</div>
          <div class="text-xs text-slate-400 font-medium mt-4">5-star reviews</div>
        </div>
        <div class="hidden sm:block w-px h-14 bg-slate-200"></div>
        <div class="text-center">
          <div class="text-5xl font-black mb-1" style="color:#1E2A3A;">10+</div>
          <div class="text-xs text-slate-400 font-medium mt-4">Verified homeowners</div>
        </div>
        <div class="hidden sm:block w-px h-14 bg-slate-200"></div>
        <div class="text-center">
          <a href="https://www.reviews.io/company-reviews/store/flipsplit" target="_blank" rel="noopener" class="flex flex-col items-center gap-1 group">
            <div class="text-sm font-black group-hover:text-[#1e88e5] transition-colors" style="color:#1E2A3A;">REVIEWS.IO</div>
            <div class="text-xs text-slate-400 font-medium">Verified source</div>
            <div class="text-xs mt-1" style="color:#1e88e5;">View all →</div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FEATURED REVIEW ─── -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="review-card featured">
        <div class="flex flex-col sm:flex-row sm:items-start gap-6">
          <div class="shrink-0">
            <div class="w-14 h-14 rounded-full flex items-center justify-center font-black text-lg text-white" style="background:#1e88e5;">P</div>
          </div>
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <div style="color:#FBBC05; font-size:16px; letter-spacing:1px;">★★★★★</div>
              <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background:rgba(26,150,232,0.1); color:#1e88e5;">Featured Review</span>
            </div>
            <blockquote class="text-lg leading-relaxed font-medium text-[#1E2A3A] mb-5">
              "FlipSplit gave my mother a better offer than any of their competitors. She received her full cash payment at closing, and then — months later — she got a profit-sharing check when the renovated home sold for more than projected. The renovations they did genuinely benefited the whole neighborhood. Highly recommend."
            </blockquote>
            <div class="flex items-center gap-3">
              <div>
                <div class="font-bold text-sm text-[#1E2A3A]">Peter Lien</div>
                <div class="text-xs text-slate-400">Southern California</div>
              </div>
              <div class="ml-auto text-xs text-slate-400 flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Verified purchase
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── REVIEWS GRID ─── -->
  <section class="pb-24 px-6" style="background:#F8FAFC;">
    <div class="max-w-[1500px] mx-auto">
      <div class="text-center pt-20 mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-3">All Reviews</p>
        <h2 class="text-3xl sm:text-4xl font-semibold" style="color:#1E2A3A;">What our homeowners say.</h2>
      </div>

      <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
        {[
          {
            name: 'Sabrina E.',
            location: 'Southern California',
            initial: 'S',
            quote: 'They sent inspectors out before making an offer, were completely transparent throughout, and the quoted price matched the final payment exactly. Closing was convenient and everything went exactly as described. No surprises.',
          },
          {
            name: 'Rosemarie Jimenez',
            location: 'Los Angeles, CA',
            initial: 'R',
            quote: 'Everything that was discussed happened exactly as promised. The team was professional, friendly, informative, and responsive from start to finish. I felt confident in every step of the process.',
          },
          {
            name: 'Kim Topolski',
            location: 'Orange County, CA',
            initial: 'K',
            quote: 'FlipSplit made the entire transaction smooth even though my home was in less than perfect condition. Quick sale, no showings, and a direct transaction that took all the stress out of selling.',
          },
          {
            name: 'Deanna Azar',
            location: 'Inland Empire, CA',
            initial: 'D',
            quote: 'The process was quick, easy, fair, and genuinely pleasant from beginning to end. I didn\'t expect selling my home to feel this stress-free. I would absolutely recommend FlipSplit to anyone.',
          },
          {
            name: 'Jennifer Cheng',
            location: 'San Diego, CA',
            initial: 'J',
            quote: 'Stephen walked me through every pro and con thoroughly so I could make an informed decision. The team remained flexible and responsive to all of my questions and inquiries throughout the entire process.',
          },
          {
            name: 'Nick Boyd',
            location: 'Los Angeles, CA',
            initial: 'N',
            quote: 'Fair offer, completely transparent throughout, and they delivered on every promise they made. I plan to use FlipSplit again in the future and have already recommended them to friends and family.',
          },
          {
            name: 'Eddie Francis',
            location: 'Southern California',
            initial: 'E',
            quote: 'I had a 10-day deadline and FlipSplit made it happen. The team handled everything professionally over Zoom meetings, explained what to expect at every stage, and never once made me feel rushed or pressured.',
          },
          {
            name: 'William Campbell',
            location: 'Orange County, CA',
            initial: 'W',
            quote: 'Easy, quick, and transparent. They met every commitment they made. The profit-sharing model on resale is a genuine differentiator — I walked away feeling like I got a fair deal, not a discounted one.',
          },
          {
            name: 'Felipe Ramirez Salazar',
            location: 'San Diego, CA',
            initial: 'F',
            quote: 'Excellent service from start to finish. The home renovation achieved top dollar at resale. Stephen was responsive and professional at every stage. Couldn\'t be happier with how it all turned out.',
          },
        ].map(({ name, location, initial, quote }) => (
          <div class="break-inside-avoid review-card">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center font-black text-sm shrink-0" style="background:rgba(26,150,232,0.1); color:#1e88e5;">{initial}</div>
              <div>
                <div class="font-bold text-sm text-[#1E2A3A]">{name}</div>
                <div class="text-xs text-slate-400">{location}</div>
              </div>
              <div class="ml-auto flex items-center gap-1 text-xs text-slate-400">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Verified
              </div>
            </div>
            <div style="color:#FBBC05; font-size:13px; letter-spacing:1px;" class="mb-3">★★★★★</div>
            <p class="text-sm text-slate-600 leading-relaxed">"{quote}"</p>
          </div>
        ))}
      </div>

      <!-- Link to REVIEWS.IO -->
      <div class="text-center mt-14">
        <a href="https://www.reviews.io/company-reviews/store/flipsplit" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-[#1e88e5] transition-colors border border-slate-200 hover:border-[#1e88e5] rounded-xl px-6 py-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Read all reviews on REVIEWS.IO
        </a>
      </div>
    </div>
  </section>

  <!-- ─── TRUST STRIP ─── -->
  <section class="py-14 px-6 border-t border-b border-slate-100 bg-white">
    <div class="max-w-[1500px] mx-auto">
      <div class="grid sm:grid-cols-3 gap-8 text-center">
        {[
          { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="#1e88e5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`, label: 'No pressure. No obligations.', body: 'Every offer is free with zero commitment to accept.' },
          { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke="#1e88e5" stroke-width="1.8"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke="#1e88e5" stroke-width="1.8"/></svg>`, label: '100% transparent offers.', body: 'We show you every number — comps, reno costs, projected resale.' },
          { icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="#1e88e5" stroke-width="1.8" stroke-linecap="round"/></svg>`, label: 'You get paid twice.', body: 'Cash at closing, plus a bonus check if the home beats our projection.' },
        ].map(({ icon, label, body }) => (
          <div class="flex flex-col items-center gap-3">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center" style="background:rgba(26,150,232,0.08);" set:html={icon}></div>
            <div class="font-black text-[#1E2A3A]">{label}</div>
            <p class="text-sm text-slate-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section id="get-offer" class="py-24 px-6" style="background: linear-gradient(135deg, #1E2A3A 0%, #1a2744 100%);">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:rgba(26,150,232,0.8);">Free. No obligation.</p>
      <h2 class="text-3xl sm:text-4xl font-semibold mb-4 leading-tight" style="color:white; font-family:'sahar','Open Sans',sans-serif;">
        Join our homeowners.<br/>Get your free offer.
      </h2>
      <p class="text-slate-400 mb-10 text-lg">Results in 24–48 hours. No repairs. No agent fees.</p>
      <AddressForm id="cta-form" class="flex flex-col items-center" align="center" />
    </div>
  </section>

  <!-- FOOTER -->
  <Footer />

</body>
</html>
