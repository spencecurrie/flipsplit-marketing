---
import '../styles/global.css';
import AddressForm from '../components/AddressForm.astro';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>How FlipSplit Works | Sell As-Is, Share the Profit</title>
  <meta name="description" content="See exactly how FlipSplit works — guaranteed cash offer, zero-cost renovation, and a profit split when your home sells for more." />
  <link rel="canonical" href="https://www.flipsplit.com/how-it-works" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root { --brand-cyan: #0080FF; --brand-dark: #0C3034; --brand-body: #34313D; }
    body { font-family: 'Open Sans', sans-serif; color: var(--brand-body); }
    h1, h2, h3, h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: var(--brand-dark); }
    .btn-primary { background: var(--brand-cyan); color: #ffffff; font-weight: 700; transition: filter 0.15s ease; }
    .btn-primary:hover { filter: brightness(1.08); }
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    .faq-icon { transition: transform 0.2s ease; display: inline-block; }
    details[open] .faq-icon { transform: rotate(45deg); }
    a, button, summary { cursor: pointer; }
    @keyframes hiw-fill { from { width: 0%; } to { width: 100%; } }
    .hiw-step { transition: border-color 0.2s, box-shadow 0.2s; }
    .hiw-step.hiw-active { border-left-color: var(--brand-cyan) !important; box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
    .hiw-step.hiw-active .hiw-num { color: var(--brand-cyan) !important; }
    .hiw-step.hiw-active .hiw-title { color: var(--brand-dark) !important; }
    .hiw-step .hiw-body { max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s ease, opacity 0.4s ease, margin-top 0.4s ease; margin-top: 0; }
    .hiw-step.hiw-active .hiw-body { max-height: 100px; opacity: 1; margin-top: 0.375rem; }
    .hiw-step.hiw-active .hiw-bar { animation: hiw-fill 4s linear forwards; }
  </style>
</head>
<body class="bg-white antialiased">

  <!-- NAV -->
  <nav class="sticky top-0 z-50 bg-white border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/"><img src="/wordmark.png" alt="FlipSplit" class="h-9" /></a>
      <div class="hidden md:flex items-center gap-8 text-sm text-slate-500 font-medium">
        <a href="/how-it-works" class="font-semibold transition-colors" style="color:#0C3034;">How It Works</a>
        <a href="/#why-flipsplit" class="hover:text-[#0C3034] transition-colors">Why FlipSplit</a>
        <a href="/blog" class="hover:text-[#0C3034] transition-colors">Blog</a>
        <a href="/#faq" class="hover:text-[#0C3034] transition-colors">FAQ</a>
      </div>
      <a href="#get-offer" class="btn-primary text-sm px-5 py-2.5 rounded-lg">Get My Offer</a>
    </div>
  </nav>

  <!-- ─── SECTION 1: HERO ─── -->
  <section class="relative overflow-hidden py-24 px-6 bg-white">
    <div class="relative max-w-6xl mx-auto grid lg:grid-cols-2 gap-14 items-center">

      <!-- Left: copy + form -->
      <div>
        <span class="inline-block text-xs font-semibold tracking-wide mb-6 px-4 py-1.5 rounded-full" style="background:rgba(0,128,255,0.1); color:#0080FF;">How It Works</span>
        <h1 class="text-5xl sm:text-6xl font-black leading-tight mb-6" style="color:#0C3034; font-family:'sahar','Open Sans',sans-serif;">
          Create<br/><span style="color:#0080FF;">your offer.</span>
        </h1>
        <p class="text-slate-500 text-lg leading-relaxed mb-10 max-w-lg">
          FlipSplit gives you the maximum cash offer we can justify. Then you choose: take the full amount at closing, or trade some upfront cash for a larger share of the backend profit if the home beats our projection.
        </p>
        <AddressForm id="hero-form" action="https://formspree.io/f/YOUR_FORM_ID" />
      </div>

      <!-- Right: interactive offer slider -->
      <div class="hidden lg:block">
        <div class="rounded-2xl p-7 border border-slate-200" style="background:#f8f4f3;">
          <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color:#0080FF;">Create your offer</p>
          <p class="text-xs mb-6 text-slate-400">Slide to adjust your cash/upside mix</p>

          <!-- Slider labels -->
          <div class="flex justify-between text-xs font-semibold mb-2 text-slate-400">
            <span>Max Cash Now</span>
            <span>Max Upside Later</span>
          </div>
          <!-- Slider -->
          <input id="hiw-slider" type="range" min="0" max="100" value="50"
            class="w-full mb-6"
            style="-webkit-appearance:none; appearance:none; height:6px; border-radius:3px; background:linear-gradient(to right, #0080FF 50%, #e2e8f0 50%); outline:none; cursor:pointer;" />

          <!-- Output -->
          <div class="grid grid-cols-2 gap-3 mb-5">
            <div class="rounded-xl p-4 border border-slate-200" style="background:#fdfcfb;">
              <div class="text-xs font-semibold uppercase tracking-widest mb-2 text-slate-400">Cash at closing</div>
              <div id="hiw-offer" class="text-2xl font-black" style="color:#0C3034;">$1,000,000</div>
              <div class="text-xs mt-1 text-slate-400">Guaranteed</div>
            </div>
            <div class="rounded-xl p-4 border" style="background:rgba(0,128,255,0.06); border-color:rgba(0,128,255,0.2);">
              <div class="text-xs font-semibold uppercase tracking-widest mb-2 text-slate-400">Backend split</div>
              <div id="hiw-split" class="text-2xl font-black" style="color:#0080FF;">50%</div>
              <div class="text-xs mt-1 text-slate-400">Of amount above projection</div>
            </div>
          </div>

          <!-- Scenario hint -->
          <div id="hiw-hint" class="rounded-xl p-4 text-xs leading-relaxed border border-slate-200 text-slate-500" style="background:#fdfcfb;">
            Balanced offer. Full cash at closing with a 50% bonus if the home sells above the $1,250,000 projection.
          </div>
        </div>
      </div>

    </div>
  </section>

  <style>
    #hiw-slider::-webkit-slider-thumb {
      -webkit-appearance: none; width: 22px; height: 22px; border-radius: 50%;
      background: #0080FF; border: 3px solid white; box-shadow: 0 0 0 2px #0080FF; cursor: pointer;
    }
    #hiw-slider::-moz-range-thumb {
      width: 22px; height: 22px; border-radius: 50%;
      background: #0080FF; border: 3px solid white; cursor: pointer;
    }
  </style>

  <script is:inline>
    (function () {
      var slider = document.getElementById('hiw-slider');
      var offerEl = document.getElementById('hiw-offer');
      var splitEl = document.getElementById('hiw-split');
      var hintEl  = document.getElementById('hiw-hint');
      if (!slider) return;

      function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }

      function update(val) {
        // val 0 = max cash, 100 = max upside
        // Offer slides from $1,050,000 (max cash) down to $900,000 (max upside)
        var offer = Math.round(1050000 - (val / 100) * 150000);
        // Split slides from 0% up to 75%
        var split = Math.round(val * 0.75);
        // Threshold: at val=0 no participation, otherwise slides from $1,300K down to $1,150K
        var threshold = Math.round(1300000 - (val / 100) * 150000);

        offerEl.textContent = fmt(offer);
        splitEl.textContent = split + '%';

        // Update slider track fill
        slider.style.background = 'linear-gradient(to right, #0080FF ' + val + '%, #e2e8f0 ' + val + '%)';

        var hint = '';
        if (val === 0) {
          hint = 'Maximum cash at closing. No backend participation — your payout is fixed regardless of resale.';
        } else if (val < 35) {
          hint = 'Higher upfront cash with a small backend. You benefit modestly if the home outperforms our projection.';
        } else if (val < 65) {
          hint = 'Balanced offer. Full cash at closing with a ' + split + '% bonus if the home sells above the ' + fmt(threshold) + ' projection.';
        } else if (val < 90) {
          hint = 'You\'re trading some upfront cash for a bigger backend share. Strong upside if the market beats our projection.';
        } else {
          hint = 'Maximum backend participation. Lower cash now, but the highest possible bonus if the home significantly outperforms.';
        }
        hintEl.textContent = hint;
      }

      slider.addEventListener('input', function () { update(parseInt(this.value)); });
      update(50);
    })();

    // ── How It Works auto-tour ──
    document.addEventListener('DOMContentLoaded', function () {
      var hiwSteps = document.querySelectorAll('.hiw-step');
      var hiwIndex = 0;
      var hiwTimer;
      var hiwAutoPlay = true;

      function hiwActivate(idx) {
        hiwIndex = ((idx % hiwSteps.length) + hiwSteps.length) % hiwSteps.length;
        hiwSteps.forEach(function (s, i) {
          s.classList.toggle('hiw-active', i === hiwIndex);
          var bar = s.querySelector('.hiw-bar');
          if (i !== hiwIndex) {
            bar.style.animation = 'none';
            bar.style.width = '0%';
          } else {
            bar.style.animation = 'none';
            bar.offsetWidth; // force reflow
            if (hiwAutoPlay) {
              bar.style.width = '';
              bar.style.animation = '';
            } else {
              bar.style.width = '100%';
            }
          }
        });
        clearTimeout(hiwTimer);
        if (hiwAutoPlay) hiwTimer = setTimeout(function () { hiwActivate(hiwIndex + 1); }, 4000);
      }

      hiwSteps.forEach(function (step, i) {
        step.addEventListener('click', function () {
          hiwAutoPlay = false;
          clearTimeout(hiwTimer);
          hiwActivate(i);
        });
      });

      hiwActivate(0);
    });
  </script>

  <!-- ─── SECTION 2: HOME SALE RECIPE ─── -->
  <section class="py-28 px-6 bg-white border-t border-slate-100">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold tracking-wide mb-3" style="color: #4B5563;">Simple by design</p>
        <h2 class="text-4xl md:text-5xl font-black" style="color: var(--brand-dark);">Our home sale recipe.</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center">

        <!-- Left: app screenshot -->
        <div class="flex items-center justify-center">
          <img src="/app-screenshot.png" alt="FlipSplit app" class="w-full max-w-xs mx-auto" />
        </div>

        <!-- Right: auto-advancing tour -->
        <div class="flex flex-col gap-3">
          {[
            { num: '01', title: 'Submit your property details', body: 'Submit your property details, a few photos, and a quick home walkthrough to receive a "no-contingencies" offer from FlipSplit within 24–48 hours.' },
            { num: '02', title: 'Customize your home offer', body: 'Choose your upfront offer price! Offer price can move up or down based on how much of the backend profit you desire from a newly renovated home.' },
            { num: '03', title: 'We handle the hard stuff', body: "From tenant issues to permitting to renovation — we take care of it all. You don't spend a dollar or lift a finger." },
            { num: '04', title: 'You get paid — twice', body: "Once the home is renovated and resold, you'll be notified within 10 days of the resale of the bonus check headed your way." },
          ].map(({ num, title, body }) => (
            <button class="hiw-step relative w-full text-left pl-5 pr-4 py-5 rounded-xl border border-slate-200 border-l-4 border-l-transparent bg-white">
              <div class="flex gap-4 items-start">
                <span class="hiw-num text-sm font-black shrink-0 mt-0.5" style="color: #CBD5E1;">{num}</span>
                <div class="flex-1">
                  <div class="hiw-title font-bold text-sm text-slate-400">{title}</div>
                  <div class="hiw-body text-sm text-slate-500 leading-relaxed">{body}</div>
                </div>
              </div>
              <div class="hiw-bar absolute bottom-0 left-0 h-0.5" style="background: var(--brand-cyan); width: 0%;"></div>
            </button>
          ))}
          <div class="flex items-center gap-4 pt-6 pl-5">
            <a href="#get-offer" class="btn-primary inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold">
              Get My Free Offer →
            </a>
            <span class="text-xs text-slate-400">No obligation. Results in 24–48 hrs.</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── SECTION 3: CREATE YOUR OFFER ─── -->
  <section class="py-24 px-6" style="background:#f8fafa;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Your choice</p>
        <h2 class="text-4xl font-black mb-4" style="color:#0C3034;">Create your offer.</h2>
        <p class="text-slate-500 text-base max-w-2xl mx-auto">Every FlipSplit offer starts with the maximum cash we can justify. From there, you decide how to structure it — more cash at closing, more backend participation, or anywhere in between.</p>
      </div>

      <!-- Three positions -->
      <div class="grid md:grid-cols-3 gap-5 mb-12">
        {[
          {
            label: "Max Cash",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#0080FF" stroke-width="1.8"/><path d="M12 7v5l3 3" stroke="#0080FF" stroke-width="1.8" stroke-linecap="round"/></svg>`,
            offer: "$1,050,000",
            split: "0%",
            threshold: "None",
            desc: "Take the highest possible upfront offer. You walk away at first closing with the maximum guaranteed cash. No backend participation — your payout is locked regardless of how the renovation performs.",
            best: "Best for: sellers who need maximum certainty and don't want to wait for a second check.",
            featured: false,
          },
          {
            label: "Balanced",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 3v18M3 12h18" stroke="#0080FF" stroke-width="1.8" stroke-linecap="round"/></svg>`,
            offer: "$1,000,000",
            split: "50%",
            threshold: "$1,250,000",
            desc: "Our standard offer — the maximum cash we can justify today, with a 50/50 split on anything the home sells above our projected resale. At the projected price, your bonus is $0. Any outperformance is split equally.",
            best: "Best for: sellers who want maximum upfront cash and a fair share of any upside.",
            featured: true,
          },
          {
            label: "Max Upside",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 17l4-8 4 5 3-3 4 6" stroke="#0080FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
            offer: "$900,000",
            split: "75%",
            threshold: "$1,150,000",
            desc: "Trade some upfront cash for a bigger share of the backend. The participation threshold is lowered, so you benefit from outperformance sooner — and at a higher rate. Higher potential, lower guaranteed floor.",
            best: "Best for: sellers who believe strongly the home will significantly beat our projection.",
            featured: false,
          },
        ].map(({ label, icon, offer, split, threshold, desc, best, featured }) => (
          <div class={`rounded-2xl border p-7 flex flex-col ${featured ? 'border-[#0080FF] shadow-lg' : 'border-slate-200 bg-white'}`} style={featured ? "background:rgba(0,128,255,0.03);" : ""}>
            {featured && <div class="text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full self-start" style="background:rgba(0,128,255,0.15); color:#0C3034;">Default offer</div>}
            <div class="flex items-center gap-3 mb-5">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style="background:rgba(0,128,255,0.1);" set:html={icon}></div>
              <h3 class="font-black text-lg" style="color:#0C3034;">{label}</h3>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="rounded-xl p-3 text-center" style="background:#f8fafa;">
                <div class="text-xs text-slate-400 mb-1">Cash offer</div>
                <div class="font-black text-sm" style="color:#0C3034;">{offer}</div>
              </div>
              <div class="rounded-xl p-3 text-center" style="background:#f8fafa;">
                <div class="text-xs text-slate-400 mb-1">Backend split</div>
                <div class="font-black text-sm" style="color:#0080FF;">{split}</div>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed mb-4 flex-1">{desc}</p>
            <p class="text-xs font-semibold" style="color:#0C3034;">{best}</p>
          </div>
        ))}
      </div>

      <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-5">How we arrive at your numbers</p>
      <div class="grid md:grid-cols-3 gap-5 mb-10">
        {[
          {
            step: "Step 1",
            title: "Recent comparable sales",
            body: "We pull the last 90 days of closed sales within a half-mile of your home — filtering for similar square footage, lot size, bed/bath count, and condition. This sets your as-is baseline.",
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M3 3h18M3 9h18M3 15h10M3 21h7" stroke="#0080FF" stroke-width="1.8" stroke-linecap="round"/></svg>`,
          },
          {
            step: "Step 2",
            title: "Renovation value analysis",
            body: "We model the after-renovation value using recent sales of fully updated homes in your neighborhood. The difference between your as-is baseline and that number is the renovation spread — and the source of your profit share.",
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M3 17l4-8 4 5 3-3 4 6" stroke="#0080FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
          },
          {
            step: "Step 3",
            title: "Maximizing your offer",
            body: "We set your cash offer at the highest amount we can justify given the projected resale value and renovation costs. The goal is to put as much money in your pocket at closing as possible. The profit participation threshold is set at the projected resale — meaning your backend bonus only kicks in if the market outperforms our projection.",
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="#0080FF" stroke-width="1.8"/><path d="M8 12h8M12 8v8" stroke="#0080FF" stroke-width="1.8" stroke-linecap="round"/></svg>`,
          },
        ].map(({ step, title, body, icon }) => (
          <div class="bg-white rounded-2xl border border-slate-200 p-8">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:rgba(0,128,255,0.1);" set:html={icon}></div>
            <div class="text-xs font-bold uppercase tracking-widest mb-2 text-slate-400">{step}</div>
            <h3 class="font-black text-lg mb-3" style="color:#0C3034;">{title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <!-- Math breakdown -->
      <div class="rounded-2xl p-8 sm:p-10 border border-slate-200" style="background:#f8f4f3;">
        <div class="flex flex-wrap items-start justify-between gap-2 mb-8">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color:#0080FF;">Real customer example</p>
            <p class="text-sm text-slate-400">Home sold $100,000 above the projected resale value</p>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-10 items-start">
          <!-- Left: the numbers -->
          <div class="space-y-0">
            <div class="flex items-start justify-between gap-4 pb-5 border-b border-slate-200">
              <div>
                <div class="text-sm font-bold" style="color:#0C3034;">Cash offer (at closing)</div>
                <div class="text-xs mt-0.5 text-slate-400">Maximum we can justify — paid at first closing</div>
              </div>
              <div class="text-sm font-black whitespace-nowrap" style="color:#0C3034;">$1,000,000</div>
            </div>
            <div class="flex items-start justify-between gap-4 py-5 border-b border-slate-200">
              <div>
                <div class="text-sm font-bold" style="color:#0C3034;">Total renovation cost</div>
                <div class="text-xs mt-0.5 text-slate-400">Funded entirely by FlipSplit — $0 from seller</div>
              </div>
              <div class="text-sm font-black whitespace-nowrap text-slate-500">$200,000</div>
            </div>
            <div class="flex items-start justify-between gap-4 py-5 border-b border-slate-200">
              <div>
                <div class="text-sm font-bold" style="color:#0C3034;">Projected resale value</div>
                <div class="text-xs mt-0.5 text-slate-400">Also the profit participation threshold</div>
              </div>
              <div class="text-sm font-black whitespace-nowrap text-slate-500">$1,250,000</div>
            </div>
            <div class="flex items-start justify-between gap-4 py-5 border-b border-slate-200">
              <div>
                <div class="text-sm font-bold" style="color:#0C3034;">Actual resale price</div>
                <div class="text-xs mt-0.5 text-slate-400">$100,000 above projection — triggers bonus</div>
              </div>
              <div class="text-sm font-black whitespace-nowrap" style="color:#0C3034;">$1,350,000</div>
            </div>
            <div class="flex items-start justify-between gap-4 pt-5">
              <div>
                <div class="text-sm font-bold" style="color:#0080FF;">Seller bonus (50% of $100K)</div>
                <div class="text-xs mt-0.5 text-slate-400">Issued as second check after resale closes</div>
              </div>
              <div class="text-sm font-black whitespace-nowrap" style="color:#0080FF;">+ $50,000</div>
            </div>
          </div>

          <!-- Right: summary callout -->
          <div class="space-y-4">
            <div class="rounded-2xl p-7 border" style="background:#fdfcfb; border-color:rgba(0,128,255,0.2);">
              <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#0080FF;">Total seller payout</p>
              <div class="text-5xl font-black mb-1" style="color:#0C3034;">$1,050,000</div>
              <p class="text-sm mb-6 text-slate-400">$1,000,000 at closing + $50,000 bonus check</p>
              <div class="border-t pt-5 border-slate-200">
                <div class="text-2xl font-black mb-1" style="color:#0080FF;">+$200,000</div>
                <p class="text-xs text-slate-400">more than a typical cash buyer would have paid</p>
              </div>
            </div>
            <div class="rounded-xl p-5 border border-slate-200" style="background:#fdfcfb;">
              <p class="text-xs font-semibold mb-2" style="color:#0C3034;">Key point</p>
              <p class="text-xs leading-relaxed text-slate-500">We set the cash offer as high as possible so you receive maximum value at closing. The backend bonus is purely upside — it only applies if the market outperforms our projection.</p>
            </div>
          </div>
        </div>
        <p class="text-xs mt-8 text-slate-300">* Based on a real FlipSplit transaction. Actual results vary by market, condition, and agreed split percentage.</p>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 4: WHY WE EXIST ─── -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Why we exist</p>
