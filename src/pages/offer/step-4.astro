---
import OfferLayout from '../../layouts/OfferLayout.astro';

const options = [
  { value: 'asap',           label: 'ASAP' },
  { value: '2_4_weeks',      label: '2–4 Weeks' },
  { value: '4_8_weeks',      label: '4–8 Weeks' },
  { value: '8_plus_weeks',   label: '8+ Weeks' },
  { value: 'just_curious',   label: 'Just curious' },
];
---

<OfferLayout
  step={4}
  title="When is your ideal selling timeframe?"
  subtitle="This will not have an impact on your offer. We can buy your home in as little as 5 days or up to 60 days."
  backHref="/offer/step-3/"
  nextHref="/offer/step-5/"
  autoAdvance={true}
>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-4xl mx-auto">
    {options.map((opt) => (
      <button type="button" class="offer-card-btn" data-value={opt.value} aria-pressed="false">
        {opt.label}
      </button>
    ))}
  </div>
</OfferLayout>

<script>
  declare global {
    interface Window {
      __funnel: {
        sessionId: string;
        getSelected: () => Record<string, unknown> | null;
        advance: () => Promise<void>;
        setError: (msg: string) => void;
        clearError: () => void;
      };
    }
  }

  const setup = (session: { timeframe?: string | null }) => {
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.offer-card-btn'));
    const nextBtn = document.getElementById('offer-next') as HTMLButtonElement;
    let selected: string | null = session.timeframe ?? null;
    let advancing = false;

    const render = () => {
      buttons.forEach((b) => {
        const isSel = b.dataset.value === selected;
        b.setAttribute('aria-pressed', isSel ? 'true' : 'false');
        b.disabled = advancing;
      });
      nextBtn.disabled = !selected || advancing;
    };

    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        if (advancing) return;
        selected = b.dataset.value!;
        advancing = true;
        render();
        setTimeout(() => window.__funnel.advance(), 280);
      });
    });

    window.__funnel.getSelected = () => (selected ? { timeframe: selected } : null);
    render();
  };

  if ((window as any).__funnel?.session) {
    setup((window as any).__funnel.session);
  } else {
    window.addEventListener('funnel-ready', (e) => setup((e as CustomEvent).detail), { once: true });
  }
</script>
