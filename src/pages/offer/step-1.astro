---
import OfferLayout from '../../layouts/OfferLayout.astro';

const options = [
  { value: 'owner', label: "Yes, I'm the owner" },
  { value: 'agent', label: "No, I'm an agent" },
  { value: 'other', label: 'Other' },
];
---

<OfferLayout
  step={1}
  title="Are you the current owner of the home?"
  subtitle="Please select your current selling situation."
  backHref="/"
  nextHref="/offer/step-2/"
  autoAdvance={true}
>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-4xl mx-auto">
    {options.map((opt) => (
      <button type="button" class="offer-card-btn" data-value={opt.value} aria-pressed="false">
        {opt.label}
      </button>
    ))}
  </div>
</OfferLayout>

<script>
  declare global {
    interface Window {
      __funnel: {
        sessionId: string;
        session: any;
        getSelected: () => Record<string, unknown> | null;
        advance: () => Promise<void>;
        setError: (msg: string) => void;
        clearError: () => void;
      };
    }
  }

  const setup = (session: { owner_status?: string | null }) => {
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.offer-card-btn'));
    const nextBtn = document.getElementById('offer-next') as HTMLButtonElement;
    let selected: string | null = null;
    let advancing = false;

    const render = () => {
      buttons.forEach((b) => {
        b.setAttribute('aria-pressed', b.dataset.value === selected ? 'true' : 'false');
        b.disabled = advancing;
      });
      nextBtn.disabled = !selected || advancing;
    };

    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        if (advancing) return;
        selected = b.dataset.value!;
        advancing = true;
        render();
        setTimeout(() => window.__funnel.advance(), 280);
      });
    });

    window.__funnel.getSelected = () => (selected ? { owner_status: selected } : null);
    render();
  };

  if ((window as any).__funnel?.session) {
    setup((window as any).__funnel.session);
  } else {
    window.addEventListener('funnel-ready', (e) => setup((e as CustomEvent).detail), { once: true });
  }
</script>
