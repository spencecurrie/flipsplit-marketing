    <div class="max-w-[1500px] mx-auto flex flex-col items-center gap-12">
      <div class="text-center max-w-2xl">
        <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-[1.1] text-brand-dark mb-5">Your home offer redefined</h2>
