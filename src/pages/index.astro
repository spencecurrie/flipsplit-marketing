  <!-- ─── LEAD CAPTURE FORM ─── -->
  <section id="get-offer" class="py-28 px-6 bg-slate-50">
    <div class="max-w-xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold tracking-wide mb-4" style="color: #4B5563;">Free. No obligation.</p>
        <h2 class="text-4xl md:text-5xl font-black mb-4 text-brand-dark">Get your free offer today.</h2>
        <p class="text-slate-500 text-lg leading-relaxed">
          Takes 2 minutes. We'll follow up with your cash offer amount, renovation plan, and profit participation projection.
        </p>
      </div>
      <form
        id="lead-form"
        class="space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-8"
        action="https://formspree.io/f/YOUR_FORM_ID"
