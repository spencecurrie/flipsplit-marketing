  <script>
    const slider  = document.getElementById('deal-slider');
    const offerEl = document.getElementById('offer-amount');
    const splitEl = document.getElementById('split-pct');
    const badgeEl = document.getElementById('split-badge');
    const tableEl = document.getElementById('earnings-table');

    let baseOffer = 415000;

    function fmt(n) {
      return '$' + Math.round(n).toLocaleString('en-US');
    }

    function updateTable(offer, pct) {
      const projected  = Math.round(offer * 1.2);
      const steps      = [0, 25000, 50000, 100000, 150000, 250000];
      const resaleRows = steps.map(s => projected + s);

      splitEl.textContent = pct + '%';
      badgeEl.textContent = pct + '% split';
      slider.style.setProperty('--fill', pct + '%');

      tableEl.innerHTML = resaleRows.map((resale, i) => {
        const above   = Math.max(0, resale - projected);
        const backend = above * (pct / 100);
        const total   = offer + backend;
        const isBase  = i === 0;
        return `
          <div class="grid grid-cols-3 gap-x-2 px-1 py-1.5 rounded-lg ${isBase ? 'bg-slate-50' : ''}">
            <span class="text-brand-dark font-semibold text-xs">
              ${fmt(resale)}${isBase ? '<span class="ml-1 text-slate-400 font-normal">proj.</span>' : ''}
            </span>
            <span class="text-center text-xs ${backend > 0 ? 'font-semibold' : 'text-slate-400'}" style="${backend > 0 ? 'color:var(--brand-cyan)' : ''}">
              ${backend > 0 ? '+' + fmt(backend) : '—'}
            </span>
            <span class="text-right font-bold text-xs text-brand-dark">${fmt(total)}</span>
          </div>`;
      }).join('');
    }

    offerEl.addEventListener('input', () => {
      const raw = offerEl.value.replace(/[^0-9]/g, '');
      offerEl.value = parseInt(raw || '0').toLocaleString('en-US');
      baseOffer = parseInt(raw) || 415000;
      slider.value = 50;
      updateTable(baseOffer, 50);
    });

    slider.addEventListener('input', () => {
      const pct   = parseInt(slider.value);
      const offer = baseOffer + (50 - pct) * 1000;
      offerEl.value = Math.max(0, offer).toLocaleString('en-US');
      updateTable(Math.max(0, offer), pct);
    });

    updateTable(baseOffer, 50);

    // ── Testimonial carousel ──
    const inner   = document.getElementById('testimonial-inner');
    const dotsEl  = document.getElementById('testimonial-dots');
    const total   = inner.children.length;
    let current   = 0;
    let autoTimer;

    const dots = Array.from({ length: total }, (_, i) => {
      const d = document.createElement('button');
      d.className = 'w-2 h-2 rounded-full transition-colors duration-300';
      d.style.background = i === 0 ? 'var(--brand-cyan)' : '#e2e8f0';
      d.addEventListener('click', () => goTo(i));
      dotsEl.appendChild(d);
      return d;
    });

    function goTo(index) {
      current = (index + total) % total;
      inner.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.style.background = i === current ? 'var(--brand-cyan)' : '#e2e8f0');
      resetTimer();
    }

    function resetTimer() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => goTo(current + 1), 5000);
    }

    document.getElementById('testimonial-prev').addEventListener('click', () => goTo(current - 1));
    document.getElementById('testimonial-next').addEventListener('click', () => goTo(current + 1));

    // Touch swipe support
    let touchStartX = 0;
    inner.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    inner.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
    });

    resetTimer();
  </script>

