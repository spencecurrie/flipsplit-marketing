              </div>
              <div>
                <div class="text-[10px] uppercase tracking-wide text-slate-400 mb-1">Total to seller</div>
                <div class="text-xl font-black text-brand-dark" style="font-family:'sahar','Open Sans',sans-serif;">$978k</div>
              </div>
            </div>
          </div>
        </article>

        <!-- Case 2: Via Viente -->
        <article class="rounded-3xl overflow-hidden bg-white border border-slate-200">
          <div class="ba-slider" role="img" aria-label="Via Viente kitchen — drag to compare before and after">
            <img class="ba-after"  src="/casestudies/viaviente-kitchen-after.jpg"  alt="Via Viente kitchen after renovation"  draggable="false" />
            <img class="ba-before" src="/casestudies/viaviente-kitchen-before.jpg" alt="Via Viente kitchen before renovation" draggable="false" />
            <div class="ba-handle" aria-hidden="true">
              <div class="ba-handle-line"></div>
              <div class="ba-handle-grip">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2A3A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 3 12 9 6"/>
