    </div>
  </section>

  <script is:inline>
    // Bind drag/touch/keyboard handlers to every .ba-slider on the page.
    (function () {
      document.querySelectorAll('.ba-slider').forEach(function (el) {
        var active = false;
        function setPos(pct) {
          var p = Math.max(0, Math.min(100, pct));
          el.style.setProperty('--pos', p + '%');
        }
        function xFrom(e) {
          return (e.touches && e.touches[0]) ? e.touches[0].clientX : e.clientX;
        }
        function updateFromEvent(e) {
          var rect = el.getBoundingClientRect();
          setPos(((xFrom(e) - rect.left) / rect.width) * 100);
        }
        el.addEventListener('mousedown',  function (e) { active = true; updateFromEvent(e); e.preventDefault(); });
        el.addEventListener('touchstart', function (e) { active = true; updateFromEvent(e); }, { passive: true });
        window.addEventListener('mousemove', function (e) { if (active) updateFromEvent(e); });
        window.addEventListener('touchmove', function (e) { if (active) updateFromEvent(e); }, { passive: true });
        window.addEventListener('mouseup',     function () { active = false; });
        window.addEventListener('touchend',    function () { active = false; });
        window.addEventListener('touchcancel', function () { active = false; });

        el.setAttribute('tabindex', '0');
        el.addEventListener('keydown', function (e) {
          var cur = parseFloat(getComputedStyle(el).getPropertyValue('--pos')) || 50;
          if (e.key === 'ArrowLeft')  { setPos(cur - 5); e.preventDefault(); }
          if (e.key === 'ArrowRight') { setPos(cur + 5); e.preventDefault(); }
        });
      });
    })();
  </script>


  <!-- ─── SITUATION TARGETING ─── -->
  <section class="py-20 px-6" style="background: #F8FAFC;">
    <div class="max-w-[1500px] mx-auto">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold tracking-wide mb-3" style="color: #4B5563;">We help in any situation</p>
        <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-[1.1] text-brand-dark mb-5">Whatever brought you here.</h2>
        <p class="text-slate-500 text-lg leading-relaxed max-w-md mx-auto">We work with homeowners in every situation — no judgment, no pressure.</p>
      </div>
      {(() => {
        const tags = [
          { label: 'Need to downsize', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/></svg>' },
          { label: 'Relocating for work', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>' },
          { label: 'Inherited a property', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
          { label: 'Behind on payments', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
          { label: 'Home needs major repairs', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>' },
          { label: 'Tired of being a landlord', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>' },
          { label: 'Need to sell fast', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
          { label: 'Avoiding foreclosure', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' },
        ];
        const chip = ({ label, icon }: { label: string; icon: string }) => (
          <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white text-sm font-medium text-brand-dark shadow-sm" style="border: 1px solid rgba(26,150,232,0.35);">
            <span class="shrink-0" set:html={icon} />
            {label}
          </span>
        );
        return (
          <div class="flex flex-wrap justify-center gap-3">
            {tags.map(chip)}
          </div>
        );
      })()}
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section id="faq" class="py-28 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="mb-14 text-center">
        <p class="text-sm font-semibold tracking-wide mb-3" style="color: #4B5563;">FAQ</p>
        <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-[1.1] text-brand-dark mb-5">Common questions.</h2>
      </div>
      <div>
        {[
          { q: "Do I have to pay anything upfront?", a: "No. FlipSplit covers 100% of renovation costs. You don't pay anything until the home sells, and even then it comes out of proceeds — never out of your pocket." },
          { q: "What if the home doesn't sell for more than expected?", a: "Your guaranteed cash offer is locked in regardless of how the market performs. If the home sells below our projection, you still get your guaranteed amount. FlipSplit absorbs the renovation risk." },
          { q: "How long does the renovation take?", a: "Most renovations take 4–8 weeks depending on scope. We target a 30–45 day total close timeline — significantly faster than the 60–90 day traditional sale." },
          { q: "Can I stay in the home during renovation?", a: "In most cases we ask that the home be vacated during active renovation work. We can work around your schedule as part of your offer review." },
          { q: "Is FlipSplit the same as iBuying?", a: "No. iBuyers give you a discounted cash offer and keep all the upside. FlipSplit renovates your home to maximize its value — and gives you a share of that upside through profit participation." },
          { q: "What types of homes does FlipSplit work with?", a: "Single-family homes in Southern California. Condition doesn't matter — that's the point. Whether it needs cosmetic updates or significant repairs, we'll make it work." },
        ].map(({ q, a }) => (
          <details class="group border-b border-slate-200 py-1">
            <summary class="flex justify-between items-center py-5 cursor-pointer font-semibold text-brand-dark hover:text-brand-cyan transition-colors">
              {q}
              <span class="faq-icon text-slate-400 text-2xl leading-none ml-6 shrink-0">+</span>
            </summary>
            <div class="pb-5 text-slate-500 leading-relaxed">
              {a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── LEAD CAPTURE FORM ─── -->
  <section id="get-offer" class="py-28 px-6 bg-slate-50">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-wide mb-4" style="color: #4B5563;">Free. No obligation.</p>
      <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-[1.1] text-brand-dark mb-5">Get your free offer today.</h2>
      <p class="text-slate-500 text-lg leading-relaxed mb-10">
        Takes 2 minutes. We'll follow up with your cash offer amount, renovation plan, and profit participation projection.
      </p>
      <AddressForm id="footer-form" class="flex flex-col items-center" align="center" />
    </div>
  </section>

  <!-- ─── FOOTER ─── -->
  <Footer />

  <script>
    const slider  = document.getElementById('deal-slider');
    const offerEl = document.getElementById('offer-amount');
    const splitEl = document.getElementById('split-pct');
    const badgeEl = document.getElementById('split-badge');
    const tableEl = document.getElementById('earnings-table');
    const netEl   = document.getElementById('net-proceeds');

    // maxOffer = the upfront cash at slider=0 (max upfront cash position).
    // Resale projections are anchored to this so they stay static as the
    // slider moves — only the upfront/backend mix changes.
    let maxOffer = 465000;

    function fmt(n) {
      return '$' + Math.round(n).toLocaleString('en-US');
    }

    function updateTable(currentOffer, pct) {
      const projected  = Math.round(maxOffer * 1.2);
      const steps      = [0, 20000, 40000, 60000];
      const resaleRows = steps.map(s => projected + s);

      splitEl.textContent = pct + '%';
      badgeEl.textContent = pct + '% split';
      slider.style.setProperty('--fill', pct + '%');

      // Net proceeds = base-case total (first row in table: cash + bonus at projected resale)
      const baseBackend = Math.max(0, resaleRows[0] - currentOffer) * (pct / 100);
      netEl.textContent = fmt(currentOffer + baseBackend);

      tableEl.innerHTML = resaleRows.map((resale, i) => {
        const above   = Math.max(0, resale - currentOffer);
        const backend = above * (pct / 100);
        const total   = currentOffer + backend;
        const isBase  = i === 0;
        return `
          <div class="grid grid-cols-3 gap-x-2 px-1 py-1.5 rounded-lg ${isBase ? 'bg-slate-50' : ''}">
            <span class="text-brand-dark font-semibold text-xs">
              ${fmt(resale)}${isBase ? '<span class="ml-1 text-slate-400 font-normal">proj.</span>' : ''}
            </span>
            <span class="text-center text-xs ${backend > 0 ? 'font-semibold' : 'text-slate-400'}" style="${backend > 0 ? 'color:var(--brand-cyan)' : ''}">
              ${backend > 0 ? '+' + fmt(backend) : '—'}
            </span>
            <span class="text-right font-bold text-xs text-brand-dark">${fmt(total)}</span>
          </div>`;
      }).join('');
    }

    // Typing in the upfront offer field sets the new max-upfront amount
    // and snaps the slider back to 0% backend.
    offerEl.addEventListener('input', () => {
      const raw = offerEl.value.replace(/[^0-9]/g, '');
      offerEl.value = parseInt(raw || '0').toLocaleString('en-US');
      maxOffer = parseInt(raw) || 465000;
      slider.value = 0;
      updateTable(maxOffer, 0);
    });

    // Each 1% of backend trades $1,000 of upfront cash.
    slider.addEventListener('input', () => {
      const pct          = parseInt(slider.value);
      const currentOffer = Math.max(0, maxOffer - pct * 1000);
      offerEl.value = currentOffer.toLocaleString('en-US');
      updateTable(currentOffer, pct);
    });

    updateTable(maxOffer, 0);

    // ── How It Works auto-tour ──
    const hiwSteps = document.querySelectorAll('.hiw-step');
    let hiwIndex = 0;
    let hiwTimer;

    function hiwActivate(idx) {
      hiwIndex = ((idx % hiwSteps.length) + hiwSteps.length) % hiwSteps.length;
      hiwSteps.forEach((s, i) => {
        s.classList.toggle('hiw-active', i === hiwIndex);
        if (i !== hiwIndex) {
          const bar = s.querySelector('.hiw-bar');
          bar.style.animation = 'none';
          bar.style.width = '0%';
        }
        if (i === hiwIndex) {
          const bar = s.querySelector('.hiw-bar');
          bar.style.animation = 'none';
          bar.offsetWidth;
          if (hiwAutoPlay) {
            bar.style.width = '';
            bar.style.animation = '';
          } else {
            bar.style.width = '100%';
          }
        }
      });
      clearTimeout(hiwTimer);
      if (hiwAutoPlay) hiwTimer = setTimeout(() => hiwActivate(hiwIndex + 1), 4000);
    }

    let hiwAutoPlay = true;

    hiwSteps.forEach((step, i) => step.addEventListener('click', () => {
      hiwAutoPlay = false;
      clearTimeout(hiwTimer);
      hiwActivate(i);
    }));
    hiwActivate(0);

  </script>

</body>
