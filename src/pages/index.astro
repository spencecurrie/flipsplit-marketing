---
import '../styles/global.css'
import AddressForm from '../components/AddressForm.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>FlipSplit — Sell Your Home For More, Without the Hassle</title>
  <meta name="description" content="FlipSplit renovates your home before it hits the market. Get a guaranteed cash offer today plus a share of the upside when it sells for more. No repairs, no stress." />
  <ClientRouter />
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://use.typekit.net/tbd3esf.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --brand-cyan: #1e88e5;
      --brand-dark: #1E2A3A;
      --brand-body: #374151;
      --brand-blue: #1e88e5;
      --brand-coral: #F97066;
    }
    body { font-family: 'Open Sans', sans-serif; color: var(--brand-body); overflow-x: hidden; }
    h1, h2, h3, h4 { font-family: 'sahar', 'Open Sans', sans-serif; color: var(--brand-dark); }
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
    .faq-icon { transition: transform 0.2s ease; display: inline-block; }
    details[open] .faq-icon { transform: rotate(45deg); }
    .hiw-item[open] .hiw-chevron { transform: rotate(180deg); }
    @keyframes hiw-fill { from { width: 0%; } to { width: 100%; } }
    .hiw-step { transition: border-color 0.2s, box-shadow 0.2s; }
    .hiw-step.hiw-active { border-left-color: var(--brand-cyan) !important; box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
    .hiw-step.hiw-active .hiw-num { color: var(--brand-cyan) !important; }
    .hiw-step.hiw-active .hiw-title { color: var(--brand-dark) !important; }
    .hiw-step .hiw-body { max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s ease, opacity 0.4s ease, margin-top 0.4s ease; margin-top: 0; }
    .hiw-step.hiw-active .hiw-body { max-height: 100px; opacity: 1; margin-top: 0.375rem; }
    .hiw-step.hiw-active .hiw-bar { animation: hiw-fill 4s linear forwards; }
    .btn-primary { background: var(--brand-cyan); color: #ffffff; font-weight: 700; transition: filter 0.15s ease; }
    .btn-primary:hover { filter: brightness(1.08); }
    .text-brand-dark { color: var(--brand-dark); }
    .text-brand-cyan { color: var(--brand-cyan); }
    .bg-brand-dark { background: #1E2A3A; }
    input::placeholder { color: #9ca3af; }
    .dark-placeholder::placeholder { color: rgba(255,255,255,0.35); }
    select option { background: #fff; color: #374151; }
    .deal-slider {
      -webkit-appearance: none; appearance: none;
      width: 100%; height: 6px; border-radius: 3px;
      background: linear-gradient(to right, #1e88e5 var(--fill, 50%), #e2e8f0 var(--fill, 50%));
      outline: none; cursor: pointer;
    }
    .deal-slider::-webkit-slider-thumb {
      -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%;
      background: #1e88e5; border: 3px solid white; box-shadow: 0 1px 6px rgba(0,0,0,0.2); cursor: pointer;
    }
    .deal-slider::-moz-range-thumb {
      width: 20px; height: 20px; border-radius: 50%;
      background: #1e88e5; border: 3px solid white; box-shadow: 0 1px 6px rgba(0,0,0,0.2); cursor: pointer;
    }

    /* ── Draggable before/after sliders (case studies section) ─────────── */
    .ba-slider {
      position: relative;
      width: 100%;
      aspect-ratio: 3 / 2;
      overflow: hidden;
      background: #f1f5f9;
      cursor: ew-resize;
      user-select: none;
      touch-action: none;
      --pos: 50%;
    }
    .ba-slider img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none;
      -webkit-user-drag: none;
    }
    .ba-before { clip-path: inset(0 calc(100% - var(--pos)) 0 0); }
    .ba-handle {
      position: absolute; top: 0; bottom: 0;
      left: var(--pos);
      transform: translateX(-50%);
      pointer-events: none;
      display: flex; align-items: center; justify-content: center;
    }
    .ba-handle-line {
      position: absolute; top: 0; bottom: 0;
      width: 3px;
      background: #fff;
      box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
    }
    .ba-handle-grip {
      position: relative;
      width: 40px; height: 40px;
      border-radius: 50%;
      background: #fff;
      box-shadow: 0 4px 14px rgba(0,0,0,0.25);
      display: flex; align-items: center; justify-content: center;
    }
    .ba-label {
      position: absolute;
      top: 12px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      pointer-events: none;
    }
    .ba-label-before { left: 12px;  background: rgba(15,23,42,0.7); color: #fff; }
    .ba-label-after  { right: 12px; background: #1e88e5;            color: #fff; }
  </style>
</head>
<body class="bg-white antialiased">

  <Nav variant="solid" />

  <!-- ─── HERO ─── -->
  <section class="px-4 sm:px-6 pt-4 lg:pt-12 pb-8">
    <div class="relative overflow-hidden rounded-3xl shadow-xl mx-auto" style="min-height: 640px; max-width: 1640px;">
      <!-- Background photo -->
      <img
        src="/hero-family.png?v=3"
        alt="Family in front of their new home"
        class="absolute inset-0 w-full h-full object-cover object-right lg:object-center"
      />
      <!-- Mobile: flat uniform dark overlay (centered text needs even contrast) -->
      <div class="absolute inset-0 lg:hidden" style="background: rgba(10,20,35,0.6);"></div>
      <!-- Desktop: gradient overlay dark-on-left so left-aligned text reads, image shows on right -->
      <div class="absolute inset-0 hidden lg:block" style="background: linear-gradient(to right, rgba(10,20,35,0.78) 0%, rgba(10,20,35,0.55) 50%, rgba(10,20,35,0.15) 100%);"></div>

      <div class="relative px-6 sm:px-12 lg:px-16 py-16 lg:py-20 flex flex-col justify-center" style="min-height: 640px;">
        <div class="max-w-2xl lg:max-w-4xl text-center lg:text-left mx-auto lg:mx-0">
          <h1 class="text-[2.5rem] sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.08] mb-10 lg:mb-6 lg:whitespace-nowrap" style="color: #ffffff;">
            Cash now, plus more <span class="lg:block">when your home resells.</span>
          </h1>
          <p class="text-[13px] lg:text-lg mb-3 lg:mb-8 leading-relaxed max-w-2xl mx-auto lg:mx-0 text-white lg:text-white/[.78]">
