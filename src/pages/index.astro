      </div>

      <!-- Right: stacked case-study cards with draggable before/after sliders -->
      <div class="flex flex-col gap-8">

        <!-- Case 1: Kimball -->
        <article class="rounded-3xl overflow-hidden bg-white border border-slate-200">
          <div class="ba-slider" role="img" aria-label="Kimball Ave kitchen — drag to compare before and after">
            <img class="ba-after"  src="/casestudies/kimball-kitchen-after.jpg"  alt="Kimball Ave kitchen after renovation"  draggable="false" />
            <img class="ba-before" src="/casestudies/kimball-kitchen-before.jpg" alt="Kimball Ave kitchen before renovation" draggable="false" />
            <div class="ba-handle" aria-hidden="true">
              <div class="ba-handle-line"></div>
